iption\":\"This tool subtly alters images, helping them appear unique across platforms\",\"cloakingDetectionTitle\":\"Cloaking Detection\",\"cloakingDetectionDescription\":\"Detect whether a link redirects users to a different destination\",\"results\":\"{count, plural, one {{formattedCount} result} other {{formattedCount} results}}\",\"newResults24h\":\"{count, plural, one {+# new result} other {+# new results}}\",\"comingSoon\":\"Coming soon\",\"errorPlaceholderTitle\":\"Something went wrong\",\"errorPlaceholderText\":\"We couldn’t load this block. Please try again.\",\"managePlan\":\"Manage plan\",\"search_left\":\"{count, plural, one {\u003cSpan\u003e{count}\u003c/Span\u003e search left} other {\u003cSpan\u003e{count}\u003c/Span\u003e searches left}}\",\"earlyBirdBadge\":\"Welcome offer\",\"earlyBirdSubtitle\":\"3M+ new ads daily · every market · Meta + TikTok\",\"earlyBirdTitle\":\"Launch ads that already sell\",\"earlyBirdTimeLeft\":\"Offer expires in {time}\",\"earlyBirdCta\":\"Get it for ${price}\",\"earlyBirdDiscountOver70\":\"Save over 70%\",\"earlyBirdDiscountLabel\":\"today only\",\"earlyBirdRebill\":\"Then $69/mo. Cancel anytime.\"},\"onboarding\":{\"skip\":\"Skip\",\"stepIndicator\":\"{index} of {size}\",\"title\":\"Title\",\"content\":\"Content\",\"reactionsText\":\"What do you think about this update?\",\"reactionLike\":\"Like\",\"reactionDislike\":\"Dislike\",\"backButton\":\"Back\",\"nextButton\":\"Next\",\"finishButton\":\"Finish\",\"appsMenuTooltipTitle\":\"New in Apps\",\"appsMenuTooltipContent\":\"Open Apps to quickly jump from app-related ads to app analytics.\",\"appsGridTooltipTitle\":\"App card in Apps\",\"appsGridTooltipContent\":\"This button opens the related app in Apps.\",\"adDetailsTitle\":\"Detailed analytics for each ad\",\"adDetailsContent\":\"Evaluate all creative data, analyze each element, and search for ads by these parameters — in one click\",\"audienceReachTitle\":\"Analyze audience reach for European countries\",\"audienceReachContent\":\"Explore the audience that saw the ad and build hypotheses for your own advertising campaigns\",\"adDownloadTitle\":\"One click — and the creative is yours\",\"adDownloadContent\":\"Download in original quality or unique version and find all ads using the same media\",\"searchAdsTitle\":\"👋 Find any ad with Meta Ads\",\"searchAdsContent\":\"Search for ads in any niche and geo. Compare, save, get inspired\",\"filterSearchTitle\":\"📊 Refine your search with detailed filters\",\"filterSearchContent\":\"Additional parameters help quickly find the right ads. The more precise the settings — the deeper and more interesting the insights\",\"adListStudyTitle\":\"⬇️ Explore all ads for your query\",\"adListStudyContent\":\"Analyze, add to collections, compare, and explore detailed analytics for each one\",\"scaleBestPracticesTitle\":\"🧡 Scale the best\",\"scaleBestPracticesContent\":\"Find the best solutions and apply them to your own ad campaigns. If you have questions or suggestions — our support is always here for you\",\"welcome-title\":\"🎉 Welcome to Adheart!\",\"welcome-description\":\"Here’s a quick guide to finding your first winning ad\",\"welcome-button\":\"Let`s find some ads!\",\"step-registration-title\":\"Registration\",\"step-registration-description\":\"Join Adheart and unlock your journey\",\"step-first-search-title\":\"First Search\",\"step-first-search-description\":\"Discover key features and filters\",\"step-ad-details-title\":\"Ad Details\",\"step-ad-details-description\":\"See ad settings and statistics\",\"step-save-search-title\":\"Save Your Search\",\"step-save-search-description\":\"Learn how to save and revisit searches\",\"step-complete-setup-title\":\"Complete Setup\",\"step-complete-setup-description\":\"Finish the tour and claim 35 free searches\",\"onboarding-get-started-title\":\"Get started with Adheart\",\"onboarding-get-started-description\":\"Dive deeper and enjoy free ad searches!\",\"onboarding-title\":\"Onboarding:\",\"sa