---
import { getLocaleFromUrl, localizeRoutePath, t, defaultLocale, getAlternates, type Locale } from '../i18n/utils';
import SEO from '../components/SEO.astro';
import SignalBar from '../components/SignalBar.astro';
import SiteNavigation from '../components/SiteNavigation.astro';
import MobileNavigation from '../components/MobileNavigation.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  breadcrumbItems?: { name: string; href: string }[];
  noindex?: boolean;
  alternateUrls?: { lang: string; href: string }[];
  articleData?: {
    title: string;
    description: string;
    datePublished: Date;
    dateModified?: Date;
    authorName?: string;
    authorType?: 'Person' | 'Organization';
    authorUrl?: string;
    imageUrl?: string;
    categoria: string;
  };
}

const { title, description, breadcrumbItems, noindex, alternateUrls, articleData } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// Páginas sem equivalente em outros idiomas
const isOnlyPT = currentPath === '/404' || currentPath.startsWith('/404/');

// Resolve alternates: prioridade para prop explícita, depois fallback automático via routeMap
const alternates = alternateUrls || (isOnlyPT
  ? [{ lang: defaultLocale, href: localizeRoutePath(currentPath, defaultLocale) }]
  : getAlternates(currentPath));

// Mapa para lookup O(1) por locale
const alternateMap = new Map(alternates.map(a => [a.lang, a.href]));

// x-default: aponta para a URL PT-BR (quando existe)
const xDefaultHref = isOnlyPT ? null : alternateMap.get(defaultLocale);

// Detecta se é home page (com ou sem locale prefix)
const normalizedPath = currentPath.replace(/\/+$/, '') || '/';
const isHomePage = normalizedPath === '/' || normalizedPath === '/es';

const prefix = locale === defaultLocale ? '' : `/${locale}`;

// URL canônica absoluta para reúso em OG e Twitter
const SITE_BASE = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://radardigital.ai';
const canonicalUrl = `${SITE_BASE}${currentPath}`;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || t('layout.meta.desc', locale)} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#0a0b0f" id="theme-color" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/inter-variable-latin-ext.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || t('layout.meta.ogdesc', locale)} />
    <meta property="og:type" content={articleData ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Radar Digital" />
    <meta property="og:locale" content={locale === 'pt-BR' ? 'pt_BR' : 'es_ES'} />
    {articleData?.imageUrl && <meta property="og:image" content={`${SITE_BASE}${articleData.imageUrl}`} />}

    <!-- Twitter Cards -->
    <meta name="twitter:card" content={articleData?.imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || t('layout.meta.ogdesc', locale)} />
    {articleData?.imageUrl && <meta name="twitter:image" content={`${SITE_BASE}${articleData.imageUrl}`} />}

    <!-- hreflang para SEO internacional -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={Astro.site ? new URL(alt.href, Astro.site).toString() : alt.href} />
    ))}
    {xDefaultHref && (
      <link rel="alternate" hreflang="x-default" href={Astro.site ? new URL(xDefaultHref, Astro.site).toString() : xDefaultHref} />
    )}

    <!-- canonical: aponta pra propria versao dessa pagina -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Schema.org JSON-LD: WebSite (apenas nas home pages) -->
    {isHomePage && <SEO type="website" description={description || t('layout.meta.desc', locale)} locale={locale} />}

    {/* BreadcrumbList + Article passam via prop breadcrumbItems / slot <head> */}
    {breadcrumbItems && <SEO type="breadcrumb" items={breadcrumbItems} />}

    {articleData && (
      <SEO type="article"
        title={articleData.title}
        description={articleData.description}
        datePublished={articleData.datePublished}
        dateModified={articleData.dateModified}
        authorName={articleData.authorName}
        authorType={articleData.authorType}
        authorUrl={articleData.authorUrl}
        imageUrl={articleData.imageUrl}
        url={currentPath}
      />
    )}

    <title>{title} — Radar Digital</title>

    <script is:inline>
      (function() {
        const saved = localStorage.getItem('radar-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        const meta = document.querySelector('#theme-color');
        if (meta) {
          meta.content = document.documentElement.classList.contains('dark') ? '#0a0b0f' : '#f8fafc';
        }
      })();
    </script>
  </head>
  <body class="radar-bg">
    <!-- Scan line effect -->
    <div class="scan-line" aria-hidden="true"></div>

    <SignalBar locale={locale} alternates={alternates} />

    <!-- Header -->
    <header class="sticky top-0 z-50 backdrop-blur-xl border-b transition-colors duration-300"
            style="background: rgba(var(--color-surface, 248, 250, 252), 0.8); border-color: var(--color-border);">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-4" aria-label={t('nav.menu.label', locale)}>
        <!-- Logo -->
        <a href={`${prefix}/`} class="flex items-center gap-2.5 group shrink-0">
          <svg class="w-7 h-7 text-cyan-500 transition-transform group-hover:scale-110 duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a10 10 0 1 0 10 10" />
            <path d="M12 6a6 6 0 1 0 6 6" />
            <path d="M12 10a2 2 0 1 0 2 2" />
            <line x1="22" y1="2" x2="12" y2="12" />
            <line x1="12" y1="2" x2="12" y2="8" />
          </svg>
          <span class="text-xl font-bold tracking-tight text-text-primary transition-colors hidden sm:inline">
            Radar <span class="text-cyan-500">Digital</span>
          </span>
        </a>

        <!-- Navigation items + Locale + Theme (desktop) -->
        <div class="flex items-center gap-4 hidden lg:flex">
          <SiteNavigation locale={locale} currentPath={currentPath} alternates={alternates} />
        </div>

        <!-- Mobile navigation (hamburger + panel) -->
        <MobileNavigation locale={locale} currentPath={currentPath} alternates={alternates} />
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t transition-colors duration-300" style="border-color: var(--color-border);">
      <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-text-muted text-sm transition-colors">
          <svg class="w-4 h-4 text-cyan-500/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2a10 10 0 1 0 10 10" />
            <path d="M12 6a6 6 0 1 0 6 6" />
            <line x1="22" y1="2" x2="12" y2="12" />
          </svg>
          <span>{t('footer.copyright', locale)}</span>
        </div>
        <div class="flex gap-6 text-xs text-text-muted transition-colors">
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.privacidade', locale)}</a>
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.termos', locale)}</a>
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.contato', locale)}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        const toggles = document.querySelectorAll('.theme-toggle');
        const html = document.documentElement;
        const themeColor = document.querySelector('#theme-color');

        toggles.forEach(function(toggle) {
          toggle.addEventListener('click', function() {
            const isDark = html.classList.toggle('dark');
            localStorage.setItem('radar-theme', isDark ? 'dark' : 'light');
            if (themeColor) {
              themeColor.content = isDark ? '#0a0b0f' : '#f8fafc';
            }
          });
        });
      });
    </script>
  </body>
</html>
