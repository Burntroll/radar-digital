---
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, localizePath, t, languages, defaultLocale, getAlternates, routePath, type Locale } from '../i18n/utils';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  breadcrumbItems?: { name: string; href: string }[];
  noindex?: boolean;
  alternateUrls?: { lang: string; href: string }[];
  articleData?: {
    title: string;
    description: string;
    datePublished: Date;
    dateModified?: Date;
    authorName?: string;
    imageUrl?: string;
    categoria: string;
  };
}

const { title, description, breadcrumbItems, noindex, alternateUrls, articleData } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const altPath = Astro.url.pathname.replace(/^\/es/, '').replace(/^\/pt-BR/, '') || '/';

// 404 e outras páginas sem equivalente ES nao devem ter hreflang es
// Adicione mais paths aqui se criar páginas sem versão em espanhol
const isOnlyPT = currentPath === '/404' || currentPath.startsWith('/404/');
// Se alternateUrls foi passado explicitamente, usa ele; senao usa logica atual
const alternates = alternateUrls || (isOnlyPT
  ? [{ lang: defaultLocale, href: localizePath(altPath, defaultLocale) }]
  : getAlternates(altPath));

// Puxa categorias de parceiros (sem filtro de locale — são estruturais)
const parceiroCategorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false)
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));

const prefix = locale === defaultLocale ? '' : `/${locale}`;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || t('layout.meta.desc', locale)} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#0a0b0f" id="theme-color" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || t('layout.meta.ogdesc', locale)} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'pt-BR' ? 'pt_BR' : 'es_ES'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- hreflang para SEO internacional -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={Astro.site ? new URL(alt.href, Astro.site).toString() : alt.href} />
    ))}
    {isOnlyPT ? null : (
      <link rel="alternate" hreflang="x-default" href={Astro.site ? new URL(alternateUrls ? alternateUrls.find(a => a.lang === defaultLocale)?.href || localizePath(altPath, defaultLocale) : localizePath(altPath, defaultLocale), Astro.site).toString() : (alternateUrls ? alternateUrls.find(a => a.lang === defaultLocale)?.href || localizePath(altPath, defaultLocale) : localizePath(altPath, defaultLocale))} />
    )}

    <!-- canonical: aponta pra propria versao dessa pagina -->
    <link rel="canonical" href={Astro.site ? new URL(currentPath, Astro.site).toString() : currentPath} />

    <!-- Schema.org JSON-LD: WebSite (presente em todas as paginas) -->
    <SEO type="website" />

    {/* BreadcrumbList + Article passam via prop breadcrumbItems / slot <head> */}
    {breadcrumbItems && <SEO type="breadcrumb" items={breadcrumbItems} />}

    {articleData && (
      <SEO type="article"
        title={articleData.title}
        description={articleData.description}
        datePublished={articleData.datePublished}
        dateModified={articleData.dateModified}
        authorName={articleData.authorName}
        imageUrl={articleData.imageUrl}
        url={currentPath}
      />
    )}

    <title>{title} — Radar Digital</title>

    <script is:inline>
      (function() {
        const saved = localStorage.getItem('radar-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        const meta = document.querySelector('#theme-color');
        if (meta) {
          meta.content = document.documentElement.classList.contains('dark') ? '#0a0b0f' : '#f8fafc';
        }
      })();
    </script>
  </head>
  <body class="radar-bg">
    <!-- Scan line effect -->
    <div class="scan-line" aria-hidden="true"></div>

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl border-b transition-colors duration-300"
            style="background: rgba(var(--color-surface, 248, 250, 252), 0.8); border-color: var(--color-border);">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={`${prefix}/`} class="flex items-center gap-2.5 group">
          <svg class="w-7 h-7 text-cyan-500 transition-transform group-hover:scale-110 duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a10 10 0 1 0 10 10" />
            <path d="M12 6a6 6 0 1 0 6 6" />
            <path d="M12 10a2 2 0 1 0 2 2" />
            <line x1="22" y1="2" x2="12" y2="12" />
            <line x1="12" y1="2" x2="12" y2="8" />
          </svg>
          <span class="text-xl font-bold tracking-tight text-text-primary transition-colors">
            Radar <span class="text-cyan-500">Digital</span>
          </span>
        </a>

        <div class="flex items-center gap-6">
          <a href={`${prefix}/`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">{t('nav.home', locale)}</a>
          <a href={`${prefix}/marketing-digital`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">{t('nav.marketing', locale)}</a>
          <a href={`${prefix}/inteligencia-artificial`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">{t('nav.ia', locale)}</a>
          <a href={`${prefix}/monetizacao`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">{t('nav.monetizacao', locale)}</a>

          <!-- Parceiros com dropdown -->
          <div class="relative group">
            <a href={`${prefix}/parceiros`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors flex items-center gap-1">
              {t('nav.parceiros', locale)}
              <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
              </svg>
            </a>

            <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="w-56 rounded-xl border shadow-2xl overflow-hidden transition-colors"
                   style="background: var(--color-surface-elevated, #15171f); border-color: var(--color-border, #1e2130);">
              <div class="py-1">
                  {parceiroCategorias.map((cat) => (
                    <a
                      href={`${prefix}/parceiros/${cat.slug}`}
                      class="block px-4 py-2.5 text-sm text-text-secondary hover:bg-cyan-500/10 hover:text-cyan-500 transition-colors"
                    >
                      {cat.data.title}
                    </a>
                  ))}
                </div>
                <div class="border-t transition-colors" style="border-color: var(--color-border, #1e2130);">
                  <a
                    href={`${prefix}/parceiros`}
                    class="flex items-center gap-2 px-4 py-3 text-xs font-semibold text-cyan-500 hover:bg-cyan-500/10 transition-colors"
                  >
                    {t('parceiros.detail.cta.see', locale)}
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Guias -->
          <a href={`${prefix}/guias`} class="text-base text-text-secondary hover:text-purple-500 transition-colors">{t('nav.guias', locale)}</a>

          <!-- Bonus -->
          <a href={routePath('bonus', locale)} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">            {t('nav.bonus', locale)}
          </a>

          <!-- Radar Market -->
          <a href={`${prefix}/market`} class="text-base text-text-secondary hover:text-cyan-500 transition-colors">
            {t('nav.market', locale)}
          </a>

          <!-- Locale Switcher -->
          <div class="relative group">
            <button class="text-base text-text-secondary hover:text-cyan-500 transition-colors flex items-center gap-1.5 px-2" aria-label={t('locale.switcher.label', locale)}>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
              </svg>
              <span class="text-xs font-semibold uppercase">{t('layout.locale.label', locale)}</span>
            </button>

            <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="w-40 rounded-xl border shadow-2xl overflow-hidden transition-colors"
                   style="background: var(--color-surface-elevated, #15171f); border-color: var(--color-border, #1e2130);">
                {(Object.keys(languages) as Locale[]).map((lang) => {
                  const href = localizePath(altPath, lang);
                  const isCurrent = lang === locale;
                  return (
                    <a
                      href={href}
                      class={`block px-4 py-2.5 text-sm transition-colors ${isCurrent ? 'text-cyan-500 font-semibold bg-cyan-500/10 locale-active' : 'text-text-secondary hover:bg-cyan-500/10 hover:text-cyan-500'}`}
                      aria-current={isCurrent ? 'true' : 'false'}
                    >
                      <span class="flex items-center justify-between">
                        <span>{languages[lang]}</span>
                        <span class="text-[10px] font-bold uppercase opacity-60">{t('layout.locale.label', lang)}</span>
                      </span>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>

          <!-- Theme Toggle -->
          <button id="theme-toggle" class="theme-toggle" aria-label={t('theme.toggle', locale)}>
            <svg class="sun-icon w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
            <svg class="moon-icon w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t transition-colors duration-300" style="border-color: var(--color-border);">
      <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-text-muted text-sm transition-colors">
          <svg class="w-4 h-4 text-cyan-500/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2a10 10 0 1 0 10 10" />
            <path d="M12 6a6 6 0 1 0 6 6" />
            <line x1="22" y1="2" x2="12" y2="12" />
          </svg>
          <span>{t('footer.copyright', locale)}</span>
        </div>
        <div class="flex gap-6 text-xs text-text-muted transition-colors">
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.privacidade', locale)}</a>
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.termos', locale)}</a>
          <a href="#" class="hover:text-cyan-500 transition-colors">{t('footer.contato', locale)}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        const toggle = document.getElementById('theme-toggle');
        const html = document.documentElement;
        const themeColor = document.querySelector('#theme-color');

        toggle.addEventListener('click', function() {
          const isDark = html.classList.toggle('dark');
          localStorage.setItem('radar-theme', isDark ? 'dark' : 'light');
          if (themeColor) {
            themeColor.content = isDark ? '#0a0b0f' : '#f8fafc';
          }
        });
      });
    </script>
  </body>
</html>
