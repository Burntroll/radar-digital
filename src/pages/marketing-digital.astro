---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, getDateLocale, type Locale } from '../i18n/utils';
import { routePath } from '../i18n/utils';
import CategoryArticleCard from '../components/CategoryArticleCard.astro';
import { matchesPublishedPrimaryHub } from '../utils/editorialDistribution';

const locale: Locale = getLocaleFromUrl(Astro.url);
const categoria = 'marketing-digital';
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const categoriaInfo = {
  slug: 'marketing-digital',
  name: t('cat.marketing.name', locale),
  tagline: t('cat.marketing.tagline', locale),
  description: t('cat.marketing.desc', locale),
  color: 'cyan',
  emoji: '',
};

const publicados = await getCollection('artigos', ({ data }) =>
  matchesPublishedPrimaryHub(data, { primaryHub: 'digital-marketing', locale }) && data.contentType !== 'guide'
);
publicados.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<Layout 
  title={categoriaInfo.name} 
  description={categoriaInfo.description}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: categoriaInfo.name, href: prefix + '/' + categoria}
  ]}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO DA CATEGORIA -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-surface transition-colors duration-300">
    <!-- Background glow cyan -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, transparent 60%);"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] rounded-full opacity-10 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 60%);"></div>

    <!-- Breadcrumb -->
    <div class="max-w-6xl mx-auto px-6 relative z-10 mb-8">
      <nav class="flex items-center gap-2 text-xs text-text-muted transition-colors">
        <a href={`${prefix}/`} class="hover:text-cyan-500 transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-cyan-500">{categoriaInfo.name}</span>
      </nav>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary transition-colors">{categoriaInfo.name.split(' ')[0]}</span>
        <span class="gradient-text"> {categoriaInfo.name.split(' ').slice(1).join(' ')}</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed transition-colors">
        {categoriaInfo.description}
      </p>

      <!-- Stats da categoria -->
      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-cyan-500">
            {publicados.length}
          </div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('cat.articles.published', locale)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- ARTIGOS -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="section-title mt-4 text-text-primary transition-colors">{locale === 'pt-BR' ? 'Artigos do' : 'Artículos del'} <span class="text-cyan-500">radar</span></h2>
          <p class="section-subtitle">{locale === 'pt-BR' ? 'Conteúdo prático sobre o que funciona em marketing digital hoje.' : 'Contenido práctico sobre lo que funciona en marketing digital hoy.'}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {publicados.map((artigo) => (
          <CategoryArticleCard article={artigo} locale={locale} accent="cyan" />
        ))}
      </div>

      <!-- CTA voltar -->
      <div class="mt-16 text-center">
        <a href={`${prefix}/`} class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-cyan-500 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          {t('cat.cta.back', locale)}
        </a>
      </div>
    </div>
  </section>
</Layout>
