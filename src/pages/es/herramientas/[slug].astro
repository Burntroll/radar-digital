---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, type Locale } from '../../../i18n/utils';
import { routePath } from '../../../i18n/utils';
import EmptyState from '../../../components/EmptyState.astro';

export async function getStaticPaths() {
  const categorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false);
  return categorias.map((categoria) => ({
    params: { slug: categoria.slug },
    props: { categoria },
  }));
}

interface Props {
  categoria: CollectionEntry<'parceiroCategorias'>;
}

const { categoria } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const todosParceiros = await getCollection('parceiros', ({ data }) => data.draft === false);
const parceiros = todosParceiros
  .filter((p) => p.data.category === categoria.slug && (p.data.locale || 'pt-BR') === locale)
  .sort((a, b) => a.data.name.localeCompare(b.data.name, locale === 'pt-BR' ? 'pt-BR' : 'es', { sensitivity: 'base' }));

const todasCategorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false);
const outrasCategorias = todasCategorias
  .filter((c) => c.slug !== categoria.slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const catDesc = categoria.data.descriptionEs;
if (!catDesc && !categoria.data.draft) {
  throw new Error(`[i18n] Missing descriptionEs for published category "${categoria.slug}"`);
}
---

<Layout 
  title={`${categoria.data.title} — ${t('nav.parceiros', locale)}`} 
  description={catDesc}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: t('nav.parceiros', locale), href: routePath('parceiros', locale)},
    {name: categoria.data.title, href: routePath('parceiros', locale) + '/' + categoria.slug}
  ]}
>
  <section class="relative pt-32 pb-16 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, transparent 60%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 transition-colors">
        <a href={`${prefix}/`} class="hover:text-text-primary transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <a href={routePath('parceiros', locale)} class="hover:text-cyan-500 transition-colors">{t('nav.parceiros', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-cyan-500">{categoria.data.title}</span>
      </nav>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6 text-text-primary transition-colors">
        {categoria.data.title}
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-3xl leading-relaxed transition-colors">
        {catDesc}
      </p>

      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-text-primary transition-colors">{parceiros.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('parceiros.stats.tools', locale)}</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-cyan-500">{parceiros.filter(p => p.data.featured).length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('parceiros.stats.destaques', locale)}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="section-title text-text-primary transition-colors">{t('parceiros.slug.section.prefix', locale)} <span class="text-cyan-500">segmento</span></h2>
        </div>
      </div>

      {parceiros.length === 0 ? (
        <EmptyState
          icon="🚧"
          title={t('cat.empty.title', locale)}
          description={t('parceiros.slug.empty', locale)}
        />
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {parceiros.map((parceiro) => (
            <article class={`glass-card overflow-hidden group flex flex-col ${parceiro.data.featured ? 'ring-1 ring-cyan-500/30' : ''}`}>
              <div class="relative h-[180px] bg-gradient-to-br from-cyan-500/10 via-surface-elevated to-surface flex items-center justify-center border-b transition-colors" style="border-color: var(--color-border);">
                {parceiro.data.logo ? (
                  <img src={parceiro.data.logo} alt={`${parceiro.data.name} logo`} class="w-24 h-24 rounded-2xl object-contain bg-surface-elevated border group-hover:scale-105 transition-transform" style="border-color: var(--color-border);" loading="lazy" />
                ) : (
                  <div class="w-24 h-24 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-3xl font-black text-cyan-500">
                    {parceiro.data.name.charAt(0).toUpperCase()}
                  </div>
                )}
                {parceiro.data.featured && (
                  <span class="absolute top-3 right-3 inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[9px] font-semibold uppercase tracking-wider bg-cyan-500/10 text-cyan-500 border border-cyan-500/20 backdrop-blur">
                    <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    {t('cat.tag.featured', locale)}
                  </span>
                )}
              </div>

              <div class="p-6 flex-1 flex flex-col">
                <h3 class="font-bold text-lg text-text-primary leading-tight mb-2">{parceiro.data.name}</h3>
                <p class="text-xs text-text-muted leading-relaxed mb-4 flex-1 transition-colors">{parceiro.data.excerpt}</p>

                {parceiro.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {parceiro.data.tags.slice(0, 4).map((tag) => (
                      <span class="inline-block px-2 py-0.5 rounded text-[9px] font-medium bg-surface-elevated text-text-muted border" style="border-color: var(--color-border);">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                {parceiro.data.languages.length > 0 && (
                  <div class="flex items-center gap-1.5 text-[10px] text-text-muted mb-4">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
                    </svg>
                    {parceiro.data.languages.join(' · ')}
                  </div>
                )}

                <a href={parceiro.data.website} target="_blank" rel="noopener noreferrer sponsored" class="mt-auto inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-500/30 hover:border-cyan-500/50 text-cyan-500 text-sm font-semibold transition-all group-hover:gap-3">
                  {parceiro.data.buttonText}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  {outrasCategorias.length > 0 && (
    <section class="py-16 border-t transition-colors" style="border-color: var(--color-border);">
      <div class="max-w-6xl mx-auto px-6">
        <h3 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-6">{t('parceiros.slug.other', locale)}</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {outrasCategorias.map((outra) => (
            <a href={routePath('parceiros', locale) + '/' + outra.slug} class="px-4 py-3 rounded-lg bg-surface-elevated border hover:border-cyan-500/30 hover:text-cyan-500" style="border-color: var(--color-border);">
              <div class="text-sm font-semibold text-text-primary">{outra.data.title}</div>
            </a>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href={routePath('parceiros', locale)} class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-cyan-500 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            {t('cat.cta.back.parceiros', locale)}
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>
