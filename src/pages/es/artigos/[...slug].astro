---
import { getCollection } from 'astro:content';

// ═══════════════════════════════════════════════════════════
// REDIRECT FALLBACK (local dev)
// Gera uma página de redirect para cada artigo ES no slug
// antigo. Em producao, o vercel.json faz o redirect 308 real.
// ═══════════════════════════════════════════════════════════

export async function getStaticPaths() {
  const artigos = await getCollection('artigos', ({ data }) => data.draft === false && data.locale === 'es');
  return artigos.map((artigo) => ({
    params: { slug: artigo.slug },
  }));
}

const { slug } = Astro.params;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="refresh" content={`0; url=/es/articulos/${slug}/`} />
</head>
<body>
  <p>Redirigiendo a <a href={`/es/articulos/${slug}/`}>/es/articulos/{slug}/</a>...</p>
</body>
</html>
