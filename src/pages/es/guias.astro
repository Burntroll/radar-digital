---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, getDateLocale, type Locale } from '../../i18n/utils';
import { routePath } from '../../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const artigos = await getCollection('artigos', ({ data }) => data.draft === false && data.contentType === 'guide');
const guias = artigos
  .filter((a) => (a.data.locale || 'pt-BR') === locale)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const filterTags = [
  'meta-ads', 'tiktok-ads', 'google-ads', 'seo', 'redes-sociais', 'youtube',
  'email-marketing', 'inteligencia-artificial', 'prompts', 'automacao',
  'afiliados-cpa', 'igaming-betting', 'crypto', 'e-commerce', 'marketplaces',
  'monetizacao', 'analytics-tracking', 'ferramentas', 'proxies', 'antidetect',
  'criativos', 'seguranca-contas', 'conteudo',
];

const colorMap: Record<string, string> = {
  cyan: 'from-cyan-500/10 via-blue-600/5',
  purple: 'from-purple-500/10 via-pink-600/5',
  amber: 'from-amber-500/10 via-orange-600/5',
};

const colorAccent: Record<string, string> = {
  cyan: 'text-cyan-500',
  purple: 'text-purple-500',
  amber: 'text-amber-500',
};
---

<Layout 
  title={locale === 'pt-BR' ? 'Guias de Marketing Digital, IA e Monetização | Radar Digital' : 'Guías de Marketing Digital, IA y Monetización | Radar Digital'} 
  description={locale === 'pt-BR' ? 'Tutoriais, checklists e guias práticos sobre marketing digital, inteligência artificial, tráfego pago, afiliados, monetização e ferramentas digitais.' : 'Tutoriales, checklists y guías prácticas sobre marketing digital, inteligencia artificial, tráfico pago, afiliados, monetización y herramientas digitales.'}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: t('nav.guias', locale), href: prefix + '/guias'}
  ]}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, rgba(124, 58, 237, 0.1) 40%, transparent 60%);"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 transition-colors">
        <a href={`${prefix}/`} class="hover:text-cyan-500 transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-purple-500">{t('nav.guias', locale)}</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary transition-colors">{t('guias.title', locale)}</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed transition-colors">
        {t('guias.subtitle', locale)}
      </p>
      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-purple-500">{guias.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('nav.guias', locale)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- BUSCA + FILTROS + CONTEÚDO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Campo de busca -->
      <div class="mb-6">
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--color-text-muted, '#64748b');" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
          <input
            id="guide-search"
            type="text"
            placeholder={t('guias.search.placeholder', locale)}
            class="w-full px-10 py-3 rounded-xl text-sm transition-all duration-200 outline-none focus:ring-2 focus:ring-cyan-500/30"
            style="background: var(--color-surface-elevated, '#15171f'); color: var(--color-text-primary); border: 1px solid var(--color-border, '#1e293b');"
          />
        </div>
      </div>

      <!-- Filtros por tema -->
      <div id="guide-filters" class="flex flex-wrap gap-2 mb-8" role="tablist" aria-label="Filtrar por tema">
        <button
          class="filter-chip active px-4 py-2 rounded-full text-xs font-medium border transition-all duration-200 cursor-pointer"
          style="background: rgba(124, 58, 237, 0.12); color: #a855f7; border-color: rgba(124, 58, 237, 0.3);"
          data-tag="all"
          role="tab"
          aria-selected="true"
        >
          {t('guias.filter.all', locale)}
        </button>
        {filterTags.map((tag) => (
          <button
            class="filter-chip px-4 py-2 rounded-full text-xs font-medium border transition-all duration-200 cursor-pointer"
            style="background: transparent; color: var(--color-text-secondary, '#94a3b8'); border-color: var(--color-border, '#1e293b');"
            data-tag={tag}
            role="tab"
            aria-selected="false"
          >
            {t(('guias.filter.' + tag) as any, locale)}
          </button>
        ))}
      </div>

      <!-- Espacio reservado para anuncio -->
      <div class="w-full rounded-xl border overflow-hidden mb-10 transition-colors flex items-center justify-center"
           style="min-height: 100px; background: var(--color-surface-elevated, '#15171f'); border-color: var(--color-border, '#1e2130');">
        <div class="text-center py-6">
          <svg class="w-5 h-5 mx-auto mb-1.5" style="color: var(--color-text-muted, '#64748b');" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m0 0V5.625m0 0a1.125 1.125 0 011.125-1.125h3.75c.621 0 1.125.504 1.125 1.125m-6.75 0V19.5m6.75-13.875v13.875m0 0h3.75c.621 0 1.125-.504 1.125-1.125V7.5c0-.621-.504-1.125-1.125-1.125h-3.75"/>
          </svg>
          <span class="text-[11px] uppercase tracking-wider font-medium" style="color: var(--color-text-muted, '#64748b');">
            {t('guias.ad.placeholder', locale)}
          </span>
        </div>
      </div>

      <!-- Grid de cards -->
      <div id="guide-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {guias.length === 0 ? (
          <p class="col-span-full text-center text-text-muted text-sm py-16 transition-colors">
            {t('guias.empty.title', locale)}
          </p>
        ) : (
          guias.map((guia) => {
            const grad = colorMap[guia.data.color] || colorMap.cyan;
            const accent = colorAccent[guia.data.color] || colorAccent.cyan;
            const categoriaNome = guia.data.categoria === 'marketing-digital' ? t('cat.marketing.name', locale)
              : guia.data.categoria === 'inteligencia-artificial' ? t('cat.ia.name', locale)
              : t('cat.monetizacao.name', locale);
            const dateStr = guia.data.date.toLocaleDateString(getDateLocale(locale), {
              day: '2-digit', month: 'short', year: 'numeric'
            });
            const tags = guia.data.guideTags || [];
            return (
              <article class="glass-card interactive-card overflow-hidden group flex flex-col" data-tags={tags.join(',')}>
                <a href={routePath('artigos', locale, guia.slug)} class="block flex flex-col flex-1">
                  <div class={`h-36 bg-gradient-to-br ${grad} to-surface-elevated flex items-center justify-center transition-colors`}>
                    <span class="text-3xl">{guia.data.emoji || '📡'}</span>
                  </div>
                  <div class="p-5 flex flex-col flex-1">
                    <div class="flex items-center gap-2 text-[10px] text-text-muted uppercase tracking-wider mb-2">
                      <span class={`font-semibold ${accent}`}>{categoriaNome}</span>
                      {guia.data.guideType && (
                        <>
                          <span>·</span>
                          <span>{guia.data.guideType}</span>
                        </>
                      )}
                    </div>
                    <h3 class="font-semibold text-text-primary group-hover:text-cyan-500 transition-colors text-sm leading-snug mb-2">
                      {guia.data.title}
                    </h3>
                    <p class="text-xs text-text-muted leading-relaxed line-clamp-2 mb-3 transition-colors">
                      {guia.data.excerpt}
                    </p>
                    {tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {tags.slice(0, 3).map((tag) => (
                          <span class="inline-block px-1.5 py-0.5 rounded text-[9px] font-medium bg-surface-elevated text-text-muted border transition-colors" style="border-color: var(--color-border);">
                            {t(('guias.filter.' + tag) as any, locale)}
                          </span>
                        ))}
                      </div>
                    )}
                    <div class="mt-auto pt-3 border-t transition-colors flex items-center justify-between" style="border-color: var(--color-border);">
                      <div class="flex items-center gap-2 text-[10px] text-text-muted">
                        <span>{guia.data.readTime}</span>
                        <span>·</span>
                        <time datetime={guia.data.date.toISOString()}>{dateStr}</time>
                      </div>
                      <span class="text-xs font-medium text-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity">
                        {t('guias.cta.read', locale)}
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })
        )}
      </div>
    </div>
  </section>
</Layout>

<!-- Client-side search + filter logic -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.querySelector<HTMLInputElement>('#guide-search');
    const chips = document.querySelectorAll<HTMLButtonElement>('#guide-filters .filter-chip');
    const cards = document.querySelectorAll<HTMLElement>('#guide-grid > article');

    function filterCards() {
      if (!searchInput) return;
      const query = (searchInput.value || '').toLowerCase().trim();
      const activeChip = document.querySelector<HTMLButtonElement>('#guide-filters .filter-chip.active');
      const activeTag = activeChip?.dataset?.tag || 'all';

      let visibleCount = 0;
      cards.forEach(card => {
        const cardTags = (card.dataset.tags || '').toLowerCase();
        const cardTitle = card.querySelector('h3')?.textContent?.toLowerCase() || '';
        const cardExcerpt = card.querySelector('p')?.textContent?.toLowerCase() || '';
        const cardText = cardTitle + ' ' + cardExcerpt + ' ' + cardTags;

        const matchesTag = activeTag === 'all' || cardTags.includes(activeTag);
        const matchesSearch = !query || cardText.includes(query);

        if (matchesTag && matchesSearch) {
          card.style.display = 'flex';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      const noResults = document.querySelector<HTMLElement>('#guide-grid > p');
      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', filterCards);
    }

    chips.forEach(chip => {
      chip.addEventListener('click', function(this: HTMLButtonElement) {
        chips.forEach(c => {
          c.style.background = 'transparent';
          c.style.color = 'var(--color-text-secondary, #94a3b8)';
          c.style.borderColor = 'var(--color-border, #1e293b)';
          c.classList.remove('active');
          c.setAttribute('aria-selected', 'false');
        });
        this.style.background = 'rgba(124, 58, 237, 0.12)';
        this.style.color = '#a855f7';
        this.style.borderColor = 'rgba(124, 58, 237, 0.3)';
        this.classList.add('active');
        this.setAttribute('aria-selected', 'true');

        filterCards();
      });
    });
  });
</script>
