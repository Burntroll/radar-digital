---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, localizePath, t, defaultLocale, type Locale } from '../../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const artigosPublicados = await getCollection('artigos', ({ data }) =>
  data.draft === false && data.contentType === 'article' && (data.locale || 'pt-BR') === locale
);
const artigosRecentes = artigosPublicados
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Guias publicados (para el card de guía en Lee primero)
const guiasPublicados = await getCollection('artigos', ({ data }) =>
  data.draft === false && data.contentType === 'guide' && (data.locale || 'pt-BR') === locale
);
const guiaRecente = guiasPublicados
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];

const [artigoPrincipal, ...artigosSecundarios] = artigosRecentes;
---

<Layout title="Radar Digital" description="Tu radar de tendencias en marketing digital, inteligencia artificial y monetización."
  breadcrumbItems={[{name: t('nav.home', locale), href: prefix + '/'}]}>

  <AdSlot variant="horizontal" />

  <!-- ════════════════════════════════════════════════ -->
  <!-- APERTURA EDITORIAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pt-8 pb-6 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Masthead -->
      <div class="border-b pb-6 mb-8" style="border-color: var(--color-border);">
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight">
          <span class="text-text-primary">Radar</span>{' '}
          <span class="gradient-text">Digital</span>
        </h1>
        <p class="text-sm text-text-secondary mt-1.5 max-w-xl">
          Marketing, IA, monetización y herramientas para quien trabaja en internet.
        </p>
      </div>

      <!-- Section label: Lee primero -->
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Lee primero</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      {artigoPrincipal ? (
        <div class="grid lg:grid-cols-3 gap-6">

          <!-- COLUMNA PRINCIPAL (2/3): Artículo Principal -->
          <div class="lg:col-span-2">
            <a
              href={`${prefix}/artigos/${artigoPrincipal.slug}`}
              class="group block glass-card overflow-hidden"
            >
              <div class={`h-52 sm:h-64 bg-gradient-to-br ${
                artigoPrincipal.data.color === 'purple' ? 'from-purple-500/10 via-pink-600/5' :
                artigoPrincipal.data.color === 'amber' ? 'from-amber-500/10 via-orange-600/5' :
                'from-cyan-500/10 via-blue-600/5'
              } to-surface-elevated flex items-center justify-center transition-colors`}>
                <span class="text-5xl sm:text-6xl">{artigoPrincipal.data.emoji || '📡'}</span>
              </div>
              <div class="p-5 sm:p-6">
                <div class="flex items-center gap-2 text-xs text-text-muted mb-2 transition-colors">
                  <span class="font-semibold uppercase tracking-wider">{artigoPrincipal.data.subtema}</span>
                  <span>·</span>
                  <span>{artigoPrincipal.data.readTime}</span>
                </div>
                <h3 class="text-xl sm:text-2xl font-bold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug">
                  {artigoPrincipal.data.title}
                </h3>
                <p class="text-sm text-text-secondary mt-2 leading-relaxed transition-colors line-clamp-2">
                  {artigoPrincipal.data.excerpt}
                </p>
                <div class="flex items-center justify-between mt-4 pt-3 border-t transition-colors" style="border-color: var(--color-border);">
                  <time class="text-xs text-text-muted">
                    {artigoPrincipal.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </time>
                  <span class="text-xs font-medium text-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity">Leer</span>
                </div>
              </div>
            </a>
          </div>

          <!-- COLUMNA LATERAL (1/3): Secundarios + Guía -->
          <div class="flex flex-col gap-4">

            {artigosSecundarios.map((artigo) => {
              const dateStr = artigo.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
              return (
                <a
                  href={`${prefix}/artigos/${artigo.slug}`}
                  class="group flex gap-4 glass-card p-4 items-start"
                >
                  <div class={`w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br ${
                    artigo.data.color === 'purple' ? 'from-purple-500/10 via-pink-600/5' :
                    artigo.data.color === 'amber' ? 'from-amber-500/10 via-orange-600/5' :
                    'from-cyan-500/10 via-blue-600/5'
                  } to-surface-elevated flex items-center justify-center transition-colors`}>
                    <span class="text-xl">{artigo.data.emoji || '📡'}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-1.5 text-[10px] text-text-muted uppercase tracking-wider mb-1">
                      <span>{artigo.data.subtema}</span>
                      <span>·</span>
                      <span>{artigo.data.readTime}</span>
                    </div>
                    <h3 class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug line-clamp-2">
                      {artigo.data.title}
                    </h3>
                    <time class="text-[10px] text-text-muted mt-1 block">{dateStr}</time>
                  </div>
                </a>
              );
            })}

            <!-- Card de Guía (si hay publicado) -->
            {guiaRecente && (
              <a
                href={`${prefix}/artigos/${guiaRecente.slug}`}
                class="group flex gap-4 glass-card p-4 items-start"
                style="border-color: rgba(168, 85, 247, 0.2);"
              >
                <div class="w-12 h-12 shrink-0 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
                  <span class="text-xl">{guiaRecente.data.emoji || '📋'}</span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-1.5 text-[10px] text-purple-500 font-semibold uppercase tracking-wider mb-1">
                    <span>Guía</span>
                    <span>·</span>
                    <span>{guiaRecente.data.readTime}</span>
                  </div>
                  <h3 class="text-sm font-semibold text-text-primary group-hover:text-purple-500 transition-colors leading-snug line-clamp-2">
                    {guiaRecente.data.title}
                  </h3>
                </div>
              </a>
            )}

          </div>

        </div>
      ) : (
        <p class="text-sm text-text-muted text-center py-12">
          Ningún artículo publicado aún.
        </p>
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- NAVEGACIÓN POR INTENCIÓN -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-16 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section label -->
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">¿Qué quieres resolver hoy?</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 1. Tráfico -->
        <a href={`${prefix}/marketing-digital`} class="group flex items-start gap-4 glass-card p-5">
          <span class="text-2xl shrink-0 mt-0.5">📈</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quiero generar más tráfico</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Estrategias para atraer más visitantes, clics y oportunidades.</p>
          </div>
        </a>

        <!-- 2. IA -->
        <a href={`${prefix}/inteligencia-artificial`} class="group flex items-start gap-4 glass-card p-5">
          <span class="text-2xl shrink-0 mt-0.5">🤖</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quiero usar IA en el trabajo</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Prompts, herramientas y flujos prácticos para ganar productividad.</p>
          </div>
        </a>

        <!-- 3. Monetizar -->
        <a href={`${prefix}/monetizacao`} class="group flex items-start gap-4 glass-card p-5">
          <span class="text-2xl shrink-0 mt-0.5">💰</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quiero monetizar contenido</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Ideas para transformar audiencia, blogs y proyectos digitales en ingresos.</p>
          </div>
        </a>

        <!-- 4. Guías -->
        <a href={`${prefix}/guias`} class="group flex items-start gap-4 glass-card p-5" style="border-color: rgba(168, 85, 247, 0.15);">
          <span class="text-2xl shrink-0 mt-0.5">📋</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-purple-500 transition-colors">Quiero organizar operaciones digitales</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Guías y checklists para trabajar mejor con cuentas, accesos y procesos.</p>
          </div>
        </a>

        <!-- 5. Herramientas -->
        <a href={`${prefix}/parceiros`} class="group flex items-start gap-4 glass-card p-5">
          <span class="text-2xl shrink-0 mt-0.5">🧰</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quiero encontrar herramientas</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Categorías de herramientas útiles para marketing, tráfico y monetización.</p>
          </div>
        </a>

        <!-- 6. Bonos -->
        <a href={`${prefix}/bonus`} class="group flex items-start gap-4 glass-card p-5">
          <span class="text-2xl shrink-0 mt-0.5">🎁</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quiero ver bonos y códigos</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Condiciones promocionales y beneficios verificados.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section id="artigos" class="py-16 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section label -->
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Últimas publicaciones</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      {artigosPublicados.length === 0 ? (
        <p class="text-sm text-text-muted text-center py-12">Ningún artículo publicado aún. Vuelve pronto.</p>
      ) : (
        <div class="grid lg:grid-cols-3 gap-10">

          <!-- COLUMNA PRINCIPAL: Lista editorial -->
          <div class="lg:col-span-2">
            <div class="flex flex-col">
              {artigosPublicados
                .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
                .map((artigo, idx) => {
                  const dateStr = artigo.data.date.toLocaleDateString('es-ES', {
                    day: '2-digit', month: 'short', year: 'numeric'
                  });
                  return (
                    <div>
                      <a
                        href={`${prefix}/artigos/${artigo.slug}`}
                        class="group block py-5 first:pt-0"
                      >
                        <div class="flex items-center gap-2 text-xs text-text-muted mb-1.5">
                          <span class="font-semibold uppercase tracking-wider">{artigo.data.subtema}</span>
                          <span>·</span>
                          <span>{artigo.data.readTime}</span>
                        </div>
                        <h3 class="text-base sm:text-lg font-bold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug">
                          {artigo.data.title}
                        </h3>
                        <p class="text-sm text-text-secondary mt-1.5 leading-relaxed line-clamp-2">
                          {artigo.data.excerpt}
                        </p>
                        <time class="text-xs text-text-muted mt-2 block">{dateStr}</time>
                      </a>
                      {idx < artigosPublicados.length - 1 && (
                        <div class="h-px" style="background: var(--color-border);"></div>
                      )}
                    </div>
                  );
                })}

              <!-- AdSlot in-feed después de la lista -->
              <div class="mt-8">
                <AdSlot variant="in-feed" />
              </div>
            </div>
          </div>

          <!-- COLUMNA LATERAL: Recomendados -->
          <div class="lg:col-span-1">
            <div class="glass-card p-5">
              <h3 class="text-xs font-semibold uppercase tracking-[0.1em] text-text-muted mb-4">
                Recomendados por la redacción
              </h3>
              <div class="flex flex-col gap-3">
                {artigosPublicados
                  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
                  .slice(0, 3)
                  .map((artigo) => {
                    const dateStr = artigo.data.date.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
                    const colorAccent = artigo.data.color === 'purple' ? 'text-purple-500' :
                      artigo.data.color === 'amber' ? 'text-amber-500' : 'text-cyan-500';
                    return (
                      <a
                        href={`${prefix}/artigos/${artigo.slug}`}
                        class="group flex items-start gap-3"
                      >
                        <span class={`text-lg shrink-0 mt-0.5 ${colorAccent}`}>·</span>
                        <div class="min-w-0 flex-1">
                          <h4 class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug line-clamp-2">
                            {artigo.data.title}
                          </h4>
                          <div class="flex items-center gap-1.5 text-[10px] text-text-muted mt-1">
                            <span class="font-medium uppercase tracking-wider">{artigo.data.subtema}</span>
                            <span>·</span>
                            <time>{dateStr}</time>
                          </div>
                        </div>
                      </a>
                    );
                  })}
              </div>
            </div>
          </div>

        </div>
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- SECCIONES DEL RADAR -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-12 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Secciones del Radar</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href={`${prefix}/marketing-digital`} class="glass-card p-4 flex items-center gap-3 group">
          <span class="text-xl shrink-0">📈</span>
          <span class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors">{t('cat.marketing.name', locale)}</span>
        </a>
        <a href={`${prefix}/inteligencia-artificial`} class="glass-card p-4 flex items-center gap-3 group">
          <span class="text-xl shrink-0">🤖</span>
          <span class="text-sm font-semibold text-text-primary group-hover:text-purple-500 transition-colors">{t('cat.ia.name', locale)}</span>
        </a>
        <a href={`${prefix}/monetizacao`} class="glass-card p-4 flex items-center gap-3 group">
          <span class="text-xl shrink-0">💰</span>
          <span class="text-sm font-semibold text-text-primary group-hover:text-amber-500 transition-colors">{t('cat.monetizacao.name', locale)}</span>
        </a>
        <a href={`${prefix}/parceiros`} class="glass-card p-4 flex items-center gap-3 group">
          <span class="text-xl shrink-0">🧰</span>
          <span class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors">{t('nav.parceiros', locale)}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- GUÍAS PRÁCTICAS -->
  <!-- ════════════════════════════════════════════════ -->
  {guiaRecente ? (
    <section class="py-12 bg-surface transition-colors duration-300">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Guías prácticas</h2>
          <div class="h-px flex-1" style="background: var(--color-border);"></div>
        </div>

        <p class="text-sm text-text-secondary mb-6 max-w-xl">
          Checklists y paso a paso para aplicar en el día a día.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a
            href={`${prefix}/artigos/${guiaRecente.slug}`}
            class="glass-card p-5 group flex items-start gap-4"
            style="border-color: rgba(168, 85, 247, 0.2);"
          >
            <span class="text-2xl shrink-0 mt-0.5">{guiaRecente.data.emoji || '📋'}</span>
            <div class="min-w-0 flex-1">
              {guiaRecente.data.guideType && (
                <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-purple-500 mb-1">{guiaRecente.data.guideType}</span>
              )}
              <h3 class="text-sm font-bold text-text-primary group-hover:text-purple-500 transition-colors leading-snug line-clamp-2">
                {guiaRecente.data.title}
              </h3>
              <p class="text-xs text-text-muted mt-1 line-clamp-2">{guiaRecente.data.excerpt}</p>
              <span class="text-xs text-purple-500 font-medium mt-2 inline-block group-hover:underline">Leer guía</span>
            </div>
          </a>
        </div>

        <a href={`${prefix}/guias`} class="inline-flex items-center gap-1 text-xs font-medium text-purple-500 hover:underline mt-4 transition-colors">
          Ver todas las guías
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </section>
  ) : (
    <section class="py-12 bg-surface transition-colors duration-300">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Guías prácticas</h2>
          <div class="h-px flex-1" style="background: var(--color-border);"></div>
        </div>

        <a href={`${prefix}/guias`} class="glass-card p-5 flex items-center gap-4 group hover:border-purple-500/20 transition-colors">
          <span class="text-2xl shrink-0">📋</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm text-text-secondary leading-relaxed">
              Checklists y paso a paso para aplicar en el día a día.
            </p>
            <span class="text-xs font-medium text-purple-500 mt-1 inline-flex items-center gap-1 group-hover:underline">
              Ver todas las guías
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="py-24 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="glass-card p-10 md:p-16 text-center max-w-3xl mx-auto glow-border">
        <span class="tag-pill">{locale === 'pt-BR' ? 'Fique ligado' : 'Mantente al tanto'}</span>
        <h2 class="section-title mt-4 text-text-primary">{locale === 'pt-BR' ? 'Receba o' : 'Recibe la'} <span class="text-cyan-500">señal</span></h2>
        <p class="text-text-secondary mt-3 max-w-lg mx-auto text-sm leading-relaxed">
          {locale === 'pt-BR' 
            ? 'Assine e seja o primeiro a saber quando novos artigos chegarem. Sem spam, só conteúdo de verdade.' 
            : 'Suscríbete y sé el primero en saber cuando lleguen nuevos artículos. Sin spam, solo contenido real.'}
        </p>
        <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Newsletter em breve! 🚀')">
          <input type="email" placeholder="tu@email.com" class="flex-1 px-5 py-3 rounded-xl text-sm" style="background: var(--color-surface-elevated); color: var(--color-text-primary); border: 1px solid var(--color-border);" required />
          <button type="submit" class="px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500/20 to-cyan-600/20 border border-cyan-500/30 text-cyan-500 text-sm font-semibold">
            {locale === 'pt-BR' ? 'Assinar' : 'Suscribirse'}
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="pb-24 bg-surface">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-xs text-text-muted uppercase tracking-[0.15em] mb-3">Radar Digital © 2026</p>
      <p class="text-text-secondary text-sm max-w-md mx-auto">
        {locale === 'pt-BR' 
          ? <>Captando sinais, entregando valor.</>
          : <>Captando señales, entregando valor.</>}
      </p>
    </div>
  </section>
</Layout>
