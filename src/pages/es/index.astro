---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import EditorialLead from '../../components/EditorialLead.astro';
import SecondaryLeads from '../../components/SecondaryLeads.astro';
import RadarNow from '../../components/RadarNow.astro';
import TopicRail from '../../components/TopicRail.astro';
import EditorialSelection from '../../components/EditorialSelection.astro';
import LatestPublications from '../../components/LatestPublications.astro';
import EditorialHubs from '../../components/EditorialHubs.astro';
import IntentNavigator from '../../components/IntentNavigator.astro';
import GuideHighlights from '../../components/GuideHighlights.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, t, defaultLocale, type Locale } from '../../i18n/utils';
import { routePath } from '../../i18n/utils';
import { loadHomeEditorialData } from '../../utils/homeData';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const {
  leadArticle: artigoPrincipal,
  secondaryArticles: artigosSecundarios,
  radarNowItems: radarAgora,
  topicRailItems: assuntosEmDestaque,
  editorialSelectionArticles: selecaoDaRedacao,
  latestPublicationArticles: ultimasPublicacoes,
  editorialHubItems: editorias,
  intentItems: intencaoResolver,
  guideItems: guiasEmDestaque,
} = await loadHomeEditorialData(locale);

// Categorías de partners publicadas
const parceiroCategorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false)
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));

// Bonos verificados destacados
const bonusDestaques = (await getCollection('bonuses', ({ data }) =>
  data.draft === false && data.status === 'verified' && (data.locale || 'pt-BR') === locale
))
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
  .slice(0, 3);

// Categorías de Radar Market
const marketCategorias = await getCollection('marketCategorias', ({ data }) => data.draft === false && data.locale === 'es')
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));
---

<Layout title="Radar Digital" description={t('home.meta.desc', locale)}
  breadcrumbItems={[{name: t('nav.home', locale), href: prefix + '/'}]}>

  <AdSlot variant="horizontal" />

  <!-- ════════════════════════════════════════════════ -->
  <!-- APERTURA EDITORIAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="home-opening" aria-labelledby="home-opening-label">
    <div class="home-opening__inner">
      <p class="home-opening__label" id="home-opening-label">{t('home.section.leia', locale)}</p>

      <div class:list={['home-opening__grid', { 'home-opening__grid--no-secondary': artigosSecundarios.length === 0 }]}>

          <!-- COLUMNA PRINCIPAL (2/3): Artículo Principal -->
          <div class="home-opening__primary">
            <EditorialLead article={artigoPrincipal} locale={locale} />
          </div>

          <!-- COLUMNA LATERAL (1/3): Noticias secundarias -->
          {artigosSecundarios.length > 0 && (
            <div class="home-opening__secondary">
              <SecondaryLeads articles={artigosSecundarios} locale={locale} />
            </div>
          )}

          <!-- PANEL LATERAL: recencia editorial verificable -->
          <div class="home-opening__radar">
            <RadarNow items={radarAgora} locale={locale} />
          </div>

      </div>
    </div>
  </section>

  <TopicRail items={assuntosEmDestaque} locale={locale} />

  <EditorialSelection articles={selecaoDaRedacao} locale={locale} />

  <IntentNavigator items={intencaoResolver} locale={locale} />

  <LatestPublications articles={ultimasPublicacoes} locale={locale} />

  <EditorialHubs items={editorias} locale={locale} />

  <GuideHighlights items={guiasEmDestaque} locale={locale} />

  <!-- ════════════════════════════════════════════════ -->
  <!-- HERRAMIENTAS EN LA PRÁCTICA -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-4">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">{t('home.section.ferramentas', locale)}</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        {t('home.tools.desc', locale)}
      </p>

      {parceiroCategorias.length > 0 ? (
        <div class="flex flex-wrap gap-2 mb-4">
          {parceiroCategorias.map((cat) => (
            <a
              href={routePath('parceiros', locale) + '/' + cat.slug}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-xs font-medium border transition-colors hover:border-cyan-500/30 hover:text-cyan-500"
              style="border-color: var(--color-border); color: var(--color-text-secondary); background: var(--color-surface-elevated);"
            >
              {cat.data.title}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">{t('home.tools.empty', locale)}</p>
      )}

      <a href={routePath('parceiros', locale)} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        {t('home.tools.cta', locale)}
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- BONOS Y CÓDIGOS PROMOCIONALES -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-4">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">{t('home.section.bonus', locale)}</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        {t('home.bonus.desc', locale)}
      </p>

      {bonusDestaques.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {bonusDestaques.map((bonus) => (
            <a
              href={routePath('bonus', locale) + '#' + bonus.data.category}
              class="glass-card interactive-card p-4 group block h-full"
            >
              <div class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors mb-1">{bonus.data.productName}</div>
              <div class="text-xs font-mono text-amber-500 font-semibold tracking-wide">{bonus.data.promoCode}</div>
              <div class="text-[11px] uppercase tracking-wider text-green-500 mt-1 font-medium">{t('home.bonus.verified', locale)}</div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">{t('home.bonus.empty', locale)}</p>
      )}

      <a href={routePath('bonus', locale)} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        {t('home.bonus.cta', locale)}
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- RADAR MARKET -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">{t('home.section.market', locale)}</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        {t('home.market.desc', locale)}
      </p>

      {marketCategorias.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {marketCategorias.map((cat) => (
            <div class="glass-card p-4 h-full">
              {cat.data.emoji && <span class="text-lg block mb-2">{cat.data.emoji}</span>}
              <h3 class="text-sm font-bold text-text-primary mb-0.5">{cat.data.title}</h3>
              <p class="text-xs text-text-muted leading-relaxed">{cat.data.description}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">{t('home.market.empty', locale)}</p>
      )}

      <a href={`${prefix}/market`} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        {t('home.market.cta', locale)}
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <section id="newsletter" class="scroll-mt-header-sticky py-14 relative bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="glass-card p-10 md:p-14 text-center max-w-3xl mx-auto relative overflow-hidden">
        <span class="tag-pill">{t('home.newsletter.badge', locale)}</span>
        <h2 class="section-title mt-4 text-text-primary">{t('home.newsletter.title.prefix', locale)} <span class="text-cyan-500">{t('home.newsletter.title.word', locale)}</span></h2>
        <p class="text-text-secondary mt-3 max-w-lg mx-auto text-sm leading-relaxed">
          {t('home.newsletter.desc', locale)}
        </p>
        <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Newsletter em breve! 🚀')">
          <input type="email" placeholder={t('home.newsletter.placeholder', locale)} class="flex-1 px-5 py-3 rounded-xl text-sm" style="background: var(--color-surface-elevated); color: var(--color-text-primary); border: 1px solid var(--color-border);" required />
          <button type="submit" class="px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500/20 to-cyan-600/20 border border-cyan-500/30 text-cyan-500 text-sm font-semibold">
            {t('home.newsletter.cta', locale)}
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
