---
import Layout from '../../layouts/Layout.astro';
import { getLocaleFromUrl, localizePath, t, defaultLocale, type Locale } from '../../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;
---

<Layout title="Radar Digital" description="Tu radar de tendencias en marketing digital, inteligencia artificial y monetización.">
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-15 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.3) 0%, rgba(124, 58, 237, 0.1) 40%, transparent 70%);"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-10 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(245, 158, 11, 0.2) 0%, transparent 60%);"></div>

    <div class="max-w-6xl mx-auto px-6 w-full relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-[1.05] tracking-tight">
          <span class="text-text-primary transition-colors">Radar</span>
          <br />
          <span class="gradient-text">Digital</span>
        </h1>

        <p class="text-lg sm:text-xl text-text-secondary mt-6 max-w-xl leading-relaxed transition-colors">
          {t('home.hero.subtitle', locale).split('.')[0]}.<br />
          <span class="text-text-primary">{t('home.hero.subtitle', locale).split('.').slice(1).join('.').trim()}</span>
        </p>

        <div class="flex flex-wrap gap-4 mt-10">
          <a href={`${prefix}/#categorias`} 
             class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                    bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 
                    hover:bg-cyan-500/20 hover:border-cyan-500/50 transition-all duration-300">
            {t('home.sections.title', locale)}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href={`${prefix}/#artigos`} 
             class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                    text-text-secondary border border-surface hover:border-cyan-500/30 hover:text-cyan-500
                    transition-all duration-300">
            {t('home.articles.title', locale)}
          </a>
        </div>

        <div class="flex flex-wrap gap-8 md:gap-12 mt-16 pt-10 border-t transition-colors duration-300" style="border-color: var(--color-border);">
          <div>
            <div class="text-2xl font-bold text-text-primary transition-colors">3</div>
            <div class="text-xs text-text-muted mt-0.5 transition-colors">{locale === 'pt-BR' ? 'Categorias' : 'Categorías'}</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary transition-colors">{locale === 'pt-BR' ? '100%' : '100%'}</div>
            <div class="text-xs text-text-muted mt-0.5 transition-colors">{locale === 'pt-BR' ? 'Sem enrolação' : 'Sin rodeos'}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="categorias" class="py-24 relative bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="tag-pill">{locale === 'pt-BR' ? 'Navegue por tema' : 'Navega por tema'}</span>
        <h2 class="section-title mt-4 text-text-primary transition-colors">{locale === 'pt-BR' ? 'Três pilares, um' : 'Tres pilares, un'} <span class="text-cyan-500">radar</span></h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href={`${prefix}/marketing-digital`} class="glass-card p-8 group glow-border">
          <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">{t('cat.marketing.name', locale)}</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">{t('home.card.marketing.desc', locale)}</p>
          <div class="flex items-center gap-2 text-cyan-500 text-sm font-medium">
            {t('home.card.explorar', locale)} →
          </div>
        </a>

        <a href={`${prefix}/inteligencia-artificial`} class="glass-card p-8 group glow-border">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">{t('cat.ia.name', locale)}</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">{t('home.card.ia.desc', locale)}</p>
          <div class="flex items-center gap-2 text-purple-500 text-sm font-medium">
            {t('home.card.explorar', locale)} →
          </div>
        </a>

        <a href={`${prefix}/monetizacao`} class="glass-card p-8 group glow-border">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">{t('cat.monetizacao.name', locale)}</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">{t('home.card.monetizacao.desc', locale)}</p>
          <div class="flex items-center gap-2 text-amber-500 text-sm font-medium">
            {t('home.card.explorar', locale)} →
          </div>
        </a>

        <a href={`${prefix}/parceiros`} class="glass-card p-8 group glow-border">
          <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text-primary mb-2">{t('nav.parceiros', locale)}</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">{t('home.card.parceiros.desc', locale)}</p>
          <div class="flex items-center gap-2 text-cyan-500 text-sm font-medium">
            {t('home.card.diretorio', locale)} →
          </div>
        </a>
      </div>
    </div>
  </section>

  <section id="artigos" class="py-24 relative bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-14">
        <div>
          <span class="tag-pill">{locale === 'pt-BR' ? 'Conteúdo recente' : 'Contenido reciente'}</span>
          <h2 class="section-title mt-4 text-text-primary transition-colors">{locale === 'pt-BR' ? 'Últimos do' : 'Últimos del'} <span class="text-cyan-500">Radar</span></h2>
        </div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: locale === 'pt-BR' ? 'Primeiro artigo sendo escrito' : 'Primer artículo en preparación', desc: locale === 'pt-BR' ? 'O Radar Digital está captando sinais. Em breve, conteúdo fresco.' : 'El Radar Digital está captando señales. Próximamente, contenido fresco.' },
          { title: locale === 'pt-BR' ? 'Ferramentas de IA explicadas' : 'Herramientas de IA explicadas', desc: locale === 'pt-BR' ? 'Análises práticas do que entrega valor vs. hype.' : 'Análisis prácticos de lo que entrega valor vs. hype.' },
          { title: locale === 'pt-BR' ? 'Estratégias de monetização' : 'Estrategias de monetización', desc: locale === 'pt-BR' ? 'Modelos de negócio digital que geram receita real.' : 'Modelos de negocio digital que generan ingresos reales.' },
        ].map((item, i) => (
          <article class="glass-card overflow-hidden group">
            <div class={`h-44 bg-gradient-to-br ${i === 0 ? 'from-cyan-500/10' : i === 1 ? 'from-purple-500/10' : 'from-amber-500/10'} to-surface-elevated flex items-center justify-center`}>
              <svg class="w-10 h-10 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/>
              </svg>
            </div>
            <div class="p-5">
              <span class="inline-block px-2.5 py-0.5 rounded-md text-[10px] font-semibold uppercase tracking-wider bg-surface-elevated text-text-muted mb-3">{t('cat.tag.em-breve', locale)}</span>
              <h3 class="font-semibold text-text-primary">{item.title}</h3>
              <p class="text-xs text-text-muted mt-2 leading-relaxed">{item.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="glass-card p-10 md:p-16 text-center max-w-3xl mx-auto glow-border">
        <span class="tag-pill">{locale === 'pt-BR' ? 'Fique ligado' : 'Mantente al tanto'}</span>
        <h2 class="section-title mt-4 text-text-primary">{locale === 'pt-BR' ? 'Receba o' : 'Recibe la'} <span class="text-cyan-500">señal</span></h2>
        <p class="text-text-secondary mt-3 max-w-lg mx-auto text-sm leading-relaxed">
          {locale === 'pt-BR' 
            ? 'Assine e seja o primeiro a saber quando novos artigos chegarem. Sem spam, só conteúdo de verdade.' 
            : 'Suscríbete y sé el primero en saber cuando lleguen nuevos artículos. Sin spam, solo contenido real.'}
        </p>
        <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Newsletter em breve! 🚀')">
          <input type="email" placeholder="tu@email.com" class="flex-1 px-5 py-3 rounded-xl text-sm" style="background: var(--color-surface-elevated); color: var(--color-text-primary); border: 1px solid var(--color-border);" required />
          <button type="submit" class="px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500/20 to-cyan-600/20 border border-cyan-500/30 text-cyan-500 text-sm font-semibold">
            {locale === 'pt-BR' ? 'Assinar' : 'Suscribirse'}
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="pb-24 bg-surface">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-xs text-text-muted uppercase tracking-[0.15em] mb-3">Radar Digital © 2026</p>
      <p class="text-text-secondary text-sm max-w-md mx-auto">
        {locale === 'pt-BR' 
          ? <>Captando sinais, entregando valor.</>
          : <>Captando señales, entregando valor.</>}
      </p>
    </div>
  </section>
</Layout>
