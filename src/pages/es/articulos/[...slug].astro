---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { t, defaultLocale, getDateLocale, type Locale } from '../../../i18n/utils';
import { routePath, type RouteKey } from '../../../i18n/utils';
import { getPublishedTranslationGroup, validatePublishedTranslationGroups } from '../../../utils/editorialTranslations';
import { getEditorialAuthor } from '../../../config/editorialAuthors';

export async function getStaticPaths() {
  const artigos = await getCollection('artigos', ({ data }) => data.draft === false && data.locale === 'es');
  return artigos.map((artigo) => ({
    params: { slug: artigo.slug },
    props: { artigo },
  }));
}

const { artigo } = Astro.props;
const locale: Locale = (artigo.data.locale || 'pt-BR') as Locale;
const prefix = locale === defaultLocale ? '' : `/${locale}`;
const { Content } = await artigo.render();

const colorMap: Record<string, { accent: string; text: string; bg: string; border: string }> = {
  cyan:   { accent: 'cyan-500',   text: 'text-cyan-500',   bg: 'bg-cyan-500/10',   border: 'border-cyan-500/20' },
  purple: { accent: 'purple-500', text: 'text-purple-500', bg: 'bg-purple-500/10', border: 'border-purple-500/20' },
  amber:  { accent: 'amber-500',  text: 'text-amber-500',  bg: 'bg-amber-500/10',  border: 'border-amber-500/20' },
};

const c = colorMap[artigo.data.color] || colorMap.cyan;

// Cor de acento do hero (glow) derivada da cor editorial do artigo
const accentRgbMap: Record<string, string> = {
  cyan:   'var(--color-brand-cyan-rgb)',
  purple: 'var(--color-editorial-accent-rgb)',
  amber:  'var(--color-commercial-rgb)',
};
const accentRgb = accentRgbMap[artigo.data.color] || accentRgbMap.cyan;

// Categoria name mapping for breadcrumb
const catNameKey: Record<string, string> = {
  'marketing-digital': 'cat.marketing.name',
  'inteligencia-artificial': 'cat.ia.name',
  'monetizacao': 'cat.monetizacao.name',
};
const categoriaNome = t(catNameKey[artigo.data.categoria] as any, locale);

const dateStr = artigo.data.date.toLocaleDateString(getDateLocale(locale), {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

// Aviso de actualización
let updatedStr: string | null = null;
if (artigo.data.updatedAt && artigo.data.updatedAt > artigo.data.date) {
  const upd = artigo.data.updatedAt;
  const d = upd.toLocaleDateString(getDateLocale(locale), { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'UTC' });
  const t = upd.toLocaleTimeString(getDateLocale(locale), { hour: '2-digit', minute: '2-digit', timeZone: 'UTC', hourCycle: 'h23' });
  updatedStr = `Actualizado el ${d} a las ${t}`;
}

// Hreflang alternates via translationKey
const allPublishedArtigos = await getCollection('artigos', ({ data }) => data.draft === false);
validatePublishedTranslationGroups(allPublishedArtigos);
const translationGroup = getPublishedTranslationGroup(allPublishedArtigos, artigo);
const alternateUrls = translationGroup.map((entry) => ({
  lang: entry.data.locale,
  href: routePath('artigos', entry.data.locale as Locale, entry.slug),
}));

// Resolve autor do registro central via authorId
const authorData = artigo.data.authorId
  ? getEditorialAuthor(artigo.data.authorId as any)
  : undefined;
const byline = authorData?.name || t('article.byline.fallback', locale);
---

<Layout 
  title={artigo.data.title} 
  description={artigo.data.excerpt}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: categoriaNome, href: routePath(artigo.data.categoria as RouteKey, locale)},
    {name: artigo.data.title, href: routePath('artigos', locale, artigo.slug)}
  ]}
  alternateUrls={alternateUrls}
  articleData={{
    title: artigo.data.title,
    description: artigo.data.excerpt,
    datePublished: artigo.data.date,
    dateModified: artigo.data.updatedAt,
    authorName: authorData?.name,
    authorType: authorData?.kind !== 'organization' ? 'Person' : 'Organization',
    authorUrl: authorData?.url,
    imageUrl: artigo.data.image,
    categoria: artigo.data.categoria,
  }}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO DO ARTIGO (V4 — banner escuro editorial)     -->
  <!-- ════════════════════════════════════════════════ -->
  <article class="bg-surface transition-colors duration-300">
    <header class="article-hero" style={`--article-accent-rgb: ${accentRgb}`}>
      <div class="article-hero__inner">
        <span class="article-hero__kicker">{artigo.data.subtema}</span>

        <h1 id="hero-title" class="article-hero__title">{artigo.data.title}</h1>

        <p class="story-deck article-hero__deck">{artigo.data.excerpt}</p>

        <div class="article-hero__meta">
          <span class="article-hero__byline">{t('article.byline', locale)} {byline}</span>
          <span>{artigo.data.readTime} {t('article.readtime', locale)}</span>
          <time datetime={artigo.data.date.toISOString()}>{dateStr}</time>
          {updatedStr && <span class="article-hero__updated">{updatedStr}</span>}
        </div>
      </div>
    </header>

    <!-- ════════════════════════════════════════════════ -->
    <!-- CONTEÚDO DO ARTIGO -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="pb-20">
      <div class="max-w-3xl mx-auto px-6">
        <div class="prose-radar">
          <Content />
        </div>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════ -->
    <!-- FOOTER DO ARTIGO -->
    <!-- ════════════════════════════════════════════════ -->
    <div class="max-w-3xl mx-auto px-6 pb-20">
      <div class="pt-10 border-t transition-colors" style="border-color: var(--color-border);">
        <a href={routePath(artigo.data.categoria as RouteKey, locale)} class={`inline-flex items-center gap-2 text-sm ${c.text} hover:underline transition-colors`}>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          {t('cat.cta.see.more', locale)} {artigo.data.categoria.replace('-', ' ')}
        </a>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  /* Tipografia do conteúdo do artigo */
  .prose-radar {
    color: var(--color-text-primary);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .prose-radar h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .prose-radar h3 {
    font-size: 1.375rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .prose-radar p {
    margin-bottom: 1.25rem;
  }
  .prose-radar ul, .prose-radar ol {
    margin: 1.25rem 0 1.25rem 1.5rem;
  }
  .prose-radar ul { list-style: disc; }
  .prose-radar ol { list-style: decimal; }
  .prose-radar li {
    margin-bottom: 0.5rem;
  }
  .prose-radar blockquote {
    border-left: 3px solid var(--color-accent, #00e5ff);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .prose-radar code {
    background: var(--color-surface-elevated, #15171f);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-family: ui-monospace, SFMono-Regular, monospace;
  }
  .prose-radar a {
    color: var(--color-accent, #00e5ff);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-radar hr {
    border: none;
    border-top: 1px solid var(--color-border, #1e2130);
    margin: 2rem 0;
  }
  .prose-radar strong {
    color: var(--color-text-primary);
    font-weight: 700;
  }
</style>
