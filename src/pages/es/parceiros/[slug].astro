---
import { getCollection } from 'astro:content';

// ═══════════════════════════════════════════════════════════
// REDIRECT FALLBACK (local dev)
// /es/parceiros/[slug]/ → /es/herramientas/[slug]/
// Em producao, o vercel.json faz o redirect 308 real.
// ═══════════════════════════════════════════════════════════

export async function getStaticPaths() {
  const categorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false);
  return categorias.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

const { slug } = Astro.params;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="refresh" content={`0; url=/es/herramientas/${slug}/`} />
</head>
<body>
  <p>Redirigiendo a <a href={`/es/herramientas/${slug}/`}>/es/herramientas/{slug}/</a>...</p>
</body>
</html>
