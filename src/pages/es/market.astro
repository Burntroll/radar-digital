---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, type Locale } from '../../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const categorias = await getCollection('marketCategorias', ({ data }) => data.draft === false && data.locale === 'pt-BR')
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));
---

<Layout
  title="Radar Market"
  description="Productos, cursos y soluciones para quienes trabajan con marketing, IA y monetización."
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: 'Radar Market', href: prefix + '/market'}
  ]}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO EDITORIAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, rgba(124, 58, 237, 0.1) 40%, transparent 60%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 transition-colors">
        <a href={`${prefix}/`} class="hover:text-cyan-500 transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-cyan-500">Radar Market</span>
      </nav>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary">Radar</span>{' '}
        <span class="gradient-text">Market</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed">
        Productos, cursos y soluciones para quienes trabajan con marketing, IA y monetización.
      </p>
      <p class="text-sm text-text-muted mt-4 max-w-xl leading-relaxed">
        Curaduría editorial de productos, cursos, servicios y soluciones de socios del mercado digital. Cada publicación pasa por evaluación de utilidad, reputación y transparencia.
      </p>
      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-text-primary">{categorias.length}</div>
          <div class="text-xs text-text-muted mt-0.5">Categorías</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary">0</div>
          <div class="text-xs text-text-muted mt-0.5">Productos disponibles</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- CATEGORÍAS -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-16 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Categorías</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      {categorias.length === 0 ? (
        <p class="text-sm text-text-muted text-center py-12">Ninguna categoría disponible aún.</p>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {categorias.map((cat) => (
            <div class="rounded-xl border p-6 transition-colors" style="border-color: var(--color-border); background: var(--color-surface-card);">
              <div class="flex items-start gap-4">
                {cat.data.emoji && <span class="text-3xl shrink-0">{cat.data.emoji}</span>}
                <div class="min-w-0 flex-1">
                  <h3 class="text-base font-bold text-text-primary mb-1.5">{cat.data.title}</h3>
                  <p class="text-sm text-text-secondary leading-relaxed">{cat.data.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- LO QUE PODRÁ APARECER AQUÍ -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-16 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Lo que podrá aparecer aquí</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">🤖</span>
          <span class="text-sm text-text-secondary">Agentes de IA</span>
        </div>
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">⚡</span>
          <span class="text-sm text-text-secondary">Automatizaciones y templates</span>
        </div>
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">🛡️</span>
          <span class="text-sm text-text-secondary">Proxies e infraestructura</span>
        </div>
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">📱</span>
          <span class="text-sm text-text-secondary">Productos para social y contenido</span>
        </div>
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">🎓</span>
          <span class="text-sm text-text-secondary">Cursos de e-commerce, afiliados e IA</span>
        </div>
        <div class="flex items-center gap-3 rounded-xl border p-4" style="border-color: var(--color-border);">
          <span class="text-xl shrink-0">📊</span>
          <span class="text-sm text-text-secondary">Tráfico pago y monetización</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- AVISO EDITORIAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="rounded-xl border p-6 md:p-8" style="border-color: var(--color-border); background: var(--color-surface-card);">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
          </svg>
          <div>
            <h3 class="text-sm font-bold text-text-primary mb-1">Curaduría editorial</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Los productos y ofertas de Radar Market pasan por curaduría editorial. Cuando una oferta esté disponible, deberá informar socio, beneficio, estado y fuente de verificación siempre que sea aplicable.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
