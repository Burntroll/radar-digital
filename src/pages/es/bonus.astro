---
// ═══════════════════════════════════════════════════════════
// REDIRECT 301: URL antiga → nova
// /es/bonus/ → /es/bonos/
// ═══════════════════════════════════════════════════════════
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="refresh" content="0; url=/es/bonos/" />
  <script>window.location.replace('/es/bonos/');</script>
</head>
<body>
  <p>Redirigiendo a <a href="/es/bonos/">/es/bonos/</a>...</p>
</body>
</html>
