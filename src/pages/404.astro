---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página não encontrada" description="404 - Página não encontrada no Radar Digital" noindex={true}>
  <!-- Three.js via CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <!-- Three.js Canvas -->
  <canvas id="bg-canvas" style="position: fixed; inset: 0; z-index: 0; width: 100vw; height: 100vh;"></canvas>

  <!-- 404 Content Overlay -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.08) 0%, transparent 60%);">
    </div>

    <div class="relative">
      <h1 class="text-[10rem] sm:text-[14rem] md:text-[18rem] font-black leading-none tracking-tighter gradient-text select-none">
        404
      </h1>

      <div class="flex items-center gap-3 justify-center my-4">
        <span class="h-px w-12" style="background: linear-gradient(90deg, transparent, var(--color-border));"></span>
        <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse-cyan"></span>
        <span class="h-px w-12" style="background: linear-gradient(90deg, var(--color-border), transparent);"></span>
      </div>

      <p class="text-text-secondary text-lg sm:text-xl font-medium transition-colors">
        Sinal perdido no espaço
      </p>
      <p class="text-text-muted text-sm mt-2 max-w-md mx-auto transition-colors">
        O radar não encontrou a página que você procura. Ela pode ter sido movida ou nunca existiu.
      </p>

      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/" 
           class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                  bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 
                  hover:bg-cyan-500/20 hover:border-cyan-500/50 transition-all duration-300">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar ao Radar
        </a>
        <button onclick="window.history.back()"
                class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                       text-text-secondary border border-surface hover:border-cyan-500/30 hover:text-cyan-500
                       transition-all duration-300 cursor-pointer">
          Página anterior
        </button>
      </div>
    </div>
  </div>

  <!-- Three.js Scene -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var canvas = document.getElementById('bg-canvas');
      if (!canvas || !window.THREE) return;

      var THREE = window.THREE;

      // Scene
      var scene = new THREE.Scene();
      var isDark = document.documentElement.classList.contains('dark');
      scene.background = new THREE.Color(isDark ? 0x050508 : 0xf0f2f6);

      var camera = new THREE.PerspectiveCamera(50, innerWidth / innerHeight, 0.1, 2000);
      camera.position.set(0, 1.5, 8);
      camera.lookAt(0, 0, 0);

      var renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true });
      renderer.setSize(innerWidth, innerHeight);
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

      // Lights
      scene.add(new THREE.AmbientLight(0x222244, 0.3));
      var ml = new THREE.DirectionalLight(0x00e5ff, 1.5);
      ml.position.set(3, 5, 4);
      scene.add(ml);
      var rl = new THREE.DirectionalLight(0x7c3aed, 0.8);
      rl.position.set(-4, -2, 3);
      scene.add(rl);
      var al = new THREE.PointLight(0xff8844, 0.4, 10);
      al.position.set(2, -1, 3);
      scene.add(al);

      // ─── Stars ───
      (function() {
        var count = 3000;
        var geo = new THREE.BufferGeometry();
        var pos = new Float32Array(count * 3);
        var sizes = new Float32Array(count);
        var colors = new Float32Array(count * 3);
        for (var i = 0; i < count; i++) {
          var r = 30 + Math.random() * 120;
          var t = Math.random() * Math.PI * 2;
          var p = Math.acos(2 * Math.random() - 1);
          pos[i*3] = r * Math.sin(p) * Math.cos(t);
          pos[i*3+1] = r * Math.sin(p) * Math.sin(t);
          pos[i*3+2] = r * Math.cos(p);
          sizes[i] = 0.3 + Math.random() * 1.2;
          if (Math.random() < 0.03) sizes[i] = 2.0 + Math.random() * 2.0;
          var tmp = Math.random();
          if (tmp < 0.15) {
            colors[i*3]=0.7+Math.random()*0.3; colors[i*3+1]=0.8+Math.random()*0.2; colors[i*3+2]=1;
          } else if (tmp < 0.25) {
            colors[i*3]=1; colors[i*3+1]=0.7+Math.random()*0.3; colors[i*3+2]=0.4+Math.random()*0.3;
          } else {
            var w = 0.85 + Math.random() * 0.15;
            colors[i*3]=w; colors[i*3+1]=w; colors[i*3+2]=w;
          }
        }
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
        geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

        var texCanvas = document.createElement('canvas');
        texCanvas.width = 64; texCanvas.height = 64;
        var ctx = texCanvas.getContext('2d');
        var g = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)');
        g.addColorStop(0.2, 'rgba(255,255,255,0.8)');
        g.addColorStop(0.5, 'rgba(255,255,255,0.3)');
        g.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, 64, 64);
        var tex = new THREE.CanvasTexture(texCanvas);

        var mat = new THREE.PointsMaterial({
          size: 0.3, map: tex, vertexColors: true, transparent: true,
          blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true,
        });
        var stars = new THREE.Points(geo, mat);
        scene.add(stars);

        // Store for animation
        window._stars = stars;
      })();

      // ─── Radar Screen (stylized) ───
      var radar = new THREE.Group();
      scene.add(radar);

      // Main outer ring
      var ringMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.1,
        transparent: true, opacity: 0.3,
      });
      var outerRing = new THREE.Mesh(new THREE.TorusGeometry(2.0, 0.025, 12, 64), ringMat);
      radar.add(outerRing);

      // Inner ring
      var innerRing = new THREE.Mesh(new THREE.TorusGeometry(1.6, 0.02, 10, 48), ringMat);
      innerRing.material = ringMat.clone();
      innerRing.material.opacity = 0.2;
      radar.add(innerRing);

      // Small center sphere
      var centerMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.5,
      });
      var center = new THREE.Mesh(new THREE.SphereGeometry(0.08, 12, 12), centerMat);
      radar.add(center);

      // Crosshairs (horizontal and vertical lines)
      var lineMat = new THREE.LineBasicMaterial({
        color: 0x00e5ff, transparent: true, opacity: 0.15,
      });
      function makeLine(p1, p2) {
        var g = new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(p1[0], p1[1], p1[2]),
          new THREE.Vector3(p2[0], p2[1], p2[2])
        ]);
        return new THREE.Line(g, lineMat);
      }
      radar.add(makeLine([-2.0, 0, 0], [2.0, 0, 0]));
      radar.add(makeLine([0, -2.0, 0], [0, 2.0, 0]));
      radar.add(makeLine([0, 0, -2.0], [0, 0, 2.0]));

      // Grid circles (concentric)
      for (var r = 0.6; r < 2.0; r += 0.5) {
        var gMat = ringMat.clone();
        gMat.opacity = 0.08;
        var gridRing = new THREE.Mesh(new THREE.TorusGeometry(r, 0.01, 8, 40), gMat);
        radar.add(gridRing);
      }

      // ─── Scan line (rotating) ───
      var scanGroup = new THREE.Group();
      radar.add(scanGroup);
      var scanMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.3,
        transparent: true, opacity: 0.2,
      });
      var scanLine = new THREE.Mesh(new THREE.PlaneGeometry(2.1, 0.02), scanMat);
      scanLine.position.x = 1.05;
      scanGroup.add(scanLine);

      // Scan gradient (cone of light behind the line)
      var gradMat = new THREE.MeshBasicMaterial({
        color: 0x00e5ff, transparent: true, opacity: 0.03, side: THREE.DoubleSide,
        depthWrite: false,
      });
      var gradGeo = new THREE.CircleGeometry(2.1, 16, 0, Math.PI * 0.08);
      var gradMesh = new THREE.Mesh(gradGeo, gradMat);
      gradMesh.position.x = 1.0;
      scanGroup.add(gradMesh);

      // ─── Radar blips (random dots that appear briefly) ───
      var blipGroup = new THREE.Group();
      radar.add(blipGroup);
      var blipMat = new THREE.PointsMaterial({
        color: 0x00e5ff, size: 0.06, transparent: true, opacity: 0.8,
        blending: THREE.AdditiveBlending,
      });
      var blipCount = 15;
      var blipGeo = new THREE.BufferGeometry();
      var blipPos = new Float32Array(blipCount * 3);
      var blipActive = new Float32Array(blipCount);
      var blipOpacity = new Float32Array(blipCount);
      for (var i = 0; i < blipCount; i++) {
        blipPos[i*3] = 0;
        blipPos[i*3+1] = 0;
        blipPos[i*3+2] = 0;
        blipActive[i] = 0;
        blipOpacity[i] = 0;
      }
      blipGeo.setAttribute('position', new THREE.BufferAttribute(blipPos, 3));
      var blipSystem = new THREE.Points(blipGeo, blipMat.clone());
      blipGroup.add(blipSystem);

      // ─── Pedestal (simple) ───
      var darkMat = new THREE.MeshPhysicalMaterial({
        color: 0x1a2430, metalness: 0.5, roughness: 0.6,
      });
      var pedestal = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.25, 0.8, 8), darkMat);
      pedestal.position.set(0, -2.1, 0);
      radar.add(pedestal);
      var baseMat = new THREE.MeshPhysicalMaterial({
        color: 0x2a3545, metalness: 0.6, roughness: 0.5,
      });
      var base = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.5, 0.12, 8), baseMat);
      base.position.set(0, -2.5, 0);
      radar.add(base);

      // ─── Cable dangling ───
      var cableMat = new THREE.LineBasicMaterial({
        color: 0xaa7733, transparent: true, opacity: 0.3,
      });
      var cablePts = [];
      cablePts.push(new THREE.Vector3(0.3, -1.8, 0.2));
      cablePts.push(new THREE.Vector3(0.6, -2.8, 0.1));
      cablePts.push(new THREE.Vector3(0.4, -3.2, -0.1));
      var cable = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(cablePts), cableMat
      );
      radar.add(cable);

      // Tilt
      radar.rotation.x = 0.15;
      radar.rotation.z = -0.1;

      // ─── Animation ───
      var mouseX = 0, mouseY = 0;
      document.addEventListener('mousemove', function(e) {
        mouseX = (e.clientX / innerWidth - 0.5) * 2;
        mouseY = (e.clientY / innerHeight - 0.5) * 2;
      });

      // Precompute blip positions
      var blipAngle = new Float32Array(blipCount);
      var blipRadius = new Float32Array(blipCount);
      var blipTimer = new Float32Array(blipCount);

      var time = 0;
      function animate() {
        requestAnimationFrame(animate);
        time += 0.005;

        // Drift
        radar.position.x = Math.sin(time * 0.15) * 1.8 + Math.sin(time * 0.07) * 1.2;
        radar.position.y = Math.cos(time * 0.12) * 1.2 + Math.sin(time * 0.09) * 0.8;
        radar.position.z = Math.sin(time * 0.05) * 0.5;
        radar.rotation.x = 0.15 + Math.sin(time * 0.1) * 0.1;
        radar.rotation.y = Math.sin(time * 0.08) * 0.2;
        radar.rotation.z = -0.1 + Math.cos(time * 0.09) * 0.08;

        // Scan line rotates
        scanGroup.rotation.y += 0.015;

        // Blips appear/disappear
        var pos = blipSystem.geometry.attributes.position;
        for (var i = 0; i < blipCount; i++) {
          blipTimer[i] -= 0.005;
          if (blipTimer[i] <= 0) {
            // New blip
            blipAngle[i] = Math.random() * Math.PI * 2;
            blipRadius[i] = 0.2 + Math.random() * 1.7;
            blipTimer[i] = 1.0 + Math.random() * 2.0;
            pos.array[i*3] = Math.cos(blipAngle[i]) * blipRadius[i];
            pos.array[i*3+1] = Math.sin(blipAngle[i]) * blipRadius[i] * 0.7;
            pos.array[i*3+2] = (Math.random() - 0.5) * 0.1;
          }
          // Fade opacity
          var life = blipTimer[i];
          var opacity = 0;
          if (life > 1.5) opacity = (2.0 - life) / 0.5;
          else if (life > 0.3) opacity = 1.0;
          else if (life > 0) opacity = life / 0.3;
          // Can't set per-particle opacity easily, so we just let them appear/disappear
        }
        pos.needsUpdate = true;

        camera.position.x += (mouseX * 0.3 - camera.position.x) * 0.01;
        camera.position.y += (-mouseY * 0.2 + 1.5 - camera.position.y) * 0.01;
        camera.lookAt(0, 0, 0);

        if (window._stars) window._stars.rotation.y += 0.00003;

        renderer.render(scene, camera);
      }
      animate();

      // Resize
      window.addEventListener('resize', function() {
        camera.aspect = innerWidth / innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(innerWidth, innerHeight);
      });

      // Theme sync
      var obs = new MutationObserver(function() {
        scene.background = new THREE.Color(
          document.documentElement.classList.contains('dark') ? 0x050508 : 0xf0f2f6
        );
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    });
  </script>
</Layout>
