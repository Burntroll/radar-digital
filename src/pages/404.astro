---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página não encontrada" description="404 - Página não encontrada no Radar Digital">
  <!-- Three.js via CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <!-- Three.js Canvas -->
  <canvas id="bg-canvas" class="fixed inset-0 z-0" style="position: fixed; inset: 0; z-index: 0; width: 100vw; height: 100vh;"></canvas>

  <!-- 404 Content Overlay -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <!-- Glow behind 404 -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.08) 0%, transparent 60%);">
    </div>

    <div class="relative">
      <h1 class="text-[10rem] sm:text-[14rem] md:text-[18rem] font-black leading-none tracking-tighter gradient-text select-none">
        404
      </h1>

      <div class="flex items-center gap-3 justify-center my-4">
        <span class="h-px w-12" style="background: linear-gradient(90deg, transparent, var(--color-border));"></span>
        <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse-cyan"></span>
        <span class="h-px w-12" style="background: linear-gradient(90deg, var(--color-border), transparent);"></span>
      </div>

      <p class="text-text-secondary text-lg sm:text-xl font-medium transition-colors">
        Sinal perdido no espaço
      </p>
      <p class="text-text-muted text-sm mt-2 max-w-md mx-auto transition-colors">
        O radar não encontrou a página que você procura. Ela pode ter sido movida ou nunca existiu.
      </p>

      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/" 
           class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                  bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 
                  hover:bg-cyan-500/20 hover:border-cyan-500/50 transition-all duration-300">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar ao Radar
        </a>
        <button onclick="window.history.back()"
                class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                       text-text-secondary border border-surface hover:border-cyan-500/30 hover:text-cyan-500
                       transition-all duration-300 cursor-pointer">
          Página anterior
        </button>
      </div>
    </div>
  </div>

  <!-- Three.js Scene -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const canvas = document.getElementById('bg-canvas');
      if (!canvas || !window.THREE) return;

      const THREE = window.THREE;

      // ─── Scene ───
      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x050508);

      const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 2000);
      camera.position.set(0, 1.5, 7);

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;

      // ─── Lights ───
      scene.add(new THREE.AmbientLight(0x222244, 0.3));
      const ml = new THREE.DirectionalLight(0x00e5ff, 1.5);
      ml.position.set(3, 5, 4);
      scene.add(ml);
      const rl = new THREE.DirectionalLight(0x7c3aed, 0.8);
      rl.position.set(-4, -2, 3);
      scene.add(rl);

      // ─── Stars ───
      const starCount = 3000;
      const starGeo = new THREE.BufferGeometry();
      const starPos = new Float32Array(starCount * 3);
      const starSizes = new Float32Array(starCount);
      const starColors = new Float32Array(starCount * 3);

      for (let i = 0; i < starCount; i++) {
        const radius = 30 + Math.random() * 120;
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        starPos[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
        starPos[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
        starPos[i * 3 + 2] = radius * Math.cos(phi);
        starSizes[i] = 0.3 + Math.random() * 1.2;
        if (Math.random() < 0.03) starSizes[i] = 2.0 + Math.random() * 2.0;
        const temp = Math.random();
        if (temp < 0.15) {
          starColors[i * 3] = 0.7 + Math.random() * 0.3;
          starColors[i * 3 + 1] = 0.8 + Math.random() * 0.2;
          starColors[i * 3 + 2] = 1.0;
        } else if (temp < 0.25) {
          starColors[i * 3] = 1.0;
          starColors[i * 3 + 1] = 0.7 + Math.random() * 0.3;
          starColors[i * 3 + 2] = 0.4 + Math.random() * 0.3;
        } else {
          const w = 0.85 + Math.random() * 0.15;
          starColors[i * 3] = w; starColors[i * 3 + 1] = w; starColors[i * 3 + 2] = w;
        }
      }
      starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
      starGeo.setAttribute('size', new THREE.BufferAttribute(starSizes, 1));
      starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

      const starTex = (function() {
        const c = document.createElement('canvas');
        c.width = 64; c.height = 64;
        const ctx = c.getContext('2d');
        const g = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)');
        g.addColorStop(0.2, 'rgba(255,255,255,0.8)');
        g.addColorStop(0.5, 'rgba(255,255,255,0.3)');
        g.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      })();

      const starMat = new THREE.PointsMaterial({
        size: 0.3, map: starTex, vertexColors: true, transparent: true,
        blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true,
      });
      const stars = new THREE.Points(starGeo, starMat);
      scene.add(stars);

      // ─── BROKEN RADAR (realistic model) ───
      const radar = new THREE.Group();
      scene.add(radar);

      // Materials
      function makeMat(color, opts) {
        return new THREE.MeshPhysicalMaterial(Object.assign({
          color: color, metalness: 0.3, roughness: 0.6,
        }, opts || {}));
      }
      var cream    = 0xeae0d0;  // Warm off-white - contrasts dark/light
      var dishIn   = 0x2a3238;  // Deep charcoal dish interior
      var metal    = 0x3a4755;  // Gunmetal structure
      var darkIron = 0x1a2430;  // Very dark base elements
      var amber    = 0xff8833;  // Warning light accent
      var copper   = 0xc4883c;  // Broken cable

      // ── 1. Main Parabolic Dish ──
      var dishBody = new THREE.Mesh(
        new THREE.SphereGeometry(1.6, 40, 28, 0, Math.PI*2, 0, Math.PI*0.45),
        makeMat(dishIn, { metalness: 0.6, roughness: 0.4 })
      );
      dishBody.rotation.x = Math.PI; dishBody.rotation.z = 0.15;
      radar.add(dishBody);

      // Dish outer shell (back of dish)
      var dishBack = new THREE.Mesh(
        new THREE.SphereGeometry(1.58, 32, 20, 0, Math.PI*2, Math.PI*0.45, Math.PI*0.15),
        makeMat(cream, { roughness: 0.7 })
      );
      dishBack.rotation.x = Math.PI; dishBack.rotation.z = 0.15;
      radar.add(dishBack);

      // Dish rim
      var rim = new THREE.Mesh(
        new THREE.TorusGeometry(1.6, 0.035, 10, 56),
        makeMat(metal, { metalness: 0.8, roughness: 0.2 })
      );
      rim.rotation.x = Math.PI * 0.43; rim.rotation.z = 0.15; rim.position.z = 0.04;
      radar.add(rim);

      // Dish panel lines (wireframe overlay)
      var panelGeo = new THREE.SphereGeometry(1.59, 14, 10, 0, Math.PI*2, 0, Math.PI*0.43);
      var panelLine = new THREE.LineSegments(
        new THREE.EdgesGeometry(panelGeo),
        new THREE.LineBasicMaterial({ color: 0x4a5a6a, transparent: true, opacity: 0.2 })
      );
      panelLine.rotation.x = Math.PI; panelLine.rotation.z = 0.15;
      radar.add(panelLine);

      // ── 2. Feed Horn Antenna (at focal point) ──
      var feedGroup = new THREE.Group();
      feedGroup.position.set(0.3, 0.8, 0); // Offset because dish is tilted
      radar.add(feedGroup);

      var feedBody = new THREE.Mesh(
        new THREE.ConeGeometry(0.2, 0.25, 8),
        makeMat(metal, { metalness: 0.7, roughness: 0.3 })
      );
      feedBody.rotation.x = Math.PI * 0.5;
      feedGroup.add(feedBody);

      var feedTip = new THREE.Mesh(
        new THREE.SphereGeometry(0.045, 6, 6),
        makeMat(0x445566, { metalness: 0.9, roughness: 0.2 })
      );
      feedTip.position.z = 0.15;
      feedGroup.add(feedTip);

      // Feed support struts (3 thin cylinders to dish edge)
      for (var s = 0; s < 3; s++) {
        var angle = (s / 3) * Math.PI * 2;
        var strut = new THREE.Mesh(
          new THREE.CylinderGeometry(0.012, 0.018, 1.0, 4),
          makeMat(metal, { metalness: 0.7, roughness: 0.3 })
        );
        strut.position.set(
          Math.cos(angle) * 0.7,
          0.6 - Math.sin(angle) * 0.4,
          Math.sin(angle) * 0.3
        );
        strut.rotation.z = Math.cos(angle) * 0.15;
        strut.rotation.x = Math.sin(angle) * 0.15;
        radar.add(strut);
      }

      // ── 3. Radome (white dome enclosure - back) ──
      var radome = new THREE.Mesh(
        new THREE.SphereGeometry(1.2, 24, 18, 0, Math.PI, 0, Math.PI*0.4),
        makeMat(cream, { roughness: 0.8, transparent: true, opacity: 0.3 })
      );
      radome.position.set(-0.1, -0.1, 0.6);
      radome.rotation.x = 0.2; radome.rotation.z = 0.1;
      radar.add(radome);

      // ── 4. Pedestal / Mast ──
      var mast = new THREE.Mesh(
        new THREE.CylinderGeometry(0.12, 0.18, 1.4, 10),
        makeMat(metal, { metalness: 0.6, roughness: 0.5 })
      );
      mast.position.set(0, -1.3, 0);
      radar.add(mast);

      // Mast ring detail
      var mastRing = new THREE.Mesh(
        new THREE.TorusGeometry(0.16, 0.025, 6, 12),
        makeMat(darkIron, { metalness: 0.7, roughness: 0.4 })
      );
      mastRing.position.set(0, -0.7, 0);
      mastRing.rotation.x = Math.PI * 0.5;
      radar.add(mastRing);

      // ── 5. Equipment Cabinet (base) ──
      var cabinet = new THREE.Mesh(
        new THREE.BoxGeometry(0.6, 0.35, 0.5),
        makeMat(darkIron, { roughness: 0.8 })
      );
      cabinet.position.set(0, -1.95, 0.1);
      radar.add(cabinet);

      // Cabinet details
      var vent = new THREE.Mesh(
        new THREE.BoxGeometry(0.35, 0.02, 0.02),
        makeMat(0x4a5a6a, { metalness: 0.5, roughness: 0.5 })
      );
      for (var v = 0; v < 4; v++) {
        var vv = vent.clone();
        vv.position.set(0.1, -1.85 + v * 0.06, 0.35);
        radar.add(vv);
      }

      // Base plate
      var basePlate = new THREE.Mesh(
        new THREE.CylinderGeometry(0.5, 0.55, 0.1, 8),
        makeMat(darkIron, { roughness: 0.9 })
      );
      basePlate.position.set(0, -2.15, 0);
      radar.add(basePlate);

      // ── 6. Broken Scanner Arm ──
      var armGroup = new THREE.Group();
      armGroup.position.set(0, 0.2, 0);
      radar.add(armGroup);

      // Arm girder (more realistic than a flat bar)
      var armBeam = new THREE.Mesh(
        new THREE.BoxGeometry(1.6, 0.04, 0.06),
        makeMat(metal, { metalness: 0.7, roughness: 0.3 })
      );
      armGroup.add(armBeam);

      // Arm cross-braces
      for (var b = -2; b <= 2; b++) {
        if (b === 0) continue;
        var brace = new THREE.Mesh(
          new THREE.BoxGeometry(0.02, 0.02, 0.1),
          makeMat(metal, { metalness: 0.6, roughness: 0.4 })
        );
        brace.position.set(b * 0.3, 0, 0);
        armGroup.add(brace);
      }

      // Scanner tips with glow
      var tipMat2 = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.8,
        transparent: true, opacity: 0.9,
      });
      var tipA = new THREE.Mesh(new THREE.SphereGeometry(0.05, 6, 6), tipMat2);
      tipA.position.set(0.8, 0, 0);
      armGroup.add(tipA);
      var tipB = new THREE.Mesh(new THREE.SphereGeometry(0.05, 6, 6), tipMat2);
      tipB.position.set(-0.8, 0, 0);
      armGroup.add(tipB);

      // ── 7. Warning Light (amber, blinking) ──
      var warnLight = new THREE.Mesh(
        new THREE.SphereGeometry(0.08, 8, 8),
        new THREE.MeshPhysicalMaterial({
          color: amber, emissive: amber, emissiveIntensity: 1.0,
          transparent: true, opacity: 0.9,
        })
      );
      warnLight.position.set(-0.2, 0.4, 1.1);
      radar.add(warnLight);

      // Light housing
      var lightHousing = new THREE.Mesh(
        new THREE.CylinderGeometry(0.07, 0.09, 0.06, 6),
        makeMat(metal, { metalness: 0.8, roughness: 0.2 })
      );
      lightHousing.position.set(-0.2, 0.36, 1.1);
      radar.add(lightHousing);

      // ── 8. Broken/Damaged Details ──

      // Cracked dish fragment floating
      var frag1 = new THREE.Mesh(
        new THREE.SphereGeometry(0.25, 5, 4, 0, Math.PI*0.5, 0, Math.PI*0.3),
        makeMat(cream, { roughness: 0.6 })
      );
      frag1.position.set(1.7, 0.7, 0.4);
      frag1.rotation.set(0.6, 0.4, 1.1);
      frag1.scale.set(0.7, 0.4, 0.5);
      radar.add(frag1);

      // Another fragment (metal piece)
      var frag2 = new THREE.Mesh(
        new THREE.BoxGeometry(0.12, 0.015, 0.2),
        makeMat(metal, { metalness: 0.7, roughness: 0.3 })
      );
      frag2.position.set(-1.5, 0.5, -0.2);
      frag2.rotation.set(0.7, 0.9, 0.3);
      radar.add(frag2);

      // Dangling broken cable
      var cablePts = [];
      cablePts.push(new THREE.Vector3(0.4, -0.2, 1.2));
      cablePts.push(new THREE.Vector3(0.7, -0.8, 1.0));
      cablePts.push(new THREE.Vector3(0.5, -1.3, 0.7));
      var cableGeo = new THREE.BufferGeometry().setFromPoints(cablePts);
      var cable = new THREE.Line(cableGeo, new THREE.LineBasicMaterial({
        color: copper, transparent: true, opacity: 0.5,
      }));
      radar.add(cable);

      // Spark particles at broken edge
      var sparkCount = 25;
      var sparkGeo2 = new THREE.BufferGeometry();
      var sparkPos2 = new Float32Array(sparkCount * 3);
      for (var i = 0; i < sparkCount * 3; i += 3) {
        var a = Math.random() * Math.PI * 2;
        var r = 0.1 + Math.random() * 0.25;
        sparkPos2[i] = 1.5 + Math.cos(a) * r;
        sparkPos2[i+1] = 0.3 + Math.sin(a) * r * 0.5;
        sparkPos2[i+2] = (Math.random() - 0.5) * 0.15;
      }
      sparkGeo2.setAttribute('position', new THREE.BufferAttribute(sparkPos2, 3));
      var sparkMat2 = new THREE.PointsMaterial({
        color: 0x00e5ff, size: 0.03, transparent: true, opacity: 0.5,
        blending: THREE.AdditiveBlending,
      });
      var sparks = new THREE.Points(sparkGeo2, sparkMat2);
      radar.add(sparks);

      // ── 9. Broken Scan Ring ──
      var ringMat2 = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.08,
        transparent: true, opacity: 0.25,
      });
      var ring2 = new THREE.Mesh(
        new THREE.TorusGeometry(0.9, 0.012, 6, 40, Math.PI * 1.3),
        ringMat2
      );
      ring2.position.set(0, 0.1, 0);
      ring2.rotation.x = Math.PI * 0.15;
      ring2.rotation.z = 0.3;
      radar.add(ring2);

      // Initial tilt
      radar.rotation.x = 0.12;
      radar.rotation.z = -0.15;

      // ─── Mouse ───
      let mouseX = 0, mouseY = 0;
      document.addEventListener('mousemove', function(e) {
        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
      });

      // ─── Animate ───
      var time = 0;
      function animate() {
        requestAnimationFrame(animate);
        time += 0.005;

        // Radar floats freely across the screen like drifting in space
        var driftX = Math.sin(time * 0.15) * 1.8 + Math.sin(time * 0.07) * 1.2;
        var driftY = Math.cos(time * 0.12) * 1.2 + Math.sin(time * 0.09) * 0.8;
        var driftZ = Math.sin(time * 0.05) * 0.5;
        radar.position.x = driftX;
        radar.position.y = driftY;
        radar.position.z = driftZ;
        // Slow tumbling rotation
        radar.rotation.x = 0.15 + Math.sin(time * 0.1) * 0.15;
        radar.rotation.y = Math.sin(time * 0.08) * 0.3;
        radar.rotation.z = -0.2 + Math.cos(time * 0.09) * 0.12;

        if (Math.sin(time * 5) > 0) armGroup.rotation.y += 0.01;
        else armGroup.rotation.y += 0.003;

        var pulse = Math.sin(time * 3) * 0.3 + 0.6;
        tipMat2.emissiveIntensity = pulse;
        // Amber warning light blinks
        warnLight.material.emissiveIntensity = 0.3 + Math.sin(time * 4) * 0.7;

        ringMat2.opacity = 0.15 + Math.sin(time * 2) * 0.1;

        camera.position.x += (mouseX * 0.3 - camera.position.x) * 0.01;
        camera.position.y += (-mouseY * 0.2 + 1.5 - camera.position.y) * 0.01;
        camera.lookAt(0, 0, 0);

        stars.rotation.y += 0.00003;

        renderer.render(scene, camera);
      }
      animate();

      // ─── Resize ───
      window.addEventListener('resize', function() {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });

      // ─── Theme sync ───
      function updateBg() {
        scene.background = new THREE.Color(
          document.documentElement.classList.contains('dark') ? 0x050508 : 0xf0f2f6
        );
      }
      var obs = new MutationObserver(function() { updateBg(); });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      updateBg();
    });
  </script>
</Layout>
