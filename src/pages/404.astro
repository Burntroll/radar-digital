---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página não encontrada" description="404 - Página não encontrada no Radar Digital">
  <!-- Three.js Canvas -->
  <canvas id="bg-canvas" class="fixed inset-0 z-0"></canvas>

  <!-- 404 Content Overlay -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <!-- Glow behind 404 -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.08) 0%, transparent 60%);">
    </div>

    <div class="relative">
      <!-- 404 Number -->
      <h1 class="text-[10rem] sm:text-[14rem] md:text-[18rem] font-black leading-none tracking-tighter gradient-text select-none">
        404
      </h1>

      <!-- Decorative line -->
      <div class="flex items-center gap-3 justify-center my-4">
        <span class="h-px w-12" style="background: linear-gradient(90deg, transparent, var(--color-border));"></span>
        <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse-cyan"></span>
        <span class="h-px w-12" style="background: linear-gradient(90deg, var(--color-border), transparent);"></span>
      </div>

      <!-- Subtitle -->
      <p class="text-text-secondary text-lg sm:text-xl font-medium transition-colors">
        Sinal perdido no espaço
      </p>
      <p class="text-text-muted text-sm mt-2 max-w-md mx-auto transition-colors">
        O radar não encontrou a página que você procura. Ela pode ter sido movida ou nunca existiu.
      </p>

      <!-- Actions -->
      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/" 
           class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                  bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 
                  hover:bg-cyan-500/20 hover:border-cyan-500/50 transition-all duration-300">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar ao Radar
        </a>
        <button onclick="window.history.back()"
                class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                       text-text-secondary border border-surface hover:border-cyan-500/30 hover:text-cyan-500
                       transition-all duration-300 cursor-pointer">
          Página anterior
        </button>
      </div>
    </div>
  </div>

  <!-- Client script: Three.js scene -->
  <script>
    import * as THREE from 'three';

    const canvas = document.getElementById('bg-canvas');
    if (!canvas) throw new Error('Canvas not found');

    // ─── Scene setup ───
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x050508);

    const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 2000);
    camera.position.set(0, 1.5, 7);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ 
      canvas, 
      alpha: false,
      antialias: true,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    // ─── Lights ───
    const ambient = new THREE.AmbientLight(0x222244, 0.3);
    scene.add(ambient);

    const mainLight = new THREE.DirectionalLight(0x00e5ff, 1.5);
    mainLight.position.set(3, 5, 4);
    scene.add(mainLight);

    const rimLight = new THREE.DirectionalLight(0x7c3aed, 0.8);
    rimLight.position.set(-4, -2, 3);
    scene.add(rimLight);

    const warmLight = new THREE.PointLight(0xff8844, 0.4, 10);
    warmLight.position.set(2, -1, 3);
    scene.add(warmLight);

    // ─── STARS (realistic) ───
    const starCount = 3000;
    const starGeo = new THREE.BufferGeometry();
    const starPos = new Float32Array(starCount * 3);
    const starSizes = new Float32Array(starCount);
    const starColors = new Float32Array(starCount * 3);

    for (let i = 0; i < starCount; i++) {
      // Distribute in a very large sphere
      const radius = 30 + Math.random() * 120; // Far away
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      
      starPos[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
      starPos[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      starPos[i * 3 + 2] = radius * Math.cos(phi);

      // Size: most are small, some are bigger
      starSizes[i] = 0.3 + Math.random() * 1.2;
      if (Math.random() < 0.03) starSizes[i] = 2.0 + Math.random() * 2.0; // A few bright ones

      // Color: mostly white, some warm, some cool
      const temp = Math.random();
      if (temp < 0.15) {
        // Blue-white (hot stars)
        starColors[i * 3] = 0.7 + Math.random() * 0.3;
        starColors[i * 3 + 1] = 0.8 + Math.random() * 0.2;
        starColors[i * 3 + 2] = 1.0;
      } else if (temp < 0.25) {
        // Yellow-orange (cool stars)
        starColors[i * 3] = 1.0;
        starColors[i * 3 + 1] = 0.7 + Math.random() * 0.3;
        starColors[i * 3 + 2] = 0.4 + Math.random() * 0.3;
      } else {
        // White
        const w = 0.85 + Math.random() * 0.15;
        starColors[i * 3] = w;
        starColors[i * 3 + 1] = w;
        starColors[i * 3 + 2] = w;
      }
    }

    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
    starGeo.setAttribute('size', new THREE.BufferAttribute(starSizes, 1));
    starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

    // Create a star texture (soft dot)
    const starCanvas = document.createElement('canvas');
    starCanvas.width = 64;
    starCanvas.height = 64;
    const ctx = starCanvas.getContext('2d');
    const gradient = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
    gradient.addColorStop(0, 'rgba(255,255,255,1)');
    gradient.addColorStop(0.2, 'rgba(255,255,255,0.8)');
    gradient.addColorStop(0.5, 'rgba(255,255,255,0.3)');
    gradient.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, 64, 64);
    const starTexture = new THREE.CanvasTexture(starCanvas);

    const starMat = new THREE.PointsMaterial({
      size: 0.3,
      map: starTexture,
      vertexColors: true,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });
    const stars = new THREE.Points(starGeo, starMat);
    stars.renderOrder = -1;
    scene.add(stars);

    // ─── BROKEN RADAR ───

    // Group to hold all radar parts
    const radarGroup = new THREE.Group();
    radarGroup.position.set(0, 0, 0);
    scene.add(radarGroup);

    // Materials
    const dishMat = new THREE.MeshPhysicalMaterial({
      color: 0x1a2a3a,
      metalness: 0.7,
      roughness: 0.3,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.04,
    });

    const accentMat = new THREE.MeshPhysicalMaterial({
      color: 0x00e5ff,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.3,
      metalness: 0.9,
      roughness: 0.2,
    });

    const darkMat = new THREE.MeshPhysicalMaterial({
      color: 0x0d1a2a,
      metalness: 0.5,
      roughness: 0.6,
    });

    // ─── 1. Radar Dish (Paraboloid approximation) ───
    const dishGeo = new THREE.SphereGeometry(1.6, 48, 32, 0, Math.PI * 2, 0, Math.PI * 0.4);
    const dish = new THREE.Mesh(dishGeo, dishMat);
    dish.rotation.x = Math.PI;
    dish.rotation.z = 0.2; // Slightly tilted - damaged
    radarGroup.add(dish);

    // Dish rim
    const rimGeo = new THREE.TorusGeometry(1.6, 0.04, 16, 64);
    const rimMat = new THREE.MeshPhysicalMaterial({
      color: 0x00e5ff,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.15,
      metalness: 0.8,
      roughness: 0.2,
    });
    const rim2 = new THREE.Mesh(rimGeo, rimMat);
    rim2.rotation.x = Math.PI * 0.38;
    rim2.rotation.z = 0.2;
    rim2.position.z = 0.05;
    radarGroup.add(rim2);

    // ─── 2. Central Mast ───
    const mastGeo = new THREE.CylinderGeometry(0.08, 0.12, 1.2, 8);
    const mast = new THREE.Mesh(mastGeo, darkMat);
    mast.position.set(0, -1.2, 0);
    radarGroup.add(mast);

    // Base platform
    const baseGeo = new THREE.CylinderGeometry(0.4, 0.5, 0.15, 8);
    const base = new THREE.Mesh(baseGeo, darkMat);
    base.position.set(0, -1.8, 0);
    radarGroup.add(base);

    // ─── 3. Scanner Arm (the rotating part) ───
    const armGroup = new THREE.Group();
    armGroup.position.set(0, 0.3, 0);
    radarGroup.add(armGroup);

    // Main arm
    const armGeo = new THREE.BoxGeometry(1.8, 0.04, 0.04);
    const arm = new THREE.Mesh(armGeo, accentMat);
    armGroup.add(arm);

    // Arm tip glow
    const tipGeo = new THREE.SphereGeometry(0.06, 8, 8);
    const tipMat = new THREE.MeshPhysicalMaterial({
      color: 0x00e5ff,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.8,
      transparent: true,
      opacity: 0.9,
    });
    const tip = new THREE.Mesh(tipGeo, tipMat);
    tip.position.set(0.9, 0, 0);
    armGroup.add(tip);

    const tip2 = new THREE.Mesh(tipGeo, tipMat);
    tip2.position.set(-0.9, 0, 0);
    armGroup.add(tip2);

    // ─── 4. Broken/Damaged details ───

    // A cracked piece floating nearby
    const crackGeo = new THREE.SphereGeometry(0.3, 6, 4, 0, Math.PI * 0.6, 0, Math.PI * 0.3);
    const crackPiece = new THREE.Mesh(crackGeo, dishMat);
    crackPiece.position.set(1.8, 0.8, 0.5);
    crackPiece.rotation.set(0.7, 0.3, 1.2);
    crackPiece.scale.set(0.8, 0.5, 0.6);
    radarGroup.add(crackPiece);

    // Another fragment
    const fragGeo = new THREE.BoxGeometry(0.15, 0.02, 0.25);
    const fragMat = new THREE.MeshPhysicalMaterial({
      color: 0x1a2a3a,
      metalness: 0.5,
      roughness: 0.5,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.02,
    });
    const frag1 = new THREE.Mesh(fragGeo, fragMat);
    frag1.position.set(-1.4, 0.6, -0.3);
    frag1.rotation.set(0.5, 0.8, 0.2);
    radarGroup.add(frag1);

    // ─── 5. Spark/Flicker effect (small glow around damage) ───
    const sparkMat = new THREE.PointsMaterial({
      color: 0x00e5ff,
      size: 0.04,
      transparent: true,
      opacity: 0.6,
      blending: THREE.AdditiveBlending,
    });
    const sparkCount = 30;
    const sparkGeo2 = new THREE.BufferGeometry();
    const sparkPos = new Float32Array(sparkCount * 3);
    for (let i = 0; i < sparkCount * 3; i += 3) {
      const angle = Math.random() * Math.PI * 2;
      const r = 0.1 + Math.random() * 0.3;
      sparkPos[i] = 1.6 + Math.cos(angle) * r;
      sparkPos[i + 1] = 0.3 + Math.sin(angle) * r * 0.5;
      sparkPos[i + 2] = (Math.random() - 0.5) * 0.2;
    }
    sparkGeo2.setAttribute('position', new THREE.BufferAttribute(sparkPos, 3));
    const sparks = new THREE.Points(sparkGeo2, sparkMat);
    radarGroup.add(sparks);

    // ─── 6. Scan ring (broken - partial) ───
    const ringGeo = new THREE.TorusGeometry(0.8, 0.015, 8, 48, Math.PI * 1.5);
    const ringMat2 = new THREE.MeshPhysicalMaterial({
      color: 0x00e5ff,
      emissive: 0x00e5ff,
      emissiveIntensity: 0.1,
      transparent: true,
      opacity: 0.3,
      wireframe: false,
    });
    const ring = new THREE.Mesh(ringGeo, ringMat2);
    ring.position.set(0, 0.1, 0);
    ring.rotation.x = Math.PI * 0.15;
    ring.rotation.z = 0.3;
    radarGroup.add(ring);

    // Connection cables (thin dangling)
    const cableMat = new THREE.LineBasicMaterial({
      color: 0x1a3a4a,
      transparent: true,
      opacity: 0.5,
    });
    for (let i = 0; i < 3; i++) {
      const pts = [];
      const startAngle = (i / 3) * Math.PI * 2;
      pts.push(new THREE.Vector3(
        Math.cos(startAngle) * 1.4,
        -0.3,
        Math.sin(startAngle) * 1.4
      ));
      pts.push(new THREE.Vector3(
        Math.cos(startAngle + 0.2) * 0.5,
        -1.8,
        Math.sin(startAngle + 0.2) * 0.5
      ));
      const cableGeo2 = new THREE.BufferGeometry().setFromPoints(pts);
      const cable = new THREE.Line(cableGeo2, cableMat);
      radarGroup.add(cable);
    }

    // ─── Tilt the whole radar (damaged/drifting look) ───
    radarGroup.rotation.x = 0.15;
    radarGroup.rotation.z = -0.2;

    // ─── Animation ───
    let mouseX = 0;
    let mouseY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
      mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
    });

    // Individual spark movement data
    const sparkSpeeds = [];
    for (let i = 0; i < sparkCount; i++) {
      sparkSpeeds.push({
        x: (Math.random() - 0.5) * 0.002,
        y: (Math.random() - 0.5) * 0.002,
        z: (Math.random() - 0.5) * 0.002,
      });
    }

    let time = 0;
    function animate() {
      requestAnimationFrame(animate);
      time += 0.005;

      // Slow drift of the whole radar
      const driftX = Math.sin(time * 0.3) * 0.03;
      const driftY = Math.cos(time * 0.2) * 0.02;
      radarGroup.position.x = driftX;
      radarGroup.position.y = driftY;

      // Subtle wobble (damaged)
      radarGroup.rotation.x = 0.15 + Math.sin(time * 0.5) * 0.02;
      radarGroup.rotation.z = -0.2 + Math.cos(time * 0.4) * 0.015;

      // Scanner arm rotates (but stutters like it's broken)
      const armSpeed = 0.01;
      if (Math.sin(time * 5) > 0) {
        armGroup.rotation.y += armSpeed;
      } else {
        armGroup.rotation.y += armSpeed * 0.3; // Stutter
      }

      // Pulse the emissive on the tips
      const pulse = Math.sin(time * 3) * 0.3 + 0.6;
      tipMat.emissiveIntensity = pulse;
      tip2Mat.emissiveIntensity = pulse;

      // Sparks float randomly
      const sparkPosAttr = sparkGeo2.attributes.position;
      for (let i = 0; i < sparkCount; i++) {
        sparkPosAttr.array[i * 3] += sparkSpeeds[i].x;
        sparkPosAttr.array[i * 3 + 1] += sparkSpeeds[i].y;
        sparkPosAttr.array[i * 3 + 2] += sparkSpeeds[i].z;
        
        // Keep them near the dish edge
        const dx = sparkPosAttr.array[i * 3] - 1.6;
        const dy = sparkPosAttr.array[i * 3 + 1] - 0.3;
        if (Math.abs(dx) > 0.5 || Math.abs(dy) > 0.5) {
          const angle = Math.random() * Math.PI * 2;
          sparkPosAttr.array[i * 3] = 1.6 + Math.cos(angle) * (0.1 + Math.random() * 0.2);
          sparkPosAttr.array[i * 3 + 1] = 0.3 + Math.sin(angle) * (0.1 + Math.random() * 0.2);
        }
      }
      sparkPosAttr.needsUpdate = true;

      // Pulse spark opacity
      sparkMat.opacity = 0.3 + Math.sin(time * 4) * 0.2;

      // Pulse ring opacity
      ringMat2.opacity = 0.15 + Math.sin(time * 2) * 0.1;

      // Subtle camera parallax with mouse
      camera.position.x += (mouseX * 0.3 - camera.position.x) * 0.01;
      camera.position.y += (-mouseY * 0.2 + 1.5 - camera.position.y) * 0.01;
      camera.lookAt(radarGroup.position.x, radarGroup.position.y, 0);

      // Very slow star rotation
      stars.rotation.y += 0.00003;

      renderer.render(scene, camera);
    }

    animate();

    // ─── Resize ───
    window.addEventListener('resize', () => {
      const w = window.innerWidth;
      const h = window.innerHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });

    // ─── Theme sync ───
    function updateBg() {
      const isDark = document.documentElement.classList.contains('dark');
      scene.background = new THREE.Color(isDark ? 0x050508 : 0xf0f2f6);
    }
    const observer = new MutationObserver(() => updateBg());
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    updateBg();
  </script>
</Layout>
