---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página não encontrada" description="404 - Página não encontrada no Radar Digital">
  <!-- Three.js via CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <!-- Three.js Canvas -->
  <canvas id="bg-canvas" class="fixed inset-0 z-0" style="position: fixed; inset: 0; z-index: 0; width: 100vw; height: 100vh;"></canvas>

  <!-- 404 Content Overlay -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <!-- Glow behind 404 -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.08) 0%, transparent 60%);">
    </div>

    <div class="relative">
      <h1 class="text-[10rem] sm:text-[14rem] md:text-[18rem] font-black leading-none tracking-tighter gradient-text select-none">
        404
      </h1>

      <div class="flex items-center gap-3 justify-center my-4">
        <span class="h-px w-12" style="background: linear-gradient(90deg, transparent, var(--color-border));"></span>
        <span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse-cyan"></span>
        <span class="h-px w-12" style="background: linear-gradient(90deg, var(--color-border), transparent);"></span>
      </div>

      <p class="text-text-secondary text-lg sm:text-xl font-medium transition-colors">
        Sinal perdido no espaço
      </p>
      <p class="text-text-muted text-sm mt-2 max-w-md mx-auto transition-colors">
        O radar não encontrou a página que você procura. Ela pode ter sido movida ou nunca existiu.
      </p>

      <div class="flex flex-wrap gap-4 justify-center mt-10">
        <a href="/" 
           class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                  bg-cyan-500/10 text-cyan-500 border border-cyan-500/30 
                  hover:bg-cyan-500/20 hover:border-cyan-500/50 transition-all duration-300">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar ao Radar
        </a>
        <button onclick="window.history.back()"
                class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-sm 
                       text-text-secondary border border-surface hover:border-cyan-500/30 hover:text-cyan-500
                       transition-all duration-300 cursor-pointer">
          Página anterior
        </button>
      </div>
    </div>
  </div>

  <!-- Three.js Scene -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const canvas = document.getElementById('bg-canvas');
      if (!canvas || !window.THREE) return;

      const THREE = window.THREE;

      // ─── Scene ───
      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x050508);

      const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 2000);
      camera.position.set(0, 1.5, 7);

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;

      // ─── Lights ───
      scene.add(new THREE.AmbientLight(0x222244, 0.3));
      const ml = new THREE.DirectionalLight(0x00e5ff, 1.5);
      ml.position.set(3, 5, 4);
      scene.add(ml);
      const rl = new THREE.DirectionalLight(0x7c3aed, 0.8);
      rl.position.set(-4, -2, 3);
      scene.add(rl);

      // ─── Stars ───
      const starCount = 3000;
      const starGeo = new THREE.BufferGeometry();
      const starPos = new Float32Array(starCount * 3);
      const starSizes = new Float32Array(starCount);
      const starColors = new Float32Array(starCount * 3);

      for (let i = 0; i < starCount; i++) {
        const radius = 30 + Math.random() * 120;
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        starPos[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
        starPos[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
        starPos[i * 3 + 2] = radius * Math.cos(phi);
        starSizes[i] = 0.3 + Math.random() * 1.2;
        if (Math.random() < 0.03) starSizes[i] = 2.0 + Math.random() * 2.0;
        const temp = Math.random();
        if (temp < 0.15) {
          starColors[i * 3] = 0.7 + Math.random() * 0.3;
          starColors[i * 3 + 1] = 0.8 + Math.random() * 0.2;
          starColors[i * 3 + 2] = 1.0;
        } else if (temp < 0.25) {
          starColors[i * 3] = 1.0;
          starColors[i * 3 + 1] = 0.7 + Math.random() * 0.3;
          starColors[i * 3 + 2] = 0.4 + Math.random() * 0.3;
        } else {
          const w = 0.85 + Math.random() * 0.15;
          starColors[i * 3] = w; starColors[i * 3 + 1] = w; starColors[i * 3 + 2] = w;
        }
      }
      starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
      starGeo.setAttribute('size', new THREE.BufferAttribute(starSizes, 1));
      starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));

      const starTex = (function() {
        const c = document.createElement('canvas');
        c.width = 64; c.height = 64;
        const ctx = c.getContext('2d');
        const g = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
        g.addColorStop(0, 'rgba(255,255,255,1)');
        g.addColorStop(0.2, 'rgba(255,255,255,0.8)');
        g.addColorStop(0.5, 'rgba(255,255,255,0.3)');
        g.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, 64, 64);
        return new THREE.CanvasTexture(c);
      })();

      const starMat = new THREE.PointsMaterial({
        size: 0.3, map: starTex, vertexColors: true, transparent: true,
        blending: THREE.AdditiveBlending, depthWrite: false, sizeAttenuation: true,
      });
      const stars = new THREE.Points(starGeo, starMat);
      scene.add(stars);

      // ─── Broken Radar ───
      const radar = new THREE.Group();
      scene.add(radar);

      const dishMat = new THREE.MeshPhysicalMaterial({
        color: 0x1a2a3a, metalness: 0.7, roughness: 0.3,
        emissive: 0x00e5ff, emissiveIntensity: 0.04,
      });
      const accentMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.3,
        metalness: 0.9, roughness: 0.2,
      });
      const darkMat = new THREE.MeshPhysicalMaterial({
        color: 0x0d1a2a, metalness: 0.5, roughness: 0.6,
      });

      // Dish
      const dish = new THREE.Mesh(new THREE.SphereGeometry(1.6, 32, 24, 0, Math.PI * 2, 0, Math.PI * 0.4), dishMat);
      dish.rotation.x = Math.PI;
      dish.rotation.z = 0.2;
      radar.add(dish);

      // Rim
      const rim = new THREE.Mesh(
        new THREE.TorusGeometry(1.6, 0.04, 12, 48),
        new THREE.MeshPhysicalMaterial({ color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.15, metalness: 0.8, roughness: 0.2 })
      );
      rim.rotation.x = Math.PI * 0.38;
      rim.rotation.z = 0.2;
      rim.position.z = 0.05;
      radar.add(rim);

      // Mast
      const mast = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.12, 1.2, 6), darkMat);
      mast.position.set(0, -1.2, 0);
      radar.add(mast);

      // Base
      const base = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.5, 0.15, 6), darkMat);
      base.position.set(0, -1.8, 0);
      radar.add(base);

      // Arm
      const armGroup = new THREE.Group();
      armGroup.position.set(0, 0.3, 0);
      radar.add(armGroup);

      const arm = new THREE.Mesh(new THREE.BoxGeometry(1.8, 0.04, 0.04), accentMat);
      armGroup.add(arm);

      const tipMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.8, transparent: true, opacity: 0.9,
      });
      const t1 = new THREE.Mesh(new THREE.SphereGeometry(0.06, 6, 6), tipMat);
      t1.position.set(0.9, 0, 0);
      armGroup.add(t1);
      const t2 = new THREE.Mesh(new THREE.SphereGeometry(0.06, 6, 6), tipMat);
      t2.position.set(-0.9, 0, 0);
      armGroup.add(t2);

      // Broken piece
      const crack = new THREE.Mesh(new THREE.SphereGeometry(0.3, 5, 4, 0, Math.PI * 0.6, 0, Math.PI * 0.3), dishMat);
      crack.position.set(1.8, 0.8, 0.5);
      crack.rotation.set(0.7, 0.3, 1.2);
      crack.scale.set(0.8, 0.5, 0.6);
      radar.add(crack);

      // Fragment
      const frag = new THREE.Mesh(
        new THREE.BoxGeometry(0.15, 0.02, 0.25),
        new THREE.MeshPhysicalMaterial({ color: 0x1a2a3a, metalness: 0.5, roughness: 0.5, emissive: 0x00e5ff, emissiveIntensity: 0.02 })
      );
      frag.position.set(-1.4, 0.6, -0.3);
      frag.rotation.set(0.5, 0.8, 0.2);
      radar.add(frag);

      // Ring
      const ringMat = new THREE.MeshPhysicalMaterial({
        color: 0x00e5ff, emissive: 0x00e5ff, emissiveIntensity: 0.1, transparent: true, opacity: 0.3,
      });
      const ring = new THREE.Mesh(new THREE.TorusGeometry(0.8, 0.015, 6, 32, Math.PI * 1.5), ringMat);
      ring.position.set(0, 0.1, 0);
      ring.rotation.x = Math.PI * 0.15;
      ring.rotation.z = 0.3;
      radar.add(ring);

      // Tilt
      radar.rotation.x = 0.15;
      radar.rotation.z = -0.2;

      // ─── Mouse ───
      let mouseX = 0, mouseY = 0;
      document.addEventListener('mousemove', function(e) {
        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
      });

      // ─── Animate ───
      var time = 0;
      function animate() {
        requestAnimationFrame(animate);
        time += 0.005;

        // Radar floats freely across the screen like drifting in space
        var driftX = Math.sin(time * 0.15) * 1.8 + Math.sin(time * 0.07) * 1.2;
        var driftY = Math.cos(time * 0.12) * 1.2 + Math.sin(time * 0.09) * 0.8;
        var driftZ = Math.sin(time * 0.05) * 0.5;
        radar.position.x = driftX;
        radar.position.y = driftY;
        radar.position.z = driftZ;
        // Slow tumbling rotation
        radar.rotation.x = 0.15 + Math.sin(time * 0.1) * 0.15;
        radar.rotation.y = Math.sin(time * 0.08) * 0.3;
        radar.rotation.z = -0.2 + Math.cos(time * 0.09) * 0.12;

        if (Math.sin(time * 5) > 0) armGroup.rotation.y += 0.01;
        else armGroup.rotation.y += 0.003;

        var pulse = Math.sin(time * 3) * 0.3 + 0.6;
        tipMat.emissiveIntensity = pulse;

        ringMat.opacity = 0.15 + Math.sin(time * 2) * 0.1;

        camera.position.x += (mouseX * 0.3 - camera.position.x) * 0.01;
        camera.position.y += (-mouseY * 0.2 + 1.5 - camera.position.y) * 0.01;
        camera.lookAt(radar.position.x, radar.position.y, radar.position.z);

        stars.rotation.y += 0.00003;

        renderer.render(scene, camera);
      }
      animate();

      // ─── Resize ───
      window.addEventListener('resize', function() {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });

      // ─── Theme sync ───
      function updateBg() {
        scene.background = new THREE.Color(
          document.documentElement.classList.contains('dark') ? 0x050508 : 0xf0f2f6
        );
      }
      var obs = new MutationObserver(function() { updateBg(); });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      updateBg();
    });
  </script>
</Layout>
