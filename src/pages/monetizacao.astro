---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, getDateLocale, type Locale } from '../i18n/utils';
import { routePath } from '../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const categoria = 'monetizacao';
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const categoriaInfo = {
  slug: 'monetizacao',
  name: t('cat.monetizacao.name', locale),
  tagline: t('cat.monetizacao.tagline', locale),
  description: t('cat.monetizacao.desc', locale),
  color: 'amber',
};
const publicados = await getCollection('artigos', ({ data }) =>
  data.categoria === categoria && data.draft === false && data.contentType !== 'guide' && (data.locale || 'pt-BR') === locale
);
publicados.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<Layout 
  title={categoriaInfo.name} 
  description={categoriaInfo.description}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: categoriaInfo.name, href: routePath('monetizacao', locale)}
  ]}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO DA CATEGORIA -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-surface transition-colors duration-300">
    <!-- Background glow amber -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(245, 158, 11, 0.25) 0%, transparent 60%);"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] rounded-full opacity-10 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(239, 68, 68, 0.2) 0%, transparent 60%);"></div>

    <!-- Breadcrumb -->
    <div class="max-w-6xl mx-auto px-6 relative z-10 mb-8">
      <nav class="flex items-center gap-2 text-xs text-text-muted transition-colors">
        <a href={`${prefix}/`} class="hover:text-amber-500 transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-amber-500">{categoriaInfo.name}</span>
      </nav>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary transition-colors">{categoriaInfo.name}</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed transition-colors">
        {categoriaInfo.description}
      </p>

      <!-- Stats da categoria -->
      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
        <div>
          <div class="text-2xl font-bold text-amber-500">
            {publicados.length}
          </div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('cat.articles.published', locale)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- ARTIGOS -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 class="section-title mt-4 text-text-primary transition-colors">{locale === 'pt-BR' ? 'Artigos do' : 'Artículos del'} <span class="text-amber-500">radar</span></h2>
          <p class="section-subtitle">{t('cat.monetizacao.desc', locale)}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {publicados.map((artigo) => (
          <article class="glass-card overflow-hidden group">
            <a href={artigo.data.draft ? `#` : routePath('artigos', locale, artigo.slug)} class="block">
              <div class="h-40 bg-gradient-to-br from-amber-500/15 via-orange-600/5 to-surface-elevated flex items-center justify-center transition-colors">
                <svg class="w-9 h-9 text-amber-500/40 group-hover:text-amber-500/70 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="inline-block px-2.5 py-0.5 rounded-md text-[10px] font-semibold uppercase tracking-wider bg-amber-500/10 text-amber-500 border border-amber-500/20">
                    {artigo.data.subtema}
                  </span>
                  <span class="text-[10px] text-text-muted transition-colors">· {artigo.data.readTime}</span>
                </div>
                <h3 class="font-semibold text-text-primary group-hover:text-amber-500 transition-colors leading-snug mb-2">
                  {artigo.data.title}
                </h3>
                <p class="text-xs text-text-muted leading-relaxed transition-colors line-clamp-3">
                  {artigo.data.excerpt}
                </p>
                <div class="mt-4 pt-4 border-t transition-colors flex items-center justify-between" style="border-color: var(--color-border);">
                  <span class="text-[10px] text-text-muted uppercase tracking-wider transition-colors">
                    {artigo.data.draft ? t('cat.tag.em-breve', locale) : artigo.data.date.toLocaleDateString(getDateLocale(locale), { day: '2-digit', month: 'short', year: 'numeric' })}
                  </span>
                  <span class="text-amber-500 text-xs font-medium flex items-center gap-1 opacity-50 group-hover:opacity-100 transition-opacity">
                    {artigo.data.draft ? t('cat.tag.em-breve', locale) : (locale === 'pt-BR' ? 'Ler' : 'Leer')}
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- CTA voltar -->
      <div class="mt-16 text-center">
        <a href={`${prefix}/`} class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-amber-500 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          {t('cat.cta.back', locale)}
        </a>
      </div>
    </div>
  </section>
</Layout>
