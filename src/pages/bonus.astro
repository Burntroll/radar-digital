---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getLocaleFromUrl, t, defaultLocale, type Locale } from '../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const todasCategorias = await getCollection('bonusCategorias', ({ data }) => data.draft === false);
const categoriasPublicadas = todasCategorias
  .sort((a, b) => a.data.order - b.data.order);

const bonuses = await getCollection('bonuses', ({ data }) => data.draft === false);
const bonusesDoLocale = bonuses
  .filter((b) => (b.data.locale || 'pt-BR') === locale)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout 
  title={t('bonus.title', locale)} 
  description={t('bonus.subtitle', locale)}
  breadcrumbItems={[
    {name: t('cat.breadcrumb.home', locale), href: prefix + '/'},
    {name: t('nav.bonus', locale), href: prefix + '/bonus'}
  ]}
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, rgba(245, 158, 11, 0.1) 40%, transparent 60%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 transition-colors">
        <a href={`${prefix}/`} class="hover:text-cyan-500 transition-colors">{t('cat.breadcrumb.home', locale)}</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-amber-500">{t('nav.bonus', locale)}</span>
      </nav>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary transition-colors">{t('bonus.title', locale).split(' e ')[0]} &</span>
        <span class="gradient-text"> {t('bonus.title', locale).split(' e ')[1] || ''}</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed transition-colors">
        {t('bonus.subtitle', locale)}
      </p>

      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-amber-500">{categoriasPublicadas.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{locale === 'pt-BR' ? 'Categorias' : 'Categorías'}</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary transition-colors">{bonusesDoLocale.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">{t('bonus.stats.bonuses', locale)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- FILTROS + CONTEÚDO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Filtros por categoria -->
      <div id="bonus-filters" class="flex flex-wrap gap-2 mb-8" role="tablist" aria-label="Filtrar por categoria">
        <button 
          class="filter-chip active px-4 py-2 rounded-full text-xs font-medium border transition-all duration-200 cursor-pointer"
          style="background: rgba(245, 158, 11, 0.12); color: #f59e0b; border-color: rgba(245, 158, 11, 0.3);"
          data-category="all"
          role="tab"
          aria-selected="true"
        >
          {t('bonus.filter.all', locale)}
        </button>
        {categoriasPublicadas.map((cat) => (
          <button
            class="filter-chip px-4 py-2 rounded-full text-xs font-medium border transition-all duration-200 cursor-pointer"
            style="background: transparent; color: var(--color-text-secondary, '#94a3b8'); border-color: var(--color-border, '#1e293b');"
            data-category={cat.slug}
            role="tab"
            aria-selected="false"
          >
            {t(('bonus.cat.' + cat.slug) as any, locale)}
          </button>
        ))}
      </div>

      <!-- Espaço reservado para anúncio -->
      <div class="w-full rounded-xl border overflow-hidden mb-10 transition-colors flex items-center justify-center"
           style="min-height: 100px; background: var(--color-surface-elevated, '#15171f'); border-color: var(--color-border, '#1e2130');">
        <div class="text-center py-6">
          <svg class="w-5 h-5 mx-auto mb-1.5" style="color: var(--color-text-muted, '#64748b');" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m0 0V5.625m0 0a1.125 1.125 0 011.125-1.125h3.75c.621 0 1.125.504 1.125 1.125m-6.75 0V19.5m6.75-13.875v13.875m0 0h3.75c.621 0 1.125-.504 1.125-1.125V7.5c0-.621-.504-1.125-1.125-1.125h-3.75"/>
          </svg>
          <span class="text-[11px] uppercase tracking-wider font-medium" style="color: var(--color-text-muted, '#64748b');">
            {t('bonus.ad.placeholder', locale)}
          </span>
        </div>
      </div>

      <!-- Grid de cards -->
      <div id="bonus-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {bonusesDoLocale.length === 0 ? (
          <p class="col-span-full text-center text-text-muted text-sm py-16 transition-colors">
            {t('bonus.noresults', locale)}
          </p>
        ) : (
          bonusesDoLocale.map((bonus) => {
            const catTitle = t(('bonus.cat.' + bonus.data.category) as any, locale);
            return (
              <article class="glass-card overflow-hidden group flex flex-col" data-category={bonus.data.category}>
                <div class="p-6 flex flex-col flex-1">
                  <!-- Logo / Image placeholder -->
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg font-bold mb-4"
                       style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2);">
                    {bonus.data.productName.charAt(0)}
                  </div>

                  <!-- Product name -->
                  <h3 class="font-bold text-text-primary transition-colors text-base mb-1">
                    {bonus.data.productName}
                  </h3>

                  <!-- Description -->
                  <p class="text-xs text-text-muted leading-relaxed mb-4 transition-colors">
                    {bonus.data.description}
                  </p>

                  <!-- Promo code -->
                  <div class="mb-4">
                    <span class="text-[10px] uppercase tracking-wider font-semibold text-text-muted block mb-1">{locale === 'pt-BR' ? 'Código' : 'Código'}</span>
                    <div class="flex items-center gap-2">
                      <code class="px-3 py-1.5 rounded-lg text-sm font-mono font-bold tracking-wide"
                            style="background: rgba(245, 158, 11, 0.08); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2);">
                        {bonus.data.promoCode}
                      </code>
                    </div>
                  </div>

                  <!-- Benefit -->
                  {bonus.data.benefit && (
                    <p class="text-xs text-text-secondary mb-4 transition-colors">
                      {bonus.data.benefit}
                    </p>
                  )}

                  <!-- Category tag -->
                  <div class="mt-auto pt-4 border-t transition-colors" style="border-color: var(--color-border);">
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] uppercase tracking-wider font-medium text-text-muted transition-colors">
                        {catTitle}
                      </span>
                      {bonus.data.expiresAt && (
                        <span class="text-[10px] text-text-muted transition-colors">
                          {t('bonus.expires', locale)}: {new Date(bonus.data.expiresAt).toLocaleDateString(locale === 'pt-BR' ? 'pt-BR' : 'es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
                        </span>
                      )}
                    </div>
                  </div>
                </div>

                <!-- CTA -->
                <a 
                  href={bonus.data.website}
                  target="_blank"
                  rel="sponsored noopener noreferrer"
                  class="block w-full py-3 text-center text-sm font-semibold transition-all duration-200"
                  style="background: rgba(245, 158, 11, 0.08); color: #f59e0b; border-top: 1px solid var(--color-border, '#1e293b');"
                >
                  {bonus.data.buttonText || t('bonus.cta.use', locale)}
                </a>
              </article>
            );
          })
        )}
      </div>
    </div>
  </section>
</Layout>

<!-- Client-side filter logic -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const chips = document.querySelectorAll('.filter-chip');
    const cards = document.querySelectorAll('#bonus-grid > article');
    const noResults = document.querySelector('#bonus-grid > p');

    chips.forEach(chip => {
      chip.addEventListener('click', function() {
        const category = this.dataset.category;

        // Update chip styles
        chips.forEach(c => {
          c.style.background = 'transparent';
          c.style.color = 'var(--color-text-secondary, #94a3b8)';
          c.style.borderColor = 'var(--color-border, #1e293b)';
          c.setAttribute('aria-selected', 'false');
        });
        this.style.background = 'rgba(245, 158, 11, 0.12)';
        this.style.color = '#f59e0b';
        this.style.borderColor = 'rgba(245, 158, 11, 0.3)';
        this.setAttribute('aria-selected', 'true');

        // Filter cards
        let visibleCount = 0;
        cards.forEach(card => {
          if (category === 'all' || card.dataset.category === category) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Show/hide no results
        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      });
    });
  });
</script>
