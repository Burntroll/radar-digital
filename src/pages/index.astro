---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, localizePath, t, defaultLocale, type Locale } from '../i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const prefix = locale === defaultLocale ? '' : `/${locale}`;

const artigosPublicados = await getCollection('artigos', ({ data }) =>
  data.draft === false && data.contentType === 'article' && (data.locale || 'pt-BR') === locale
);
const artigosRecentes = artigosPublicados
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

// Guias publicados (para o card de guia no Leia primeiro)
const guiasPublicados = await getCollection('artigos', ({ data }) =>
  data.draft === false && data.contentType === 'guide' && (data.locale || 'pt-BR') === locale
);
const guiaRecente = guiasPublicados
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];

const [artigoPrincipal, ...artigosSecundarios] = artigosRecentes;

// Categorias de parceiros publicadas
const parceiroCategorias = await getCollection('parceiroCategorias', ({ data }) => data.draft === false)
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));

// Bônus verificados em destaque
const bonusDestaques = (await getCollection('bonuses', ({ data }) =>
  data.draft === false && data.status === 'verified' && (data.locale || 'pt-BR') === locale
))
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
  .slice(0, 3);

// Categorias do Radar Market
const marketCategorias = await getCollection('marketCategorias', ({ data }) => data.draft === false && data.locale === 'pt-BR')
  .then(cats => cats.sort((a, b) => a.data.order - b.data.order));
---

<Layout title="Radar Digital" description={locale === 'pt-BR' ? 'Seu radar de tendências em marketing digital, inteligência artificial e monetização.' : 'Tu radar de tendencias en marketing digital, inteligencia artificial y monetización.'}
  breadcrumbItems={[{name: t('nav.home', locale), href: prefix + '/'}]}>

  <AdSlot variant="horizontal" />

  <!-- ════════════════════════════════════════════════ -->
  <!-- ABERTURA EDITORIAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pt-8 pb-6 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Masthead -->
      <div class="border-b pb-6 mb-8" style="border-color: var(--color-border);">
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight">
          <span class="text-text-primary">Radar</span>{' '}
          <span class="gradient-text">Digital</span>
        </h1>
        <p class="text-sm text-text-secondary mt-1.5 max-w-xl">
          Marketing, IA, monetização e ferramentas para quem trabalha na internet.
        </p>
      </div>

      <!-- Section label: Leia primeiro -->
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Leia primeiro</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      {artigoPrincipal ? (
        <div class="grid lg:grid-cols-3 gap-6">

          <!-- COLUNA PRINCIPAL (2/3): Artigo Principal -->
          <div class="lg:col-span-2">
            <a
              href={`${prefix}/artigos/${artigoPrincipal.slug}`}
              class="group block glass-card overflow-hidden"
            >
              <div class={`h-52 sm:h-64 bg-gradient-to-br ${
                artigoPrincipal.data.color === 'purple' ? 'from-purple-500/10 via-pink-600/5' :
                artigoPrincipal.data.color === 'amber' ? 'from-amber-500/10 via-orange-600/5' :
                'from-cyan-500/10 via-blue-600/5'
              } to-surface-elevated flex items-center justify-center transition-colors`}>
                <span class="text-5xl sm:text-6xl">{artigoPrincipal.data.emoji || '📡'}</span>
              </div>
              <div class="p-5 sm:p-6">
                <div class="flex items-center gap-2 text-xs text-text-muted mb-2 transition-colors">
                  <span class="font-semibold uppercase tracking-wider">{artigoPrincipal.data.subtema}</span>
                  <span>·</span>
                  <span>{artigoPrincipal.data.readTime}</span>
                </div>
                <h3 class="text-xl sm:text-2xl font-bold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug">
                  {artigoPrincipal.data.title}
                </h3>
                <p class="text-sm text-text-secondary mt-2 leading-relaxed transition-colors line-clamp-2">
                  {artigoPrincipal.data.excerpt}
                </p>
                <div class="flex items-center justify-between mt-4 pt-3 border-t transition-colors" style="border-color: var(--color-border);">
                  <time class="text-xs text-text-muted">
                    {artigoPrincipal.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </time>
                  <span class="text-xs font-medium text-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity">
                    {locale === 'pt-BR' ? 'Ler' : 'Leer'}
                  </span>
                </div>
              </div>
            </a>
          </div>

          <!-- COLUNA LATERAL (1/3): Secundários + Guia -->
          <div class="flex flex-col gap-4">

            {artigosSecundarios.map((artigo) => {
              const dateStr = artigo.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
              return (
                <a
                  href={`${prefix}/artigos/${artigo.slug}`}
                  class="group flex gap-4 glass-card p-4 items-start"
                >
                  <div class={`w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br ${
                    artigo.data.color === 'purple' ? 'from-purple-500/10 via-pink-600/5' :
                    artigo.data.color === 'amber' ? 'from-amber-500/10 via-orange-600/5' :
                    'from-cyan-500/10 via-blue-600/5'
                  } to-surface-elevated flex items-center justify-center transition-colors`}>
                    <span class="text-xl">{artigo.data.emoji || '📡'}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-1.5 text-[10px] text-text-muted uppercase tracking-wider mb-1">
                      <span>{artigo.data.subtema}</span>
                      <span>·</span>
                      <span>{artigo.data.readTime}</span>
                    </div>
                    <h3 class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug line-clamp-2">
                      {artigo.data.title}
                    </h3>
                    <time class="text-[10px] text-text-muted mt-1 block">{dateStr}</time>
                  </div>
                </a>
              );
            })}

            <!-- Card de Guia (se houver publicado) -->
            {guiaRecente && (
              <a
                href={`${prefix}/artigos/${guiaRecente.slug}`}
                class="group flex gap-4 glass-card p-4 items-start"
                style="border-color: rgba(168, 85, 247, 0.2);"
              >
                <div class="w-12 h-12 shrink-0 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
                  <span class="text-xl">{guiaRecente.data.emoji || '📋'}</span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-1.5 text-[10px] text-purple-500 font-semibold uppercase tracking-wider mb-1">
                    <span>Guia</span>
                    <span>·</span>
                    <span>{guiaRecente.data.readTime}</span>
                  </div>
                  <h3 class="text-sm font-semibold text-text-primary group-hover:text-purple-500 transition-colors leading-snug line-clamp-2">
                    {guiaRecente.data.title}
                  </h3>
                </div>
              </a>
            )}

          </div>

        </div>
      ) : (
        <p class="text-sm text-text-muted text-center py-12">
          Nenhum artigo publicado ainda.
        </p>
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- NAVEGAÇÃO POR INTENÇÃO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section label -->
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">O que você quer resolver hoje?</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- 1. Tráfego -->
        <a href={`${prefix}/marketing-digital`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-cyan-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">📈</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quero gerar mais tráfego</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Estratégias para atrair mais visitantes, cliques e oportunidades.</p>
          </div>
        </a>

        <!-- 2. IA -->
        <a href={`${prefix}/inteligencia-artificial`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-cyan-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">🤖</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quero usar IA no trabalho</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Prompts, ferramentas e fluxos práticos para ganhar produtividade.</p>
          </div>
        </a>

        <!-- 3. Monetizar -->
        <a href={`${prefix}/monetizacao`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-cyan-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">💰</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quero monetizar conteúdo</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Ideias para transformar audiência, blogs e projetos digitais em receita.</p>
          </div>
        </a>

        <!-- 4. Guias -->
        <a href={`${prefix}/guias`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-purple-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">📋</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-purple-500 transition-colors">Quero organizar operações digitais</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Guias e checklists para trabalhar melhor com contas, acessos e processos.</p>
          </div>
        </a>

        <!-- 5. Ferramentas -->
        <a href={`${prefix}/parceiros`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-cyan-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">🧰</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quero encontrar ferramentas</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Categorias de ferramentas úteis para marketing, tráfego e monetização.</p>
          </div>
        </a>

        <!-- 6. Bônus -->
        <a href={`${prefix}/bonus`} class="group flex items-start gap-4 rounded-xl border p-4 transition-colors hover:border-cyan-500/30" style="border-color: var(--color-border); background: var(--color-surface-card);">
          <span class="text-2xl shrink-0 mt-0.5">🎁</span>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold text-text-primary group-hover:text-cyan-500 transition-colors">Quero ver bônus e códigos</h3>
            <p class="text-xs text-text-muted mt-1 leading-relaxed">Condições promocionais e benefícios verificados.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- ÚLTIMAS PUBLICAÇÕES -->
  <!-- ════════════════════════════════════════════════ -->
  <section id="artigos" class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Section label -->
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Últimas publicações</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      {artigosPublicados.length === 0 ? (
        <p class="text-sm text-text-muted text-center py-12 transition-colors">
          Nenhum artigo publicado ainda. Volte em breve.
        </p>
      ) : (
        <div class="grid lg:grid-cols-3 gap-10">

          <!-- COLUNA PRINCIPAL: Lista editorial -->
          <div class="lg:col-span-2">
            <div class="flex flex-col">
              {artigosPublicados
                .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
                .map((artigo, idx) => {
                  const dateStr = artigo.data.date.toLocaleDateString('pt-BR', {
                    day: '2-digit', month: 'short', year: 'numeric'
                  });
                  return (
                    <div>
                      <a
                        href={`${prefix}/artigos/${artigo.slug}`}
                        class="group block py-5 first:pt-0"
                      >
                        <div class="flex items-center gap-2 text-xs text-text-muted mb-1.5">
                          <span class="font-semibold uppercase tracking-wider">{artigo.data.subtema}</span>
                          <span>·</span>
                          <span>{artigo.data.readTime}</span>
                        </div>
                        <h3 class="text-base sm:text-lg font-bold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug">
                          {artigo.data.title}
                        </h3>
                        <p class="text-sm text-text-secondary mt-1.5 leading-relaxed line-clamp-2 transition-colors">
                          {artigo.data.excerpt}
                        </p>
                        <time class="text-xs text-text-muted mt-2 block transition-colors">{dateStr}</time>
                      </a>
                      {idx < artigosPublicados.length - 1 && (
                        <div class="h-px" style="background: var(--color-border);"></div>
                      )}
                    </div>
                  );
                })}

              <!-- AdSlot in-feed após a lista -->
              <div class="mt-8">
                <AdSlot variant="in-feed" />
              </div>
            </div>
          </div>

          <!-- COLUNA LATERAL: Recomendados -->
          <div class="lg:col-span-1">
            <div class="glass-card p-5">
              <h3 class="text-xs font-semibold uppercase tracking-[0.1em] text-text-muted mb-4">
                Recomendados pela redação
              </h3>
              <div class="flex flex-col gap-3">
                {artigosPublicados
                  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
                  .slice(0, 3)
                  .map((artigo) => {
                    const dateStr = artigo.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
                    const colorAccent = artigo.data.color === 'purple' ? 'text-purple-500' :
                      artigo.data.color === 'amber' ? 'text-amber-500' : 'text-cyan-500';
                    return (
                      <a
                        href={`${prefix}/artigos/${artigo.slug}`}
                        class="group flex items-start gap-3"
                      >
                        <span class={`text-lg shrink-0 mt-0.5 ${colorAccent}`}>·</span>
                        <div class="min-w-0 flex-1">
                          <h4 class="text-sm font-semibold text-text-primary group-hover:text-cyan-500 transition-colors leading-snug line-clamp-2">
                            {artigo.data.title}
                          </h4>
                          <div class="flex items-center gap-1.5 text-[10px] text-text-muted mt-1">
                            <span class="font-medium uppercase tracking-wider">{artigo.data.subtema}</span>
                            <span>·</span>
                            <time>{dateStr}</time>
                          </div>
                        </div>
                      </a>
                    );
                  })}
              </div>
            </div>
          </div>

        </div>
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- GUIAS PRÁTICOS -->
  <!-- ════════════════════════════════════════════════ -->
  {guiaRecente ? (
    <section class="py-14 bg-surface transition-colors duration-300">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Guias práticos</h2>
          <div class="h-px flex-1" style="background: var(--color-border);"></div>
        </div>

        <p class="text-sm text-text-secondary mb-6 max-w-xl">
          Checklists e passo a passo para aplicar no dia a dia.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Card do guia mais recente -->
          <a
            href={`${prefix}/artigos/${guiaRecente.slug}`}
            class="glass-card p-5 group flex items-start gap-4"
            style="border-color: rgba(168, 85, 247, 0.2);"
          >
            <span class="text-2xl shrink-0 mt-0.5">{guiaRecente.data.emoji || '📋'}</span>
            <div class="min-w-0 flex-1">
              {guiaRecente.data.guideType && (
                <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-purple-500 mb-1">{guiaRecente.data.guideType}</span>
              )}
              <h3 class="text-sm font-bold text-text-primary group-hover:text-purple-500 transition-colors leading-snug line-clamp-2">
                {guiaRecente.data.title}
              </h3>
              <p class="text-xs text-text-muted mt-1 line-clamp-2">{guiaRecente.data.excerpt}</p>
              <span class="text-xs text-purple-500 font-medium mt-2 inline-block group-hover:underline">
                {locale === 'pt-BR' ? 'Ler guia' : 'Leer guía'}
              </span>
            </div>
          </a>
        </div>

        <a href={`${prefix}/guias`} class="inline-flex items-center gap-1 text-xs font-medium text-purple-500 hover:underline mt-4 transition-colors">
          {locale === 'pt-BR' ? 'Ver todos os guias' : 'Ver todas las guías'}
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </section>
  ) : (
    <section class="py-14 bg-surface transition-colors duration-300">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Guias práticos</h2>
          <div class="h-px flex-1" style="background: var(--color-border);"></div>
        </div>

        <a href={`${prefix}/guias`} class="glass-card p-5 flex items-center gap-4 group hover:border-purple-500/20 transition-colors">
          <span class="text-2xl shrink-0">📋</span>
          <div class="min-w-0 flex-1">
            <p class="text-sm text-text-secondary leading-relaxed">
              {locale === 'pt-BR' ? 'Checklists e passo a passo para aplicar no dia a dia.' : 'Checklists y paso a paso para aplicar en el día a día.'}
            </p>
            <span class="text-xs font-medium text-purple-500 mt-1 inline-flex items-center gap-1 group-hover:underline">
              {locale === 'pt-BR' ? 'Ver todos os guias' : 'Ver todas las guías'}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════════════ -->
  <!-- FERRAMENTAS NA PRÁTICA -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-4">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Ferramentas na prática</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        Categorias úteis para operações digitais, conteúdo, tráfego e monetização.
      </p>

      {parceiroCategorias.length > 0 ? (
        <div class="flex flex-wrap gap-2 mb-4">
          {parceiroCategorias.map((cat) => (
            <a
              href={`${prefix}/parceiros/${cat.slug}`}
              class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-xs font-medium border transition-colors hover:border-cyan-500/30 hover:text-cyan-500"
              style="border-color: var(--color-border); color: var(--color-text-secondary); background: var(--color-surface-elevated);"
            >
              {cat.data.title}
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">Diretório em construção.</p>
      )}

      <a href={`${prefix}/parceiros`} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        Ver ferramentas
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- BÔNUS E CÓDIGOS PROMOCIONAIS -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-4">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Bônus e códigos promocionais</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        Condições úteis para ferramentas do mercado digital, com status claro.
      </p>

      {bonusDestaques.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
          {bonusDestaques.map((bonus) => (
            <a
              href={`${prefix}/bonus#${bonus.data.category}`}
              class="rounded-xl border p-4 group transition-colors hover:border-cyan-500/30"
              style="border-color: var(--color-border); background: var(--color-surface-card);"
            >
              <div class="text-xs font-semibold text-text-primary group-hover:text-cyan-500 transition-colors mb-1">{bonus.data.productName}</div>
              <div class="text-[10px] font-mono text-amber-500 font-semibold tracking-wide">{bonus.data.promoCode}</div>
              <div class="text-[9px] uppercase tracking-wider text-green-500 mt-1 font-medium">✓ verificado</div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">Nenhum bônus verificado no momento.</p>
      )}

      <a href={`${prefix}/bonus`} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        Ver bônus
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- RADAR MARKET -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">Radar Market</h2>
        <div class="h-px flex-1" style="background: var(--color-border);"></div>
      </div>

      <p class="text-sm text-text-secondary mb-5 max-w-xl">
        Produtos, cursos e soluções para quem trabalha com marketing, IA e monetização.
      </p>

      {marketCategorias.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          {marketCategorias.map((cat) => (
            <div class="rounded-xl border p-4 transition-colors" style="border-color: var(--color-border); background: var(--color-surface-card);">
              {cat.data.emoji && <span class="text-lg block mb-2">{cat.data.emoji}</span>}
              <h3 class="text-xs font-bold text-text-primary mb-0.5">{cat.data.title}</h3>
              <p class="text-[10px] text-text-muted leading-relaxed line-clamp-2">{cat.data.description}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-text-muted mb-4">Categorias em construção.</p>
      )}

      <a href={`${prefix}/market`} class="inline-flex items-center gap-1 text-xs font-medium text-cyan-500 hover:underline transition-colors">
        Explorar Radar Market
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- NEWSLETTER -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-14 relative bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="glass-card p-10 md:p-14 text-center max-w-3xl mx-auto relative overflow-hidden">
        <!-- Decorative dots -->
        <div class="absolute -top-20 -right-20 w-40 h-40 opacity-[0.04] dark:opacity-[0.04] opacity-[0.08]">
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="10" r="2" fill="#00e5ff"/><circle cx="30" cy="10" r="2" fill="#00e5ff"/>
            <circle cx="50" cy="10" r="2" fill="#00e5ff"/><circle cx="70" cy="10" r="2" fill="#00e5ff"/>
            <circle cx="90" cy="10" r="2" fill="#00e5ff"/><circle cx="10" cy="30" r="2" fill="#00e5ff"/>
            <circle cx="30" cy="30" r="2" fill="#00e5ff"/><circle cx="50" cy="30" r="2" fill="#00e5ff"/>
            <circle cx="70" cy="30" r="2" fill="#00e5ff"/><circle cx="90" cy="30" r="2" fill="#00e5ff"/>
          </svg>
        </div>

        <div class="relative z-10">
          <span class="tag-pill">{locale === 'pt-BR' ? 'Fique ligado' : 'Mantente al tanto'}</span>
          <h2 class="section-title mt-4 text-text-primary transition-colors">{locale === 'pt-BR' ? 'Receba o' : 'Recibe la'} <span class="text-cyan-500">{locale === 'pt-BR' ? 'sinal' : 'señal'}</span></h2>
          <p class="text-text-secondary mt-3 max-w-lg mx-auto text-sm leading-relaxed transition-colors">
            {locale === 'pt-BR' 
              ? 'Assine e seja o primeiro a saber quando novos artigos chegarem no Radar Digital. Sem spam, só conteúdo de verdade.' 
              : 'Suscríbete y sé el primero en saber cuando lleguen nuevos artículos al Radar Digital. Sin spam, solo contenido real.'}
          </p>

          <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Newsletter em breve! 🚀')">
            <input 
              type="email" 
              placeholder={locale === 'pt-BR' ? 'seu@email.com' : 'tu@email.com'} 
              class="flex-1 px-5 py-3 rounded-xl text-sm transition-all duration-300"
              style="background: var(--color-surface-elevated); color: var(--color-text-primary); border: 1px solid var(--color-border);"
              required
            />
            <button 
              type="submit" 
              class="px-6 py-3 rounded-xl bg-gradient-to-r from-cyan-500/20 to-cyan-600/20 
                     border border-cyan-500/30 text-cyan-500 text-sm font-semibold
                     hover:from-cyan-500/30 hover:to-cyan-600/30 hover:border-cyan-500/50
                     transition-all duration-300">
              {locale === 'pt-BR' ? 'Assinar' : 'Suscribirse'}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- CTA FINAL -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="pb-14 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-xs text-text-muted uppercase tracking-[0.15em] mb-3 transition-colors">Radar Digital © 2026</p>
      <p class="text-text-secondary text-sm max-w-md mx-auto transition-colors">
        {locale === 'pt-BR'
          ? <>Captando sinais, entregando valor.</>
          : <>Captando señales, entregando valor.</>}
      </p>
    </div>
  </section>
</Layout>
