---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const todasCategorias = await getCollection('parceiroCategorias');
const categoriasPublicadas = todasCategorias
  .filter((c) => c.data.draft === false)
  .sort((a, b) => a.data.order - b.data.order);

const todosParceiros = await getCollection('parceiros', ({ data }) => data.draft === false);

const parceirosPorCategoria: Record<string, number> = {};
for (const p of todosParceiros) {
  parceirosPorCategoria[p.data.category] = (parceirosPorCategoria[p.data.category] || 0) + 1;
}

const slugEmoji: Record<string, string> = {
  'trackers': '📊',
  'antidetect-browsers': '🎭',
  'spy-services': '🔍',
  'criacao-de-criativos': '🎨',
  'gateways-de-pagamento': '💳',
  'proxies': '🌐',
  'sms-verificacao': '📱',
  'cursos-e-comunidades': '🎓',
};
---

<Layout 
  title="Parceiros e Ferramentas" 
  description="Ferramentas, serviços e plataformas recomendados por categoria. Curadoria pra quem opera marketing digital, mídia paga e negócio online."
>
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative pt-32 pb-20 overflow-hidden bg-surface transition-colors duration-300">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-20 blur-3xl pointer-events-none" 
         style="background: radial-gradient(circle, rgba(0, 229, 255, 0.25) 0%, transparent 60%);"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] rounded-full opacity-10 blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 60%);"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 transition-colors">
        <a href="/" class="hover:text-cyan-500 transition-colors">Início</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
        </svg>
        <span class="text-cyan-500">Parceiros</span>
      </nav>

      <div class="flex items-center gap-3 mb-6">
        <div class="w-14 h-14 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center">
          <span class="text-2xl">🤝</span>
        </div>
        <span class="tag-pill">Diretório curado</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.05] tracking-tight mb-6">
        <span class="text-text-primary transition-colors">Parceiros &</span>
        <span class="gradient-text"> Ferramentas</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed transition-colors">
        Curadoria de ferramentas, serviços e plataformas que recomendamos por nicho. Cada parceiro listado aqui passou por critério: utilidade real, mercado ativo, reputação consistente.
      </p>

      <!-- Stats -->
      <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t transition-colors" style="border-color: var(--color-border);">
        <div>
          <div class="text-2xl font-bold text-text-primary transition-colors">{categoriasPublicadas.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">Categorias</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-cyan-500">{todosParceiros.length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">Parceiros listados</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-text-primary transition-colors">{todosParceiros.filter(p => p.data.featured).length}</div>
          <div class="text-xs text-text-muted mt-0.5 transition-colors">Em destaque</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════ -->
  <!-- GRID DE CATEGORIAS -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="py-20 bg-surface transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <span class="tag-pill">Categorias</span>
        <h2 class="section-title mt-4 text-text-primary transition-colors">Escolha o <span class="text-cyan-500">nicho</span></h2>
        <p class="section-subtitle">Cada categoria traz uma explicação do segmento e os parceiros que recomendamos.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoriasPublicadas.map((cat) => {
          const qtd = parceirosPorCategoria[cat.slug] || 0;
          const temParceiros = qtd > 0;
          return (
            <a
              href={temParceiros ? `/parceiros/${cat.slug}` : '#'}
              class={`glass-card overflow-hidden group block ${!temParceiros ? 'opacity-60 cursor-not-allowed' : ''}`}
            >
              <div class="p-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-xl">
                    {slugEmoji[cat.data.slug] || '🔹'}
                  </div>
                  {!temParceiros ? (
                    <span class="inline-block px-2 py-0.5 rounded-md text-[9px] font-semibold uppercase tracking-wider bg-text-muted/10 text-text-muted border border-text-muted/20">
                      Em breve
                    </span>
                  ) : (
                    <span class="inline-block px-2 py-0.5 rounded-md text-[9px] font-semibold uppercase tracking-wider bg-cyan-500/10 text-cyan-500 border border-cyan-500/20">
                      {qtd} {qtd === 1 ? 'parceiro' : 'parceiros'}
                    </span>
                  )}
                </div>

                <h3 class="font-bold text-lg text-text-primary group-hover:text-cyan-500 transition-colors leading-snug mb-2">
                  {cat.data.title}
                </h3>
                <p class="text-xs text-text-muted leading-relaxed line-clamp-3 transition-colors">
                  {cat.data.description}
                </p>

                <div class="mt-5 pt-4 border-t transition-colors flex items-center justify-between" style="border-color: var(--color-border);">
                  <span class="text-[10px] text-text-muted uppercase tracking-wider transition-colors">
                    Categoria {String(cat.data.order).padStart(2, '0')}
                  </span>
                  {temParceiros ? (
                    <span class="text-cyan-500 text-xs font-medium flex items-center gap-1 group-hover:gap-2 transition-all">
                      Ver parceiros
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="text-text-muted text-xs flex items-center gap-1">
                      Em breve
                    </span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- CTA voltar -->
      <div class="mt-16 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-cyan-500 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar para a home
        </a>
      </div>
    </div>
  </section>
</Layout>
