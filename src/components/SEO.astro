---
/**
 * Componente <SEO />
 *
 * Gera Schema.org JSON-LD pra Google Rich Results.
 * Tipos: Article (posts), BreadcrumbList (toda pagina), WebSite (home).
 *
 * Uso:
 *   <SEO type="breadcrumb" items={[{name: 'Início', href: '/'}, ...]} />
 *   <SEO type="article" {...articleProps} />
 *   <SEO type="website" />
 */

import { locales, defaultLocale } from '../i18n/config';

export interface Props {
  type: 'article' | 'breadcrumb' | 'website';
  // breadcrumb
  items?: { name: string; href: string }[];
  // article
  title?: string;
  description?: string;
  datePublished?: Date;
  dateModified?: Date;
  authorName?: string;
  imageUrl?: string;
  url?: string;
}

const { type, items, title, description, datePublished, dateModified, authorName = 'Radar Digital', url } = Astro.props;

const SITE_URL = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://radardigital.ai';

// Mapeia o pathname pra inferir o locale usando config central
function inferLanguageFromPath(href: string): string {
  const [, lang] = href.split('/');
  for (const [key, cfg] of Object.entries(locales)) {
    if (cfg.prefix && cfg.prefix === lang) {
      return key;
    }
  }
  return defaultLocale;
}

let jsonLd: Record<string, any> | null = null;

if (type === 'breadcrumb' && items && items.length > 0) {
  jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: {
        '@id': `${SITE_URL}${item.href}`,
        '@language': inferLanguageFromPath(item.href),
      },
    })),
  };
} else if (type === 'article' && title) {
  jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description || '',
    datePublished: datePublished?.toISOString(),
    dateModified: (dateModified || datePublished)?.toISOString(),
    author: {
      '@type': 'Person',
      name: authorName,
    },
    publisher: {
      '@type': 'Organization',
      name: 'Radar Digital',
      logo: {
        '@type': 'ImageObject',
        url: `${SITE_URL}/favicon.svg`,
      },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': url ? `${SITE_URL}${url}` : SITE_URL,
    },
  };
}
---

{
  jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  )
}
