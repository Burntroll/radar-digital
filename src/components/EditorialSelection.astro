---
import type { HomeArticle } from '../utils/homeData';
import { t, type Locale } from '../i18n/utils';
import StoryCard from './StoryCard.astro';

interface Props {
  articles: HomeArticle[];
  locale: Locale;
}

const { articles, locale } = Astro.props as Props;
const visibleArticles = articles.slice(0, 3);
---

{visibleArticles.length > 0 && (
  <section
    class="editorial-selection"
    aria-labelledby="editorial-selection-title"
    aria-describedby="editorial-selection-rule"
    data-editorial-selection
    data-count={visibleArticles.length}
    data-selection-rule="remaining-recency"
  >
    <div class="editorial-selection__inner">
      <header class="editorial-selection__header">
        <div>
          <span class="editorial-selection__eyebrow">{t('home.selection.eyebrow', locale)}</span>
          <h2 id="editorial-selection-title">{t('home.selection.title', locale)}</h2>
        </div>
        <p id="editorial-selection-rule">{t('home.selection.rule', locale)}</p>
      </header>

      <div
        class:list={[
          'editorial-selection__grid',
          `editorial-selection__grid--${visibleArticles.length}`,
        ]}
      >
        {visibleArticles.map((article, index) => (
          <StoryCard article={article} locale={locale} featured={index === 0} />
        ))}
      </div>
    </div>
  </section>
)}
