---
import { routePath, t, type Locale } from '../i18n/utils';
import type { HomeGuideItem } from '../utils/homeData';

interface Props {
  items: HomeGuideItem[];
  locale: Locale;
}

const { items, locale } = Astro.props;
const allGuidesHref = routePath('guias', locale);
const featureGuide = items[0] ?? null;
const listGuides = items.slice(1);
---

<section
  id="guias"
  class="guide-highlights"
  aria-labelledby="guide-highlights-title"
  data-guide-highlights
  data-count={items.length}
>
  <div class="guide-highlights__inner">
    <header class="guide-highlights__header">
      <div>
        <span class="guide-highlights__eyebrow">{t('home.guides.eyebrow', locale)}</span>
        <h2 id="guide-highlights-title">{t('home.section.guias', locale)}</h2>
      </div>
      <p class="guide-highlights__desc">{t('home.guides.desc', locale)}</p>
    </header>

    {featureGuide ? (
      <div class="guide-highlights__layout">
        <a class="guide-feature" href={featureGuide.href}>
          <div class="guide-feature__content">
            <span class="guide-feature__kicker">{t('home.article.guide.badge', locale)}</span>
            <h3 class="guide-feature__title">{featureGuide.title}</h3>
            <div class="guide-feature__meta">
              {featureGuide.guideType && <span>{featureGuide.guideType}</span>}
            </div>
          </div>
        </a>

        {listGuides.length > 0 && (
          <div class="guide-list">
            {listGuides.map((item, index) => (
              <a class="guide-item" href={item.href} data-guide-id={item.id}>
                <span class="guide-item__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                <span class="guide-item__copy">
                  <h4>{item.title}</h4>
                  {item.guideType && <small>{item.guideType}</small>}
                </span>
                <span class="guide-item__arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="guide-highlights__empty">
        <p>{t('home.guides.empty', locale)}</p>
      </div>
    )}

    <a class="guide-highlights__all" href={allGuidesHref}>
      {t('home.guides.all', locale)}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
