---
// ═══════════════════════════════════════════════════════════════════════════
// MobileNavigation — navegação mobile dedicada (< 1024px)
//
// Renderiza hamburger + painel vertical com accordions derivados de
// mainNavigation. Exibido apenas abaixo de 1024px.
// ═══════════════════════════════════════════════════════════════════════════

import { t, routePath, defaultLocale, type Locale, type RouteKey, type UIKey } from '../i18n/utils';
import { enabledLocales, locales } from '../i18n/config';
import { mainNavigation, type NavLinkItem, type NavGroupItem } from '../config/siteNavigation';

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: { lang: string; href: string }[];
}

const { locale, currentPath, alternates } = Astro.props as Props;
const prefix = locale === defaultLocale ? '' : `/${locale}`;

// ─── Helpers ───────────────────────────────────────────────────────

function isActiveRoute(item: NavLinkItem): boolean {
  if (!item.routeKey) {
    const homePath = prefix || '/';
    return currentPath === homePath || currentPath === homePath + '/';
  }
  const route = routePath(item.routeKey as RouteKey, locale);
  return currentPath === route || currentPath === route + '/';
}

function groupHasActive(children: (NavLinkItem | NavGroupItem)[]): boolean {
  for (const child of children) {
    if (child.type === 'link' && isActiveRoute(child)) return true;
    if (child.type === 'group' && groupHasActive(child.children)) return true;
  }
  return false;
}

function linkHref(item: NavLinkItem): string {
  if (!item.routeKey) return prefix || '/';
  return routePath(item.routeKey as RouteKey, locale);
}
---

<!-- Hamburger Button -->
<button
  type="button"
  id="mobile-menu-toggle"
  class="lg:hidden relative w-10 h-10 flex items-center justify-center rounded-xl cursor-pointer transition-colors hover:bg-cyan-500/10"
  aria-controls="mobile-menu-panel"
  aria-expanded="false"
  aria-label={t('nav.menu.open' as UIKey, locale)}
  data-label-open={t('nav.menu.open' as UIKey, locale)}
  data-label-close={t('nav.menu.close' as UIKey, locale)}
  style="min-width:44px;min-height:44px;"
>
  <!-- Hamburger icon (visible when closed) -->
  <svg class="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <line x1="4" y1="6" x2="20" y2="6" />
    <line x1="4" y1="12" x2="20" y2="12" />
    <line x1="4" y1="18" x2="20" y2="18" />
  </svg>
  <!-- X icon (visible when open) -->
  <svg class="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none;">
    <line x1="18" y1="6" x2="6" y2="18" />
    <line x1="6" y1="6" x2="18" y2="18" />
  </svg>
</button>

<!-- Mobile Panel -->
<div
  id="mobile-menu-panel"
  class="lg:hidden"
  hidden
  aria-hidden="true"
  style="position:fixed;top:4rem;bottom:0;left:0;right:0;z-index:40;background:var(--color-surface,#0a0b0f);border-top:1px solid var(--color-border,#1e293b);overflow-y:auto;overflow-x:hidden;"
>
  <nav aria-label={t('nav.menu.label' as UIKey, locale)} class="p-4 flex flex-col gap-1">
    {
      mainNavigation
        .filter((section) => section.eligible)
        .map((section) => {
          const item = section.item;

          // ── Links diretos ──
          if (item.type === 'link') {
            const active = isActiveRoute(item);
            const href = linkHref(item);
            return (
              <a
                href={href}
                class={`flex items-center gap-2 px-4 py-3 rounded-xl text-sm font-medium transition-colors min-h-[44px]
                  ${active
                    ? 'text-cyan-500 bg-cyan-500/10 font-semibold'
                    : 'text-text-secondary hover:text-cyan-500 hover:bg-cyan-500/6'
                  }`}
                aria-current={active ? 'page' : undefined}
              >
                {item.icon === 'tools' && (
                  <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-7.42 7.42-1.41-1.41 7.42-7.42m0 0a5.5 5.5 0 117.07-7.07l-2.12 2.12a1.5 1.5 0 000 2.12l2.12 2.12a5.5 5.5 0 01-7.07 7.07z" />
                  </svg>
                )}
                {item.icon === 'bonus' && (
                  <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V3m0 0l-3 3m3-3l3 3m-9 7h6a2 2 0 012 2v1a2 2 0 01-2 2H9a2 2 0 01-2-2v-1a2 2 0 012-2z" />
                  </svg>
                )}
                <span>{t(item.labelKey as UIKey, locale)}</span>
              </a>
            );
          }

          // ── Grupos (accordions) ──
          const group = item as NavGroupItem;
          const hasActive = groupHasActive(group.children);
          const useSubGroups = group.presentation === 'grouped' && group.groups != null && group.groups.length > 0;

          return (
            <details class="mobile-accordion" open={hasActive || undefined}>
              <summary
                class={`flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium transition-colors cursor-pointer list-none min-h-[44px]
                  ${hasActive
                    ? 'text-cyan-500 font-semibold'
                    : 'text-text-secondary hover:text-cyan-500 hover:bg-cyan-500/6'
                  }`}
              >
                <span>{t(group.labelKey as UIKey, locale)}</span>
                <svg class="accordion-chevron w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="ml-2 mt-1 mb-2 flex flex-col gap-0.5">
                {useSubGroups ? (
                  group.groups!.filter(g => g.children.length > 0).map((sub) => (
                    <div class="mb-2">
                      <span class="block px-4 py-1 text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-text-muted">
                        {t(sub.labelKey as UIKey, locale)}
                      </span>
                      {sub.children.map((link) => {
                        const linkActive = isActiveRoute(link);
                        return (
                          <a
                            href={linkHref(link)}
                            class={`flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm transition-colors min-h-[44px]
                              ${linkActive
                                ? 'text-cyan-500 bg-cyan-500/10 font-semibold'
                                : 'text-text-secondary hover:text-cyan-500 hover:bg-cyan-500/6'
                              }`}
                            aria-current={linkActive ? 'page' : undefined}
                          >
                            {t(link.labelKey as UIKey, locale)}
                          </a>
                        );
                      })}
                    </div>
                  ))
                ) : (
                  group.children.filter(c => c.type === 'link').map((child) => {
                    const link = child as NavLinkItem;
                    const linkActive = isActiveRoute(link);
                    return (
                      <a
                        href={linkHref(link)}
                        class={`flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm transition-colors min-h-[44px]
                          ${linkActive
                            ? 'text-cyan-500 bg-cyan-500/10 font-semibold'
                            : 'text-text-secondary hover:text-cyan-500 hover:bg-cyan-500/6'
                          }`}
                        aria-current={linkActive ? 'page' : undefined}
                      >
                        {t(link.labelKey as UIKey, locale)}
                      </a>
                    );
                  })
                )}
              </div>
            </details>
          );
        })
    }

    <!-- Divider -->
    <hr class="my-3 border-t" style="border-color:var(--color-border,#1e293b);" />

    <!-- Locale Section -->
    <span class="block px-4 py-1 text-xs font-semibold uppercase tracking-wider text-text-muted">
      {t('nav.menu.language' as UIKey, locale)}
    </span>
    <div class="flex gap-2 px-4 py-2">
      {alternates
        .filter((alt: { lang: string; href: string }) => enabledLocales.includes(alt.lang as Locale))
        .map((alt: { lang: string; href: string }) => {
          const isCurrent = alt.lang === locale;
          const label = locales[alt.lang as keyof typeof locales]?.label || alt.lang;
          return (
            <a
              href={alt.href}
              class={`flex-1 flex items-center justify-center gap-1.5 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors min-h-[44px]
                ${isCurrent
                  ? 'text-cyan-500 bg-cyan-500/10 font-semibold'
                  : 'text-text-secondary hover:text-cyan-500 hover:bg-cyan-500/6'
                }`}
              aria-current={isCurrent ? 'page' : undefined}
            >
              <span>{label}</span>
            </a>
          );
        })
      }
    </div>

    <!-- Theme Toggle -->
    <div class="px-4 pt-1 pb-2">
      <button
        id="theme-toggle-mobile"
        class="theme-toggle w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-medium transition-colors min-h-[44px]"
        aria-label={t('theme.toggle' as UIKey, locale)}
        style="background:rgba(0,229,255,0.06);border:1px solid var(--color-border,#1e293b);"
      >
        <svg class="sun-icon w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="moon-icon w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <span>{t('theme.toggle' as UIKey, locale)}</span>
      </button>
    </div>
  </nav>
</div>

<style>
  /* Chevron rotation for mobile accordions */
  .mobile-accordion[open] .accordion-chevron {
    transform: rotate(180deg);
  }

  /* Hide default details marker */
  .mobile-accordion summary::-webkit-details-marker {
    display: none;
  }

  /* Toggle icon visibility */
  #mobile-menu-toggle[aria-expanded="true"] .menu-icon {
    display: none;
  }
  #mobile-menu-toggle[aria-expanded="true"] .close-icon {
    display: block !important;
  }
  #mobile-menu-toggle[aria-expanded="false"] .menu-icon {
    display: block;
  }
  #mobile-menu-toggle[aria-expanded="false"] .close-icon {
    display: none !important;
  }

  /* Theme toggle icon sync */
  #theme-toggle-mobile .sun-icon { display: none; }
  #theme-toggle-mobile .moon-icon { display: block; }
  :root:not(.dark) #theme-toggle-mobile .sun-icon { display: block; }
  :root:not(.dark) #theme-toggle-mobile .moon-icon { display: none; }
  .dark #theme-toggle-mobile .sun-icon { display: block; }
  .dark #theme-toggle-mobile .moon-icon { display: none; }
</style>

<script>
  (function() {
    var btn = document.getElementById('mobile-menu-toggle');
    var panel = document.getElementById('mobile-menu-panel');
    if (!btn || !panel) return;

    var openLabel = btn.getAttribute('data-label-open') || 'Abrir menu';
    var closeLabel = btn.getAttribute('data-label-close') || 'Fechar menu';
    var previousOverflow = '';

    function openMenu() {
      if (!panel || !btn) return;
      panel.removeAttribute('hidden');
      panel.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', closeLabel);

      previousOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';

      var main = document.querySelector('main');
      var footer = document.querySelector('footer');
      if (main) main.inert = true;
      if (footer) footer.inert = true;
    }

    function closeMenu() {
      if (!panel || !btn) return;
      panel.setAttribute('hidden', '');
      panel.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', openLabel);

      document.body.style.overflow = previousOverflow;

      var main = document.querySelector('main');
      var footer = document.querySelector('footer');
      if (main) main.inert = false;
      if (footer) footer.inert = false;
    }

    btn.addEventListener('click', function() {
      var b = /** @type {HTMLElement|null} */ (btn);
      if (!b) return;
      var expanded = b.getAttribute('aria-expanded');
      if (expanded === 'true') {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Fechar ao clicar em qualquer link dentro do painel
    var links = panel.querySelectorAll('a');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', function() {
        setTimeout(closeMenu, 10);
      });
    }

    var mq = window.matchMedia('(min-width: 1024px)');
    function handleResize() {
      if (mq.matches) {
        if (panel && panel.hasAttribute('hidden') === false) {
          closeMenu();
        }
      }
    }
    mq.addEventListener('change', handleResize);
  })();
</script>
