---
// ═══════════════════════════════════════════════════════════════════════════
// MobileNavigation — navegação mobile dedicada (< 1024px)
//
// Renderiza hamburger + painel vertical com accordions derivados de
// mainNavigation. Exibido apenas abaixo de 1024px.
// ═══════════════════════════════════════════════════════════════════════════

import { t, routePath, defaultLocale, type Locale, type RouteKey, type UIKey } from '../i18n/utils';
import { enabledLocales, locales } from '../i18n/config';
import { mainNavigation, type NavLinkItem, type NavGroupItem } from '../config/siteNavigation';

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: { lang: string; href: string }[];
}

const { locale, currentPath, alternates } = Astro.props as Props;
const prefix = locale === defaultLocale ? '' : `/${locale}`;

// ─── Helpers ───────────────────────────────────────────────────────

function isActiveRoute(item: NavLinkItem): boolean {
  if (!item.routeKey) {
    const homePath = prefix || '/';
    return currentPath === homePath || currentPath === homePath + '/';
  }
  const route = routePath(item.routeKey as RouteKey, locale);
  return currentPath === route || currentPath === route + '/';
}

function groupHasActive(children: (NavLinkItem | NavGroupItem)[]): boolean {
  for (const child of children) {
    if (child.type === 'link' && isActiveRoute(child)) return true;
    if (child.type === 'group' && groupHasActive(child.children)) return true;
  }
  return false;
}

function linkHref(item: NavLinkItem): string {
  if (!item.routeKey) return prefix || '/';
  return routePath(item.routeKey as RouteKey, locale);
}
---

<!-- Hamburger Button -->
<button
  type="button"
  id="mobile-menu-toggle"
  class="mobile-menu__toggle lg:hidden"
  aria-controls="mobile-menu-panel"
  aria-expanded="false"
  aria-label={t('nav.menu.open' as UIKey, locale)}
  data-label-open={t('nav.menu.open' as UIKey, locale)}
  data-label-close={t('nav.menu.close' as UIKey, locale)}
>
  <!-- Hamburger icon (visible when closed) -->
  <svg class="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <line x1="4" y1="6" x2="20" y2="6" />
    <line x1="4" y1="12" x2="20" y2="12" />
    <line x1="4" y1="18" x2="20" y2="18" />
  </svg>
  <!-- X icon (visible when open) -->
  <svg class="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <line x1="18" y1="6" x2="6" y2="18" />
    <line x1="6" y1="6" x2="18" y2="18" />
  </svg>
</button>

<!-- Mobile Panel -->
<div
  id="mobile-menu-panel"
  class="mobile-menu__panel lg:hidden"
  hidden
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={t('nav.menu.label' as UIKey, locale)}
  tabindex="-1"
>
  <div class="mobile-menu__surface">
    <div class="mobile-menu__navigation">
    {
      mainNavigation
        .filter((section) => section.eligible)
        .map((section) => {
          const item = section.item;

          // ── Links diretos ──
          if (item.type === 'link') {
            const active = isActiveRoute(item);
            const href = linkHref(item);
            return (
              <a
                href={href}
                class={`mobile-menu__item${active ? ' is-active' : ''}`}
                aria-current={active ? 'page' : undefined}
              >

                <span>{t(item.labelKey as UIKey, locale)}</span>
              </a>
            );
          }

          // ── Grupos (accordions) ──
          const group = item as NavGroupItem;
          const hasActive = groupHasActive(group.children);
          const useSubGroups = group.presentation === 'grouped' && group.groups != null && group.groups.length > 0;

          return (
            <details class={`mobile-accordion${hasActive ? ' is-active' : ''}`} open={hasActive || undefined}>
              <summary class="mobile-menu__summary">
                <span>{t(group.labelKey as UIKey, locale)}</span>
                <svg class="accordion-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="mobile-menu__children">
                {useSubGroups ? (
                  group.groups!.filter(g => g.children.length > 0).map((sub) => (
                    <div class="mobile-menu__subgroup">
                      <span class="mobile-menu__eyebrow">
                        {t(sub.labelKey as UIKey, locale)}
                      </span>
                      {sub.children.map((link) => {
                        const linkActive = isActiveRoute(link);
                        return (
                          <a
                            href={linkHref(link)}
                            class={`mobile-menu__subitem${linkActive ? ' is-active' : ''}`}
                            aria-current={linkActive ? 'page' : undefined}
                          >
                            {t(link.labelKey as UIKey, locale)}
                          </a>
                        );
                      })}
                    </div>
                  ))
                ) : (
                  group.children.filter(c => c.type === 'link').map((child) => {
                    const link = child as NavLinkItem;
                    const linkActive = isActiveRoute(link);
                    return (
                      <a
                        href={linkHref(link)}
                        class={`mobile-menu__subitem${linkActive ? ' is-active' : ''}`}
                        aria-current={linkActive ? 'page' : undefined}
                      >
                        {t(link.labelKey as UIKey, locale)}
                      </a>
                    );
                  })
                )}
              </div>
            </details>
          );
        })
    }
    </div>

    <div class="mobile-menu__utilities">
      <hr class="mobile-menu__divider" />

      <span class="mobile-menu__eyebrow mobile-menu__language-label">
        {t('nav.menu.language' as UIKey, locale)}
      </span>
      <div class="mobile-menu__locales">
        {alternates
          .filter((alt: { lang: string; href: string }) => enabledLocales.includes(alt.lang as Locale))
          .map((alt: { lang: string; href: string }) => {
            const isCurrent = alt.lang === locale;
            const label = locales[alt.lang as keyof typeof locales]?.label || alt.lang;
            return (
              <a
                href={alt.href}
                class={`mobile-menu__locale${isCurrent ? ' is-active' : ''}`}
                aria-current={isCurrent ? 'page' : undefined}
              >
                <span>{label}</span>
              </a>
            );
          })
        }
      </div>

      <button
        id="theme-toggle-mobile"
        class="theme-toggle mobile-menu__theme"
        aria-label={t('theme.toggle' as UIKey, locale)}
      >
        <svg class="sun-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="moon-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <span>{t('theme.toggle' as UIKey, locale)}</span>
      </button>
    </div>
  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('#mobile-menu-toggle');
  const panel = document.querySelector<HTMLElement>('#mobile-menu-panel');

  if (toggle && panel) {
    const openLabel = toggle.dataset.labelOpen || 'Abrir menu';
    const closeLabel = toggle.dataset.labelClose || 'Fechar menu';
    const main = document.querySelector<HTMLElement>('main');
    const footer = document.querySelector<HTMLElement>('[data-site-footer]');
    const desktopQuery = window.matchMedia('(min-width: 1024px)');
    const accordions = Array.from(panel.querySelectorAll<HTMLDetailsElement>('.mobile-accordion'));
    let previousOverflow = '';
    let mainWasInert = false;
    let footerWasInert = false;

    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

    const updatePanelHeight = () => {
      if (!isOpen()) return;
      const availableHeight = Math.max(0, window.innerHeight - panel.getBoundingClientRect().top);
      panel.style.setProperty('--mobile-menu-available-height', `${availableHeight}px`);
    };

    const getPanelFocusables = () => Array.from(
      panel.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), summary, [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((element) => element.getClientRects().length > 0);

    const syncAccordion = (accordion: HTMLDetailsElement) => {
      const summary = accordion.querySelector<HTMLElement>(':scope > summary');
      summary?.setAttribute('aria-expanded', String(accordion.open));
    };

    const openMenu = () => {
      if (isOpen()) return;

      previousOverflow = document.body.style.overflow;
      mainWasInert = main?.inert ?? false;
      footerWasInert = footer?.inert ?? false;

      panel.hidden = false;
      panel.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', closeLabel);
      document.body.style.overflow = 'hidden';
      if (main) main.inert = true;
      if (footer) footer.inert = true;

      panel.scrollTop = 0;
      updatePanelHeight();
      requestAnimationFrame(() => {
        (getPanelFocusables()[0] || panel).focus();
      });
    };

    const closeMenu = (restoreFocus = false) => {
      if (!isOpen()) return;

      panel.hidden = true;
      panel.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', openLabel);
      document.body.style.overflow = previousOverflow;
      if (main) main.inert = mainWasInert;
      if (footer) footer.inert = footerWasInert;

      if (restoreFocus && !desktopQuery.matches) toggle.focus();
    };

    accordions.forEach((accordion) => {
      const summary = accordion.querySelector<HTMLElement>(':scope > summary');
      syncAccordion(accordion);

      summary?.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        accordion.open = !accordion.open;
      });

      accordion.addEventListener('toggle', () => {
        syncAccordion(accordion);
        if (!accordion.open) return;

        accordions.forEach((otherAccordion) => {
          if (otherAccordion !== accordion && otherAccordion.open) {
            otherAccordion.open = false;
          }
        });
      });
    });

    toggle.addEventListener('click', () => {
      if (isOpen()) closeMenu();
      else openMenu();
    });

    panel.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen()) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        event.stopPropagation();
        closeMenu(true);
        return;
      }

      if (event.key !== 'Tab') return;

      const focusables = [toggle, ...getPanelFocusables()];
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement;

      if (event.shiftKey && active === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && active === last) {
        event.preventDefault();
        first.focus();
      } else if (!focusables.includes(active as HTMLElement)) {
        event.preventDefault();
        (getPanelFocusables()[0] || toggle).focus();
      }
    });

    document.addEventListener('focusin', (event) => {
      if (!isOpen() || !(event.target instanceof Node)) return;
      if (event.target === toggle || panel.contains(event.target)) return;
      (getPanelFocusables()[0] || toggle).focus();
    });

    desktopQuery.addEventListener('change', () => {
      if (desktopQuery.matches) closeMenu();
    });

    window.addEventListener('resize', updatePanelHeight);
    window.addEventListener('scroll', updatePanelHeight, { passive: true });
    window.visualViewport?.addEventListener('resize', updatePanelHeight);
    panel.addEventListener('animationend', updatePanelHeight);
    window.addEventListener('pagehide', () => closeMenu());
  }
</script>
