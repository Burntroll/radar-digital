---
import { getDateLocale, t, type Locale } from '../i18n/utils';
import { routePath } from '../i18n/utils';

export interface Props {
  article: {
    slug?: string;
    data: {
      draft?: boolean;
      slug?: string;
      subtema: string;
      readTime: string;
      title: string;
      excerpt: string;
      date: Date;
      color?: string;
    };
  };
  locale: Locale;
  accent: 'cyan' | 'purple' | 'amber';
}

const { article: artigo, locale, accent } = Astro.props;
const href = artigo.data.draft ? '#' : routePath('artigos', locale, artigo.slug || '');
const dateStr = artigo.data.draft
  ? t('cat.tag.em-breve', locale)
  : artigo.data.date.toLocaleDateString(getDateLocale(locale), {
      day: '2-digit', month: 'short', year: 'numeric',
    });
const ctaLabel = artigo.data.draft
  ? t('cat.tag.em-breve', locale)
  : (locale === 'pt-BR' ? 'Ler' : 'Leer');

interface AccentClasses {
  gradient: string;
  badge: string;
  hoverText: string;
  cta: string;
  svgWrap: string;
  svgIcon: string;
}

const colorMap: Record<string, AccentClasses> = {
  cyan: {
    gradient: 'from-cyan-500/15 via-blue-600/5',
    badge: 'bg-cyan-500/10 text-cyan-500 border-cyan-500/20',
    hoverText: 'group-hover:text-cyan-500',
    cta: 'text-cyan-500',
    svgWrap: 'text-cyan-500/40 group-hover:text-cyan-500/70',
    svgIcon: 'M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z',
  },
  purple: {
    gradient: 'from-purple-500/15 via-pink-600/5',
    badge: 'bg-purple-500/10 text-purple-500 border-purple-500/20',
    hoverText: 'group-hover:text-purple-500',
    cta: 'text-purple-500',
    svgWrap: 'text-purple-500/40 group-hover:text-purple-500/70',
    svgIcon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
  },
  amber: {
    gradient: 'from-amber-500/15 via-orange-600/5',
    badge: 'bg-amber-500/10 text-amber-500 border-amber-500/20',
    hoverText: 'group-hover:text-amber-500',
    cta: 'text-amber-500',
    svgWrap: 'text-amber-500/40 group-hover:text-amber-500/70',
    svgIcon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
};

const c = colorMap[accent];
---

<article class="glass-card interactive-card overflow-hidden group h-full">
  <a href={href} class="flex h-full flex-col">
    <div class={`h-40 bg-gradient-to-br ${c.gradient} to-surface-elevated flex items-center justify-center transition-colors`}>
      <svg class={`w-9 h-9 ${c.svgWrap} transition-colors`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
        <path stroke-linecap="round" stroke-linejoin="round" d={c.svgIcon} />
      </svg>
    </div>
    <div class="p-6 flex flex-1 flex-col">
      <div class="flex items-center gap-2 mb-3">
        <span class={`inline-block px-2.5 py-0.5 rounded-md text-[10px] font-semibold uppercase tracking-wider ${c.badge}`}>
          {artigo.data.subtema}
        </span>
        <span class="text-[10px] text-text-muted transition-colors">· {artigo.data.readTime}</span>
      </div>
      <h3 class={`font-semibold text-text-primary ${c.hoverText} transition-colors leading-snug mb-2`}>
        {artigo.data.title}
      </h3>
      <p class="text-xs text-text-muted leading-relaxed transition-colors line-clamp-3">
        {artigo.data.excerpt}
      </p>
      <div class="mt-auto pt-4 border-t transition-colors flex items-center justify-between" style="border-color: var(--color-border);">
        <span class="text-[10px] text-text-muted uppercase tracking-wider transition-colors">
          {dateStr}
        </span>
        <span class={`${c.cta} text-xs font-medium flex items-center gap-1 opacity-75 group-hover:opacity-100 transition-opacity`}>
          {ctaLabel}
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
