---
// ═══════════════════════════════════════════════════════════════════════════
// SiteFooter — rodapé global V4
//
// Renderiza marca, navegação editorial, recursos, idiomas e transparência.
// Apenas links para rotas que existem são incluídos.
// Páginas institucionais (Privacidade, Termos, Contato) pertencem ao Bloco 10.
// ═══════════════════════════════════════════════════════════════════════════

import { t, routePath, type Locale, type RouteKey, type UIKey } from '../i18n/utils';
import BrandMark from './BrandMark.astro';

interface Alternate {
  lang: string;
  href: string;
}

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: Alternate[];
}

const { locale, currentPath, alternates } = Astro.props;
const prefix = locale === 'pt-BR' ? '' : `/${locale}`;

interface FooterLink {
  labelKey: UIKey;
  href: string;
}

interface FooterSection {
  headingKey: UIKey;
  links: FooterLink[];
}

const editorialSection: FooterSection = {
  headingKey: 'footer.section.editorial' as UIKey,
  links: [
    { labelKey: 'nav.ia' as UIKey, href: routePath('inteligencia-artificial' as RouteKey, locale) },
    { labelKey: 'nav.marketing' as UIKey, href: routePath('marketing-digital' as RouteKey, locale) },
    { labelKey: 'nav.monetizacao' as UIKey, href: routePath('monetizacao' as RouteKey, locale) },
  ],
};

const resourcesSection: FooterSection = {
  headingKey: 'footer.section.resources' as UIKey,
  links: [
    { labelKey: 'nav.guias' as UIKey, href: routePath('guias' as RouteKey, locale) },
    { labelKey: 'nav.parceiros' as UIKey, href: routePath('parceiros' as RouteKey, locale) },
    { labelKey: 'nav.bonus' as UIKey, href: routePath('bonus' as RouteKey, locale) },
    { labelKey: 'nav.market' as UIKey, href: routePath('market' as RouteKey, locale) },
  ],
};

const sections: FooterSection[] = [editorialSection, resourcesSection];
---

<footer class="site-footer" data-site-footer>
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <!-- Brand column -->
      <div class="site-footer__brand">
        <a href={prefix || '/'} class="site-footer__logo" aria-label={t('footer.home.label' as UIKey, locale)}>
          <BrandMark aria-hidden="true" />
          <span class="site-footer__logo-text">Radar Digital</span>
        </a>
        <p class="site-footer__tagline">
          {t('footer.description' as UIKey, locale)}
        </p>
      </div>

      <!-- Section columns -->
      {sections.map((section) => (
        <nav class="site-footer__nav" aria-label={t(section.headingKey as UIKey, locale)}>
          <h3 class="site-footer__heading">
            {t(section.headingKey as UIKey, locale)}
          </h3>
          <ul class="site-footer__list">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={['site-footer__link', currentPath === link.href && 'site-footer__link--active'].filter(Boolean).join(' ')}
                  aria-current={currentPath === link.href ? 'page' : undefined}
                >
                  {t(link.labelKey as UIKey, locale)}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}

      <!-- Language section -->
      <nav class="site-footer__nav" aria-label={t('footer.section.institutional' as UIKey, locale)}>
        <h3 class="site-footer__heading">
          {t('footer.section.institutional' as UIKey, locale)}
        </h3>
        <ul class="site-footer__list">
          {alternates.map((alt) => {
            const isCurrent = alt.lang === locale;
            return (
              <li>
                <a
                  href={alt.href}
                  class={['site-footer__link', isCurrent && 'site-footer__link--active'].filter(Boolean).join(' ')}
                  hreflang={alt.lang}
                  lang={alt.lang}
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  {alt.lang === 'pt-BR' ? 'Português' : 'Español'}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </div>

    <!-- Transparency line -->
    <p class="site-footer__transparency">
      {t('footer.transparency' as UIKey, locale)}
    </p>

    <!-- Bottom bar -->
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">{t('footer.copyright' as UIKey, locale)}</p>
      <p class="site-footer__portal">{t('footer.portal' as UIKey, locale)}</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid var(--color-border);
  background: var(--color-surface-contrast);
  color: var(--color-text-inverse);
  transition: background-color 300ms ease, border-color 300ms ease;
}

.site-footer__inner {
  max-width: min(1440px, 100vw - var(--gutter-page) * 2);
  margin: 0 auto;
  padding: 3rem var(--gutter-page) 1.5rem;
}

.site-footer__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}

@media (min-width: 48rem) {
  .site-footer__grid {
    grid-template-columns: 2fr 1fr 1fr 1fr;
  }
}

.site-footer__brand {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.site-footer__logo {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: var(--color-text-inverse);
  transition: opacity 200ms ease;
}

.site-footer__logo:hover {
  opacity: 0.85;
}

.site-footer__logo:focus-visible {
  outline: 2px solid var(--color-signal);
  outline-offset: 3px;
  border-radius: 2px;
}

.site-footer__logo-text {
  font-family: var(--font-family-editorial);
  font-size: var(--type-card-title-size);
  font-weight: var(--type-card-title-weight);
  line-height: var(--type-card-title-leading);
}

.site-footer__tagline {
  color: rgb(var(--color-text-inverse-rgb) / 0.7);
  font-family: var(--font-family-functional);
  font-size: var(--type-summary-size);
  line-height: var(--type-summary-leading);
  max-width: 22rem;
}

.site-footer__nav {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.site-footer__heading {
  color: rgb(var(--color-text-inverse-rgb) / 0.5);
  font-family: var(--font-family-functional);
  font-size: var(--type-eyebrow-size);
  font-weight: 800;
  letter-spacing: 0.05em;
  line-height: var(--type-eyebrow-leading);
  text-transform: uppercase;
}

.site-footer__list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.site-footer__link {
  color: var(--color-text-inverse);
  font-family: var(--font-family-functional);
  font-size: 0.875rem;
  text-decoration: none;
  transition: color 200ms ease;
}

.site-footer__link:hover {
  color: var(--color-signal);
}

.site-footer__link:focus-visible {
  outline: 2px solid var(--color-signal);
  outline-offset: 2px;
  border-radius: 2px;
}

.site-footer__link--active {
  color: var(--color-signal);
  font-weight: 720;
}

.site-footer__transparency {
  margin-top: 2rem;
  padding: 0.75rem 0;
  border-top: 1px solid rgb(var(--color-text-inverse-rgb) / 0.12);
  color: rgb(var(--color-text-inverse-rgb) / 0.55);
  font-family: var(--font-family-functional);
  font-size: 0.75rem;
  line-height: 1.4;
}

.site-footer__bottom {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgb(var(--color-text-inverse-rgb) / 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  text-align: center;
}

@media (min-width: 48rem) {
  .site-footer__bottom {
    flex-direction: row;
    justify-content: space-between;
  }
}

.site-footer__copyright {
  color: rgb(var(--color-text-inverse-rgb) / 0.5);
  font-family: var(--font-family-functional);
  font-size: 0.75rem;
}

.site-footer__portal {
  color: rgb(var(--color-text-inverse-rgb) / 0.55);
  font-family: var(--font-family-functional);
  font-size: 0.6875rem;
}
</style>
