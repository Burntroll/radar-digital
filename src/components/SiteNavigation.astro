---
// Navegação desktop V4 derivada exclusivamente de mainNavigation.
// O contrato de rótulos, agrupamentos, elegibilidade e rotas permanece centralizado
// em src/config/siteNavigation.ts. Details/summary preserva o disclosure nativo;
// o script abaixo acrescenta Escape, exclusividade entre painéis e clique externo.

import { t, routePath, defaultLocale, type Locale, type RouteKey, type UIKey } from '../i18n/utils';
import {
  mainNavigation,
  type NavLinkItem,
  type NavGroupItem,
  type NavGroupedSubGroup,
} from '../config/siteNavigation';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props as Props;
const prefix = locale === defaultLocale ? '' : '/' + locale;

function isActiveRoute(item: NavLinkItem): boolean {
  if (!item.routeKey) {
    const homePath = prefix || '/';
    return currentPath === homePath || currentPath === homePath + '/';
  }

  const route = routePath(item.routeKey as RouteKey, locale);
  return currentPath === route || currentPath === route + '/';
}

function groupHasActive(children: (NavLinkItem | NavGroupItem)[]): boolean {
  for (const child of children) {
    if (child.type === 'link' && isActiveRoute(child)) return true;
    if (child.type === 'group' && groupHasActive(child.children)) return true;
  }

  return false;
}

function linkHref(item: NavLinkItem): string {
  if (!item.routeKey) return prefix || '/';
  return routePath(item.routeKey as RouteKey, locale);
}
---

<div class="site-navigation" data-desktop-navigation>
  {
    mainNavigation
      .filter((section) => section.eligible)
      .map((section) => {
        const item = section.item;

        if (item.type === 'link') {
          const active = isActiveRoute(item);

          return (
            <a
              href={linkHref(item)}
              class={['site-navigation__link', active && 'is-active'].filter(Boolean).join(' ')}
              aria-current={active ? 'page' : undefined}
            >
              {t(item.labelKey as UIKey, locale)}
            </a>
          );
        }

        const group = item as NavGroupItem;
        const hasActive = groupHasActive(group.children);
        const isGrouped = group.presentation === 'grouped';
        const isMega = group.presentation === 'mega';

        return (
          <details
            class={[
              'nav-group',
              isGrouped && 'nav-group--grouped',
              isMega && 'nav-group--mega',
              hasActive && 'is-active',
            ].filter(Boolean).join(' ')}
          >
            <summary class="site-navigation__trigger" aria-expanded="false">
              <span>{t(group.labelKey as UIKey, locale)}</span>
              <svg
                class="nav-chevron"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>

            {isGrouped ? (
              <div class="nav-panel nav-panel--grouped">
                <div class="nav-mega-panel nav-mega-panel--grouped">
                  {group.groups?.filter((candidate) => candidate.children.length > 0).map((candidate) => {
                    const subGroup = candidate as NavGroupedSubGroup;

                    return (
                      <div class="nav-mega-group">
                        <span class="nav-mega-group-title">{t(subGroup.labelKey as UIKey, locale)}</span>
                        {subGroup.children.map((link) => {
                          const active = isActiveRoute(link);
                          const description = link.descKey ? t(link.descKey as UIKey, locale) : null;

                          return (
                            <a
                              href={linkHref(link)}
                              class={['nav-mega-item', active && 'is-active'].filter(Boolean).join(' ')}
                              aria-current={active ? 'page' : undefined}
                            >
                              <span class="nav-mega-label">{t(link.labelKey as UIKey, locale)}</span>
                              {description && <span class="nav-mega-desc">{description}</span>}
                            </a>
                          );
                        })}
                      </div>
                    );
                  })}
                </div>
              </div>
            ) : isMega ? (
              <div class="nav-panel nav-panel--mega">
                <div class="nav-mega-panel">
                  {group.children.filter((child) => child.type === 'link').map((child) => {
                    const link = child as NavLinkItem;
                    const active = isActiveRoute(link);
                    const description = link.descKey ? t(link.descKey as UIKey, locale) : null;

                    return (
                      <a
                        href={linkHref(link)}
                        class={['nav-mega-item', active && 'is-active'].filter(Boolean).join(' ')}
                        aria-current={active ? 'page' : undefined}
                      >
                        <span class="nav-mega-label">{t(link.labelKey as UIKey, locale)}</span>
                        {description && <span class="nav-mega-desc">{description}</span>}
                      </a>
                    );
                  })}
                </div>
              </div>
            ) : (
              <div class="nav-panel nav-panel--compact">
                <div class="nav-mega-panel nav-mega-panel--compact">
                  {group.children.filter((child) => child.type === 'link').map((child) => {
                    const link = child as NavLinkItem;
                    const active = isActiveRoute(link);

                    return (
                      <a
                        href={linkHref(link)}
                        class={['nav-mega-item', active && 'is-active'].filter(Boolean).join(' ')}
                        aria-current={active ? 'page' : undefined}
                      >
                        <span class="nav-mega-label">{t(link.labelKey as UIKey, locale)}</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            )}
          </details>
        );
      })
  }
</div>

<script>
  const desktopNavigations = document.querySelectorAll<HTMLElement>('[data-desktop-navigation]');

  desktopNavigations.forEach((navigation) => {
    const groups = Array.from(navigation.querySelectorAll<HTMLDetailsElement>('.nav-group'));

    const syncExpandedState = (group: HTMLDetailsElement) => {
      const trigger = group.querySelector<HTMLElement>(':scope > summary');
      trigger?.setAttribute('aria-expanded', String(group.open));
    };

    groups.forEach((group) => {
      syncExpandedState(group);

      group.addEventListener('toggle', () => {
        syncExpandedState(group);

        if (group.open) {
          groups.forEach((otherGroup) => {
            if (otherGroup !== group && otherGroup.open) otherGroup.open = false;
          });
        }
      });
    });

    navigation.addEventListener('keydown', (event) => {
      const trigger = event.target instanceof HTMLElement
        ? event.target.closest<HTMLElement>('.site-navigation__trigger')
        : null;

      if (trigger && (event.key === 'Enter' || event.key === ' ')) {
        const group = trigger.parentElement;
        if (group instanceof HTMLDetailsElement) group.open = !group.open;
        event.preventDefault();
        return;
      }

      if (event.key !== 'Escape') return;

      const openGroup = groups.find((group) => group.open);
      if (!openGroup) return;

      const escapeTrigger = openGroup.querySelector<HTMLElement>(':scope > summary');
      openGroup.open = false;
      escapeTrigger?.focus();
      event.preventDefault();
      event.stopPropagation();
    });

    document.addEventListener('pointerdown', (event) => {
      if (!(event.target instanceof Node) || navigation.contains(event.target)) return;
      groups.forEach((group) => {
        if (group.open) group.open = false;
      });
    });
  });
</script>
