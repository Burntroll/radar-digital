---
// ═══════════════════════════════════════════════════════════════════════════
// SiteNavigation — componente de navegação principal
//
// Renderiza a estrutura-base aprovada:
//   - Início (anchor)
//   - Setores (disclosure) → Inteligência Artificial (mega menu)
//   - Operação (disclosure) → Marketing Digital, Monetização
//   - Verticais → oculto (eligible=false)
//   - Recursos (disclosure) → Guias
//   - Radar Market (anchor)
//
// Usa <details>/<summary> para grupos, garantindo funcionamento
// por clique, teclado e viewports estreitas sem JS adicional.
// Setores usa apresentação mega menu com título + descrição.
// ═══════════════════════════════════════════════════════════════════════════

import { t, routePath, defaultLocale, type Locale } from '../i18n/utils';
import { enabledLocales, locales } from '../i18n/config';
import { mainNavigation, type NavLinkItem, type NavGroupItem, type NavGroupedSubGroup } from '../config/siteNavigation';

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: { lang: string; href: string }[];
}

const { locale, currentPath, alternates } = Astro.props;
const prefix = locale === defaultLocale ? '' : `/${locale}`;

// ─── Helpers ───────────────────────────────────────────────────────

/** Retorna true se o path atual corresponde a uma rota do item */
function isActiveRoute(item: NavLinkItem): boolean {
  if (!item.routeKey) {
    // home
    const homePath = prefix || '/';
    return currentPath === homePath || currentPath === homePath + '/';
  }
  const route = routePath(item.routeKey as any, locale);
  return currentPath === route || currentPath === route + '/';
}

/** Verifica se algum filho de um grupo está ativo */
function groupHasActive(children: (NavLinkItem | NavGroupItem)[]): boolean {
  for (const child of children) {
    if (child.type === 'link' && isActiveRoute(child)) return true;
    if (child.type === 'group' && groupHasActive(child.children)) return true;
  }
  return false;
}

/** Gera a URL para um NavLinkItem */
function linkHref(item: NavLinkItem): string {
  if (!item.routeKey) return prefix || '/';
  return routePath(item.routeKey as any, locale);
}
---

<div class="flex items-center gap-4 overflow-x-auto">
{
  mainNavigation
    .filter((section) => section.eligible)
    .map((section) => {
      const item = section.item;
      if (item.type === 'link') {
        const active = isActiveRoute(item);
        const href = linkHref(item);
        return (
          <a
            href={href}
            class="text-base text-text-secondary hover:text-cyan-500 transition-colors whitespace-nowrap"
            aria-current={active ? 'page' : undefined}
          >
            {item.icon === 'tools' && (
              <svg class="w-4 h-4 inline-block align-middle mr-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-7.42 7.42-1.41-1.41 7.42-7.42m0 0a5.5 5.5 0 117.07-7.07l-2.12 2.12a1.5 1.5 0 000 2.12l2.12 2.12a5.5 5.5 0 01-7.07 7.07z" />
              </svg>
            )}
            {item.icon === 'bonus' && (
              <svg class="w-4 h-4 inline-block align-middle mr-1.5 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V3m0 0l-3 3m3-3l3 3m-9 7h6a2 2 0 012 2v1a2 2 0 01-2 2H9a2 2 0 01-2-2v-1a2 2 0 012-2z" />
              </svg>
            )}
            {t(item.labelKey as any, locale)}
          </a>
        );
      } else {
        // group
        const group = item as NavGroupItem;
        const hasActive = groupHasActive(group.children);
        const isMega = group.presentation === 'mega' || group.presentation === 'grouped';
        const isGrouped = group.presentation === 'grouped';

        return (
          <details class={`nav-group relative${isGrouped ? ' nav-grouped' : ''}`}>
            <summary
              class={`text-base transition-colors whitespace-nowrap list-none cursor-pointer
                ${hasActive ? 'text-cyan-500' : 'text-text-secondary hover:text-cyan-500'}`}
            >
              {t(group.labelKey as any, locale)}
              <svg class="nav-chevron w-3.5 h-3.5 ml-1 inline-block align-middle transition-transform"
                   fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
              </svg>
            </summary>
            {isGrouped ? (
              <div class={`nav-panel absolute top-full pt-2 z-50${isGrouped ? ' nav-panel-grouped' : ''}`}
                   style={isGrouped ? undefined : 'left:0'}
                   >
                <div class="nav-mega-panel nav-mega-panel-grouped">
                  {group.groups?.filter(g => g.children.length > 0).map((sub) => {
                    const subGrp = sub as NavGroupedSubGroup;
                    return (
                      <div class="nav-mega-group">
                        <span class="nav-mega-group-title">{t(subGrp.labelKey as any, locale)}</span>
                        {subGrp.children.map((link) => {
                          const active = isActiveRoute(link);
                          const desc = link.descKey ? t(link.descKey as any, locale) : null;
                          return (
                            <a
                              href={linkHref(link)}
                              class={`nav-mega-item ${active ? 'nav-mega-item-active' : ''}`}
                              aria-current={active ? 'page' : undefined}
                            >
                              <span class="nav-mega-label">{t(link.labelKey as any, locale)}</span>
                              {desc && <span class="nav-mega-desc">{desc}</span>}
                            </a>
                          );
                        })}
                      </div>
                    );
                  })}
                </div>
              </div>
            ) : isMega ? (
              <div class="nav-panel absolute left-0 top-full pt-2 z-50">
                <div class="nav-mega-panel">
                  {group.children.filter(c => c.type === 'link').map((child) => {
                    const link = child as NavLinkItem;
                    const active = isActiveRoute(link);
                    const desc = link.descKey ? t(link.descKey as any, locale) : null;
                    return (
                      <a
                        href={linkHref(link)}
                        class={`nav-mega-item ${active ? 'nav-mega-item-active' : ''}`}
                        aria-current={active ? 'page' : undefined}
                      >
                        <span class="nav-mega-label">{t(link.labelKey as any, locale)}</span>
                        {desc && <span class="nav-mega-desc">{desc}</span>}
                      </a>
                    );
                  })}
                </div>
              </div>
            ) : (
              <div class="nav-panel absolute left-0 top-full pt-2 z-50 min-w-48">
                <div class="rounded-xl border shadow-2xl overflow-hidden transition-colors"
                     style="background: var(--color-surface-elevated, #15171f); border-color: var(--color-border, #1e2130);">
                  <div class="py-1">
                    {group.children.filter(c => c.type === 'link').map((child) => {
                      const link = child as NavLinkItem;
                      const active = isActiveRoute(link);
                      return (
                        <a
                          href={linkHref(link)}
                          class={`block px-4 py-2.5 text-sm transition-colors
                            ${active
                              ? 'text-cyan-500 font-semibold bg-cyan-500/10'
                              : 'text-text-secondary hover:bg-cyan-500/10 hover:text-cyan-500'}`}
                          aria-current={active ? 'page' : undefined}
                        >
                          {t(link.labelKey as any, locale)}
                        </a>
                      );
                    })}
                  </div>
                </div>
              </div>
            )}
          </details>
        );
      }
    })
}

</div>

<!-- Locale Switcher -->
<details class="nav-group relative">
  <summary
    class="text-base transition-colors whitespace-nowrap list-none cursor-pointer flex items-center gap-1.5 px-2 text-text-secondary hover:text-cyan-500"
    aria-label={t('locale.switcher.label' as any, locale)}
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
    </svg>
    <span class="text-xs font-semibold uppercase">{t('layout.locale.label' as any, locale)}</span>
    <svg class="nav-chevron w-3.5 h-3.5 ml-1 inline-block align-middle transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
    </svg>
  </summary>
  <div class="nav-panel absolute right-0 top-full pt-2 z-50">
    <div class="w-40 rounded-xl border shadow-2xl overflow-hidden transition-colors"
         style="background: var(--color-surface-elevated, #15171f); border-color: var(--color-border, #1e2130);">
      {alternates.map((alt) => {
        const isCurrent = alt.lang === locale;
        const label = (enabledLocales.includes(alt.lang as any))
          ? locales[alt.lang as keyof typeof locales]?.label
          : null;
        if (!label) return null;
        return (
          <a
            href={alt.href}
            class={`block px-4 py-2.5 text-sm transition-colors ${isCurrent
              ? 'text-cyan-500 font-semibold bg-cyan-500/10 locale-active'
              : 'text-text-secondary hover:bg-cyan-500/10 hover:text-cyan-500'}`}
            aria-current={isCurrent ? 'true' : 'false'}
          >
            <span class="flex items-center justify-between">
              <span>{label}</span>
              <span class="text-[10px] font-bold uppercase opacity-60">{t('layout.locale.label' as any, alt.lang as Locale)}</span>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</details>

<!-- Theme Toggle -->
<button id="theme-toggle" class="theme-toggle" aria-label={t('theme.toggle' as any, locale)}>
  <svg class="sun-icon w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  <svg class="moon-icon w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<style>
  /* Chevron gira quando details está aberto */
  .nav-group[open] .nav-chevron {
    transform: rotate(180deg);
  }

  /* details > summary no marker padrão */
  .nav-group summary::-webkit-details-marker {
    display: none;
  }

  /* ─── Mega panel (apenas Setores) ─── */
  .nav-mega-panel {
    min-width: 14rem;
    padding: 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border, #1e2130);
    background: var(--color-surface-elevated, #15171f);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .nav-mega-item {
    display: block;
    padding: 0.5rem 0.625rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .nav-mega-item:hover {
    background: rgba(0, 229, 255, 0.06);
  }

  .nav-mega-item-active {
    background: rgba(0, 229, 255, 0.08);
  }

  .nav-mega-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-primary, #f1f5f9);
    line-height: 1.25rem;
    display: block;
  }

  .nav-mega-item-active .nav-mega-label {
    color: var(--color-accent, #06b6d4);
  }

  .nav-mega-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted, #64748b);
    line-height: 1.125rem;
    margin-top: 0.125rem;
    display: block;
  }

  /* ─── Grouped panel (apenas Operação) ─── */
  .nav-mega-panel-grouped {
    display: flex;
    gap: 0.5rem;
  }

  .nav-mega-group {
    min-width: 10rem;
  }

  .nav-mega-group-title {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted, #64748b);
    padding: 0.375rem 0.625rem 0.25rem;
  }
</style>

<style is:global>
  /* Panel agrupado de Operação — mobile responsivo */
  @media (max-width: 640px) {
    .nav-panel-grouped {
      position: fixed !important;
      top: 3.5rem !important;
      left: 0.5rem !important;
      right: 0.5rem !important;
      width: auto !important;
    }
    .nav-grouped .nav-mega-panel-grouped {
      max-width: 100%;
      flex-wrap: wrap;
    }
  }
</style>
