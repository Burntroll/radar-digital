---
import type { HomeArticle } from '../utils/homeData';
import { getDateLocale, routePath, t, type Locale } from '../i18n/utils';

interface Props {
  article: HomeArticle;
  locale: Locale;
  featured?: boolean;
}

const { article, locale, featured = false } = Astro.props as Props;
const href = routePath('artigos', locale, article.slug);
const titleId = `story-card-title-${article.id.replace(/[^a-z0-9]+/gi, '-')}`;
const dateText = article.data.date.toLocaleDateString(getDateLocale(locale), {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const imageSrc = article.data.image?.startsWith('/') ? article.data.image : null;
const formatLabel = article.data.contentType === 'guide'
  ? t('home.article.guide.badge', locale)
  : article.data.subtema;
---

<article
  class:list={['story-card', { 'story-card--featured': featured }]}
  data-story-card
  data-featured={featured ? 'true' : 'false'}
  data-image={imageSrc ? 'available' : 'placeholder'}
  data-summary={featured ? 'visible' : 'omitted'}
>
  <a class="story-card__link" href={href} aria-labelledby={titleId}>
    <div class="story-card__media" aria-hidden="true">
      {imageSrc ? (
        <img src={imageSrc} alt="" width="960" height="600" loading="lazy" decoding="async" />
      ) : (
        <span class="story-card__signal">{article.data.emoji || '📡'}</span>
      )}
    </div>

    <div class="story-card__body">
      <span class="story-card__kicker">{formatLabel}</span>
      <h3 id={titleId}>{article.data.title}</h3>
      {featured && <p>{article.data.excerpt}</p>}

      <div class="story-card__meta">
        <time datetime={article.data.date.toISOString()}>{dateText}</time>
        <span>{article.data.readTime}</span>
        <span class="story-card__cta" aria-hidden="true">
          {t('home.article.read', locale)} <span>→</span>
        </span>
      </div>
    </div>
  </a>
</article>
