---
/**
 * EmptyState — Estado vazio padronizado para listas e filtros.
 *
 * Uso:
 *   <EmptyState title="Nenhum resultado" />
 *   <EmptyState title="Nenhum resultado" description="Tente ajustar sua busca." />
 *   <EmptyState title="..." id="guide-empty-state" hidden />
 *
 * Props:
 *   title       — obrigatório, texto do título
 *   description — opcional, texto da descrição
 *   id          — opcional, id do elemento
 *   class:      — opcional, classes adicionais
 *   hidden      — opcional, boolean para ocultar via atributo HTML
 *   icon        — opcional, emoji/ícone exibido acima do título
 */

export interface Props {
  title: string;
  description?: string;
  id?: string;
  class?: string;
  hidden?: boolean;
  icon?: string;
}

const { title, description, id, hidden, icon, class: className } = Astro.props;
---

<div
  id={id}
  class={`glass-card p-12 text-center${className ? ' ' + className : ''}`}
  aria-live="polite"
  {hidden}
>
  {icon && (
    <div class="text-5xl mb-4">{icon}</div>
  )}
  <h3 class="text-xl font-bold text-text-primary mb-2">{title}</h3>
  {description && (
    <p class="text-text-muted text-sm max-w-md mx-auto">{description}</p>
  )}
</div>
