---
import BrandMark from './BrandMark.astro';
import MobileNavigation from './MobileNavigation.astro';
import { getDateLocale, t, defaultLocale, type Locale } from '../i18n/utils';
import { locales } from '../i18n/config';

interface Props {
  locale: Locale;
  currentPath: string;
  alternates: { lang: string; href: string }[];
}

const { locale, currentPath, alternates } = Astro.props;
const prefix = locale === defaultLocale ? '' : `/${locales[locale].prefix}`;
const homeHref = `${prefix}/`;
const newsletterHref = `${homeHref}#newsletter`;
const dateLocale = getDateLocale(locale);
const now = new Date();
const dateISO = now.toISOString().slice(0, 10);
const formattedDate = new Intl.DateTimeFormat(dateLocale, {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(now);
---

<div class="masthead">
  <div class="masthead__inner">
    <time class="masthead__date" datetime={dateISO} data-masthead-date data-locale={dateLocale}>
      {formattedDate}
    </time>

    <a class="masthead__brand" href={homeHref} aria-label={t('masthead.home.label', locale)}>
      <BrandMark />
      <span class="masthead__brand-copy">
        <strong>Radar Digital</strong>
      </span>
    </a>

    <div class="masthead__tools">
      <button class="masthead__search" type="button" data-search-open aria-label={t('masthead.search.label', locale)}>
        <span aria-hidden="true">⌕</span>
        <span class="masthead__search-text">{t('masthead.search.placeholder', locale)}</span>
      </button>
      <a class="masthead__newsletter" href={newsletterHref}>{t('signal.newsletter', locale)}</a>
      <button id="theme-toggle" class="theme-toggle masthead__theme" aria-label={t('theme.toggle', locale)}>
        <svg class="sun-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg class="moon-icon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
        <span>{t('masthead.theme', locale)}</span>
      </button>
      <MobileNavigation locale={locale} currentPath={currentPath} alternates={alternates} />
    </div>
  </div>
</div>

<script>
  const dateNodes = document.querySelectorAll<HTMLTimeElement>('[data-masthead-date]');
  const currentDate = new Date();

  dateNodes.forEach((node) => {
    const locale = node.dataset.locale || document.documentElement.lang;
    node.dateTime = currentDate.toISOString().slice(0, 10);
    node.textContent = new Intl.DateTimeFormat(locale, {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(currentDate);
  });
</script>
