---
// ═══════════════════════════════════════════════════════════════════════════
// NewsletterBlock — bloco visual de newsletter V4
//
// Apresentação editorial estática e honesta. Sem formulário, input ou botão.
// A integração real é responsabilidade do Bloco 9 (Plano de Ação 2.2).
//
// Props:
//   locale: Locale — define o idioma do conteúdo
// ═══════════════════════════════════════════════════════════════════════════

import { t, type Locale, type UIKey } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section
  id="newsletter"
  class="newsletter-block"
  aria-labelledby="newsletter-title"
>
  <div class="newsletter-block__container">
    <div class="newsletter-block__card">
      <!-- Decorative grid dots -->
      <div class="newsletter-block__dots" aria-hidden="true">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="10" cy="10" r="2" fill="currentColor"/><circle cx="30" cy="10" r="2" fill="currentColor"/>
          <circle cx="50" cy="10" r="2" fill="currentColor"/><circle cx="70" cy="10" r="2" fill="currentColor"/>
          <circle cx="90" cy="10" r="2" fill="currentColor"/><circle cx="10" cy="30" r="2" fill="currentColor"/>
          <circle cx="30" cy="30" r="2" fill="currentColor"/><circle cx="50" cy="30" r="2" fill="currentColor"/>
          <circle cx="70" cy="30" r="2" fill="currentColor"/><circle cx="90" cy="30" r="2" fill="currentColor"/>
        </svg>
      </div>

      <div class="newsletter-block__content">
        <span class="newsletter-block__eyebrow">
          {t('home.newsletter.eyebrow' as UIKey, locale)}
        </span>

        <h2 id="newsletter-title" class="newsletter-block__title">
          {t('home.newsletter.title' as UIKey, locale)}
        </h2>

        <p class="newsletter-block__desc">
          {t('home.newsletter.desc' as UIKey, locale)}
        </p>

        <div class="newsletter-block__status">
          <span class="newsletter-block__pill">
            {t('home.newsletter.status' as UIKey, locale)}
          </span>
        </div>

        <p class="newsletter-block__note">
          {t('home.newsletter.note' as UIKey, locale)}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
.newsletter-block {
  padding: 3.5rem 0;
  background: var(--color-canvas);
}

.newsletter-block__container {
  max-width: min(1440px, 100vw - var(--gutter-page) * 2);
  margin: 0 auto;
  padding: 0 var(--gutter-page);
}

.newsletter-block__card {
  position: relative;
  max-width: 48rem;
  margin: 0 auto;
  padding: 2.5rem 2rem;
  border-radius: var(--radius-md);
  background: var(--color-surface-primary);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-resting);
  text-align: center;
  overflow: hidden;
}

.newsletter-block__dots {
  position: absolute;
  top: -1.25rem;
  right: -1.875rem;
  width: 10rem;
  height: 10rem;
  color: rgb(var(--color-signal-rgb) / 0.08);
  pointer-events: none;
}

:global(.dark) .newsletter-block__dots {
  color: rgb(var(--color-signal-rgb) / 0.06);
}

.newsletter-block__content {
  position: relative;
  z-index: 1;
}

.newsletter-block__eyebrow {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  background: rgb(var(--color-signal-rgb) / 0.12);
  color: var(--color-text-primary);
  font-family: var(--font-family-functional);
  font-size: var(--type-eyebrow-size);
  font-weight: 800;
  letter-spacing: 0.05em;
  line-height: var(--type-eyebrow-leading);
  text-transform: uppercase;
}

.newsletter-block__title {
  margin-top: 1rem;
  font-family: var(--font-family-editorial);
  font-size: var(--type-section-size);
  font-weight: var(--type-section-weight);
  line-height: var(--type-section-leading);
  color: var(--color-text-primary);
}

.newsletter-block__desc {
  max-width: 28rem;
  margin: 0.75rem auto 0;
  color: var(--color-text-secondary);
  font-family: var(--font-family-functional);
  font-size: var(--type-summary-size);
  line-height: var(--type-summary-leading);
}

.newsletter-block__status {
  margin-top: 1.25rem;
}

.newsletter-block__pill {
  display: inline-block;
  padding: 0.375rem 1rem;
  border-radius: 9999px;
  background: rgb(var(--color-surface-contrast-rgb));
  color: rgb(var(--color-text-inverse-rgb));
  font-family: var(--font-family-functional);
  font-size: 0.8125rem;
  font-weight: 720;
  letter-spacing: 0.025em;
}

.newsletter-block__note {
  margin-top: 0.75rem;
  color: var(--color-text-muted);
  font-family: var(--font-family-functional);
  font-size: 0.8125rem;
  line-height: 1.4;
  max-width: 22rem;
  margin-left: auto;
  margin-right: auto;
}
</style>
