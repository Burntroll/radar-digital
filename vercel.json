{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/es/bonus",
      "destination": "/es/bonos",
      "permanent": true
    },
    {
      "source": "/es/monetizacao",
      "destination": "/es/monetizacion",
      "permanent": true
    },
    {
      "source": "/es/artigos/:slug*",
      "destination": "/es/articulos/:slug*",
      "permanent": true
    },
    {
      "source": "/parceiros",
      "destination": "/ferramentas",
      "permanent": true
    },
    {
      "source": "/parceiros/:slug*",
      "destination": "/ferramentas/:slug*",
      "permanent": true
    },
    {
      "source": "/es/parceiros",
      "destination": "/es/herramientas",
      "permanent": true
    },
    {
      "source": "/es/parceiros/:slug*",
      "destination": "/es/herramientas/:slug*",
      "permanent": true
    }
  ]
}
