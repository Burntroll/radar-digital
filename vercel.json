{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/es/bonus",
      "destination": "/es/bonos",
      "permanent": true
    },
    {
      "source": "/es/monetizacao",
      "destination": "/es/monetizacion",
      "permanent": true
    }
  ]
}
